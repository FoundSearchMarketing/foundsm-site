            <form class="site-footer__newsletter-form" action="#">
              <label class="site-footer__label" for="footer-newsletter-email">Email address</label>
              <div class="site-footer__field-row">
                <input
                  class="site-footer__input"
                  id="footer-newsletter-email"
                  name="email"
                  type="email"
                  placeholder="name@company.com"
                  autocomplete="email"
                />
                <button class="site-footer__newsletter-button" type="button">Join the List</button>
              </div>
            </form>
          </div>
        </section>

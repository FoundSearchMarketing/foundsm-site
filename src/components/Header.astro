---
---

<header class="site-header" id="site-header">
  <nav class="navbar" aria-label="Main navigation">
    <div class="container navbar__inner">
      <a href="/" class="navbar__logo" aria-label="Found Search Marketing - Home">
        <img src="/images/logo.svg" alt="Found Search Marketing" width="160" height="33" loading="eager" />
      </a>

      <ul class="navbar__menu" id="navbar-menu" role="menubar">
        <li class="navbar__item" role="none">
          <a href="/our-approach" class="navbar__link" role="menuitem">Our Approach</a>
        </li>
        <li class="navbar__item navbar__item--dropdown" role="none">
          <button class="navbar__link navbar__dropdown-toggle" aria-expanded="false" aria-haspopup="true" role="menuitem">
            Capabilities
            <svg class="navbar__chevron" width="12" height="12" viewBox="0 0 12 12" aria-hidden="true"><path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" fill="none"/></svg>
          </button>
          <ul class="navbar__dropdown" role="menu" aria-label="Capabilities submenu">
            <li role="none"><a href="/capabilities/paid-media" class="navbar__dropdown-link" role="menuitem">Paid Media</a></li>
            <li role="none"><a href="/capabilities/data-activation" class="navbar__dropdown-link" role="menuitem">Data Activation</a></li>
            <li role="none"><a href="/capabilities/data-intelligence" class="navbar__dropdown-link" role="menuitem">Data Intelligence</a></li>
            <li role="none"><a href="/capabilities/performance-creative" class="navbar__dropdown-link" role="menuitem">Performance Creative</a></li>
          </ul>
        </li>
        <li class="navbar__item" role="none">
          <a href="/insights" class="navbar__link" role="menuitem">Insights</a>
        </li>
        <li class="navbar__item navbar__item--dropdown" role="none">
          <button class="navbar__link navbar__dropdown-toggle" aria-expanded="false" aria-haspopup="true" role="menuitem">
            About Us
            <svg class="navbar__chevron" width="12" height="12" viewBox="0 0 12 12" aria-hidden="true"><path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" fill="none"/></svg>
          </button>
          <ul class="navbar__dropdown" role="menu" aria-label="About Us submenu">
            <li role="none"><a href="/team" class="navbar__dropdown-link" role="menuitem">Team</a></li>
          </ul>
        </li>
        <li class="navbar__item navbar__item--cta" role="none">
          <a href="/contact-us" class="btn btn--dark" role="menuitem">Contact Us</a>
        </li>
        <li class="navbar__item navbar__item--cta" role="none">
          <a href="/about-us" class="btn btn--green" role="menuitem">Join Us</a>
        </li>
      </ul>

      <button class="navbar__hamburger" id="navbar-hamburger" aria-label="Toggle navigation menu" aria-expanded="false" aria-controls="navbar-menu">
        <span class="navbar__hamburger-line"></span>
        <span class="navbar__hamburger-line"></span>
        <span class="navbar__hamburger-line"></span>
      </button>
    </div>
  </nav>
</header>

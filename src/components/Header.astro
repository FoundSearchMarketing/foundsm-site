---
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const isExactPath = (href: string) => currentPath === (href.replace(/\/$/, '') || '/');
const isPathSection = (href: string) => {
  const normalizedHref = href.replace(/\/$/, '') || '/';
  return currentPath === normalizedHref || currentPath.startsWith(`${normalizedHref}/`);
};
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="site-header__brand" href="/" aria-label="Found Search Marketing home">
      <img
        class="site-header__logo"
        src="/images/logo.svg"
        alt="Found Search Marketing"
        width="209"
        height="43"
        loading="eager"
      />
    </a>

    <nav
      class="site-header__nav"
      id="primary-navigation"
      aria-label="Primary"
      aria-hidden="true"
    >
      <ul class="site-header__menu" role="list">
        <li class="site-header__item">
          <a class="site-header__link" href="/our-approach/">Our Approach</a>
        </li>
        <li class="site-header__item">
          <a class="site-header__link" href="/insights/">Insights</a>
        </li>
        <li class="site-header__item site-header__item--has-submenu">
          <a class="site-header__link" href="/capabilities/" aria-current={isExactPath('/capabilities/') ? 'page' : undefined}>Capabilities</a>
          <button
            class="site-header__submenu-toggle"
            type="button"
            aria-label="Toggle Capabilities submenu"
            aria-expanded="false"
            aria-controls="submenu-capabilities"
            aria-haspopup="true"
          >
            <span class="site-header__sr-only">Toggle Capabilities submenu</span>
          </button>
          <ul
            class="site-header__submenu"
            id="submenu-capabilities"
            role="list"
            aria-hidden="true"
          >
            <li><a class="site-header__submenu-link" href="/capabilities/paid-media/" aria-current={isExactPath('/capabilities/paid-media/') ? 'page' : undefined}>Paid Media</a></li>
            <li><a class="site-header__submenu-link" href="/capabilities/data-activation/" aria-current={isExactPath('/capabilities/data-activation/') ? 'page' : undefined}>Data Activation</a></li>
            <li><a class="site-header__submenu-link" href="/capabilities/data-intelligence/" aria-current={isExactPath('/capabilities/data-intelligence/') ? 'page' : undefined}>Data Intelligence</a></li>
            <li><a class="site-header__submenu-link" href="/capabilities/performance-creative/" aria-current={isExactPath('/capabilities/performance-creative/') ? 'page' : undefined}>Performance Creative</a></li>
          </ul>
        </li>
        <li class="site-header__item site-header__item--has-submenu">
          <a class="site-header__link" href="/about-us/" aria-current={isExactPath('/about-us/') ? 'page' : undefined}>About Us</a>
          <button
            class="site-header__submenu-toggle"
            type="button"
            aria-label="Toggle About Us submenu"
            aria-expanded="false"
            aria-controls="submenu-about"
            aria-haspopup="true"
          >
            <span class="site-header__sr-only">Toggle About Us submenu</span>
          </button>
          <ul
            class="site-header__submenu"
            id="submenu-about"
            role="list"
            aria-hidden="true"
          >
            <li><a class="site-header__submenu-link" href="/newsletter/">Newsletter</a></li>
            <li><a class="site-header__submenu-link" href="/team/">Team</a></li>
          </ul>
        </li>
        <li class="site-header__item site-header__item--cta">
          <a class="site-header__link site-header__cta site-header__cta--primary" href="/contact-us/">Contact Us</a>
        </li>
        <li class="site-header__item site-header__item--cta">
          <a class="site-header__link site-header__cta site-header__cta--secondary" href="/about-us/">Join Us</a>
        </li>
      </ul>
    </nav>

    <button
      class="site-header__menu-toggle"
      type="button"
      aria-label="Open navigation menu"
      aria-controls="primary-navigation"
      aria-expanded="false"
    >
      <svg class="site-header__menu-icon site-header__menu-icon--open" aria-hidden="true" viewBox="0 0 24 24" fill="none">
        <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-linecap="round" stroke-width="2"></path>
      </svg>
      <svg class="site-header__menu-icon site-header__menu-icon--close" aria-hidden="true" viewBox="0 0 24 24" fill="none">
        <path d="m6 6 12 12M18 6 6 18" stroke="currentColor" stroke-linecap="round" stroke-width="2"></path>
      </svg>
      <span class="site-header__sr-only">Toggle navigation menu</span>
    </button>
  </div>
</header>

<script>
  (() => {
    const header = document.querySelector<HTMLElement>(".site-header");
    const nav = document.querySelector<HTMLElement>(".site-header__nav");
    const menuToggle = document.querySelector<HTMLButtonElement>(".site-header__menu-toggle");
    const submenuItems = Array.from(
      document.querySelectorAll<HTMLElement>(".site-header__item--has-submenu")
    );
    const mobileQuery = window.matchMedia("(max-width: 1024px)");

    if (!header || !nav || !menuToggle) {
      return;
    }

    const setSubmenuOpen = (item: HTMLElement, open: boolean) => {
      const toggle = item.querySelector<HTMLButtonElement>(".site-header__submenu-toggle");
      const submenu = item.querySelector<HTMLElement>(".site-header__submenu");
      if (!toggle || !submenu) return;

      item.classList.toggle("is-submenu-open", open);
      toggle.setAttribute("aria-expanded", String(open));
      submenu.setAttribute("aria-hidden", String(!open));
    };

    const closeAllSubmenus = (except: HTMLElement | null = null) => {
      submenuItems.forEach((item) => {
        if (item !== except) {
          setSubmenuOpen(item, false);
        }
      });
    };

    const setMenuOpen = (open: boolean) => {
      header.classList.toggle("is-menu-open", open);
      menuToggle.setAttribute("aria-expanded", String(open));
      menuToggle.setAttribute(
        "aria-label",
        open ? "Close navigation menu" : "Open navigation menu"
      );
      nav.setAttribute("aria-hidden", mobileQuery.matches ? String(!open) : "false");

      if (!open) {
        closeAllSubmenus();
      }
    };

    const syncViewportState = () => {
      if (mobileQuery.matches) {
        nav.setAttribute(
          "aria-hidden",
          String(!header.classList.contains("is-menu-open"))
        );
      } else {
        header.classList.remove("is-menu-open");
        nav.setAttribute("aria-hidden", "false");
        closeAllSubmenus();
        menuToggle.setAttribute("aria-expanded", "false");
        menuToggle.setAttribute("aria-label", "Open navigation menu");
      }
    };

    const updateScrollState = () => {
      header.classList.toggle("is-scrolled", window.scrollY > 8);
    };

    menuToggle.addEventListener("click", () => {
      setMenuOpen(!header.classList.contains("is-menu-open"));
    });

    const closeTimers = new WeakMap<HTMLElement, number>();
    const HOVER_CLOSE_DELAY = 150;

    const cancelCloseTimer = (item: HTMLElement) => {
      const timer = closeTimers.get(item);
      if (timer !== undefined) {
        window.clearTimeout(timer);
        closeTimers.delete(item);
      }
    };

    submenuItems.forEach((item) => {
      const toggle = item.querySelector<HTMLButtonElement>(".site-header__submenu-toggle");
      if (!toggle) return;

      toggle.addEventListener("click", (event) => {
        event.preventDefault();
        event.stopPropagation();

        cancelCloseTimer(item);
        const open = !item.classList.contains("is-submenu-open");
        closeAllSubmenus(open ? item : null);
        setSubmenuOpen(item, open);
      });

      item.addEventListener("mouseenter", () => {
        if (!mobileQuery.matches) {
          cancelCloseTimer(item);
          closeAllSubmenus(item);
          setSubmenuOpen(item, true);
        }
      });

      item.addEventListener("mouseleave", () => {
        if (!mobileQuery.matches) {
          cancelCloseTimer(item);
          const timer = window.setTimeout(() => {
            setSubmenuOpen(item, false);
            closeTimers.delete(item);
          }, HOVER_CLOSE_DELAY);
          closeTimers.set(item, timer);
        }
      });

      item.addEventListener("focusin", () => {
        if (!mobileQuery.matches) {
          closeAllSubmenus(item);
          setSubmenuOpen(item, true);
        }
      });

      item.addEventListener("focusout", () => {
        if (!mobileQuery.matches) {
          window.requestAnimationFrame(() => {
            if (!item.contains(document.activeElement)) {
              setSubmenuOpen(item, false);
            }
          });
        }
      });
    });

    document.addEventListener("click", (event) => {
      const target = event.target as Node;
      if (!header.contains(target)) {
        closeAllSubmenus();

        if (mobileQuery.matches) {
          setMenuOpen(false);
        }
      }
    });

    document.addEventListener("keydown", (event) => {
      if (event.key !== "Escape") {
        return;
      }

      const openItem = submenuItems.find((item) =>
        item.classList.contains("is-submenu-open")
      );

      if (openItem) {
        setSubmenuOpen(openItem, false);
        openItem.querySelector<HTMLButtonElement>(".site-header__submenu-toggle")?.focus();
        return;
      }

      if (mobileQuery.matches && header.classList.contains("is-menu-open")) {
        setMenuOpen(false);
        menuToggle.focus();
      }
    });

    window.addEventListener("resize", syncViewportState);
    window.addEventListener("scroll", updateScrollState, { passive: true });

    syncViewportState();
    updateScrollState();
  })();
</script>

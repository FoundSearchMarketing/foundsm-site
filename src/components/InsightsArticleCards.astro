---
interface ArticleCategory {
  label: string;
  slug: string;
}

interface ArticleImage {
  src: string;
  srcset?: string;
  sizes?: string;
  width: number;
  height: number;
  alt: string;
  wpImageId: number;
}

interface ArticleCard {
  id: number;
  title: string;
  url: string;
  categories: ArticleCategory[];
  dateLabel: string;
  datetime: string;
  excerpt: string;
  image: ArticleImage;
}

interface Props {
  articles?: ArticleCard[];
  filterScope?: string;
}


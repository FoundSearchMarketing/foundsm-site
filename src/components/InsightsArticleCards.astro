---
interface ArticleCategory {
  label: string;
  slug: string;
}

interface ArticleImage {
  src: string;
  srcset?: string;
  sizes?: string;
  width: number;
  height: number;
  alt: string;
  wpImageId: number;
}

interface ArticleCard {
  id: number;
  title: string;
  url: string;
  categories: ArticleCategory[];
  dateLabel: string;
  datetime: string;
  excerpt: string;
  image: ArticleImage;
}

interface Props {
  articles: ArticleCard[];
  filterScope?: string;
  postsPerPage?: number;
}

const { articles, filterScope = 'insights-articles', postsPerPage = 6 } = Astro.props;
---

<section
  class="insights-article-cards"
  data-filter-scope={filterScope}
  data-posts-per-page={postsPerPage}
  data-source-page-id="2283"
  aria-label="Article list"
>
  <div
    class="insights-article-cards__grid-region"
    data-source-widget="a93972f"
    data-source-template="2487"
    data-grid-settings='{"row_gap":{"unit":"px","size":30,"sizes":[]},"columns":"3","columns_tablet":"2","columns_mobile":"1"}'
  >
    <div class="insights-article-cards__grid" id="insights-article-cards-grid" role="list">
      {
        articles.map((article, index) => {
          const dataCategory = article.categories.map((category) => category.slug).join(' ');

          return (
            <article
              class="insights-article-card"
              data-source-template="2487"
              data-article-id={article.id}
              data-category={dataCategory}
              data-filter-card
              role="listitem"
            >
              <div class="insights-article-card__inner" data-source-widget="d7c28da">
                <a class="insights-article-card__image-link" href={article.url} data-source-widget="d798176">
                  <img
                    fetchpriority={index === 0 ? 'high' : undefined}
                    loading={index === 0 ? undefined : 'lazy'}
                    decoding="async"
                    width={article.image.width}
                    height={article.image.height}
                    src={article.image.src}
                    class={`insights-article-card__image wp-image-${article.image.wpImageId}`}
                    alt={article.image.alt}
                    srcset={article.image.srcset}
                    sizes={article.image.sizes}
                  />
                </a>

                <ul
                  class="insights-article-card__categories"
                  aria-label="Article categories"
                  data-source-widget="3310647"
                  itemprop="about"
                >
                  {article.categories.map((category) => (
                    <li class="insights-article-card__category">{category.label}</li>
                  ))}
                </ul>

                <h3 class="insights-article-card__title" data-source-widget="bad4e0c">
                  <a class="insights-article-card__title-link" href={article.url}>
                    {article.title}
                  </a>
                </h3>

                <p class="insights-article-card__date" data-source-widget="01dc494" itemprop="datePublished">
                  <time datetime={article.datetime}>{article.dateLabel}</time>
                </p>

                <p class="insights-article-card__excerpt" data-source-widget="d3ab759">
                  {article.excerpt}
                </p>

                <a class="insights-article-card__button" href={article.url} data-source-widget="841dbf1">
                  <span class="insights-article-card__button-text">Read Article →</span>
                </a>
              </div>
            </article>
          );
        })
      }
    </div>
  </div>

  <slot name="pagination" />
</section>

<script>
  const initInsightsArticlePagination = () => {
    const articleSections = document.querySelectorAll<HTMLElement>('.insights-article-cards');

    articleSections.forEach((section) => {
      if (section.dataset.paginationInitialized === 'true') {
        return;
      }

      const pagination = section.querySelector<HTMLElement>('[data-insights-pagination]');
      const nav = pagination?.querySelector<HTMLElement>('[data-insights-pagination-nav]');
      const loadAnchor = pagination?.querySelector<HTMLElement>('[data-insights-pagination-load-anchor]');
      const cards = Array.from(section.querySelectorAll<HTMLElement>('[data-filter-card]'));

      if (!pagination || !nav || cards.length === 0) {
        return;
      }

      section.dataset.paginationInitialized = 'true';

      const filterScope = section.dataset.filterScope ?? 'insights-articles';
      const tabList = Array.from(document.querySelectorAll<HTMLElement>('[data-filter-tabs]')).find((candidate) => {
        const tabsSection = candidate.closest<HTMLElement>('.insights-articles-tabs');
        return (tabsSection?.dataset.filterScope ?? 'insights-articles') === filterScope;
      });
      const filterButtons = tabList
        ? Array.from(tabList.querySelectorAll<HTMLButtonElement>('[data-filter]'))
        : [];
      const pageSize = Number(section.dataset.postsPerPage ?? pagination.dataset.pageSize) || 6;
      const loopId = pagination.dataset.sourceLoopId ?? 'a93972f';
      let currentPage = Number(pagination.dataset.currentPage) || 1;

      const pageHref = (page: number) => (page === 1 ? '/insights/' : `/insights/?e-page-${loopId}=${page}`);

      const getActiveFilter = () => {
        const activeButton = filterButtons.find((button) => button.getAttribute('aria-pressed') === 'true');
        return activeButton?.dataset.filter ?? '__all';
      };

      const createScreenReaderLabel = () => {
        const label = document.createElement('span');
        label.className = 'insights-pagination__sr-only';
        label.textContent = 'Page';
        return label;
      };

      const createPageNode = ({
        page,
        label,
        modifier,
        disabled = false,
        current = false,
      }: {
        page: number;
        label: string;
        modifier?: string;
        disabled?: boolean;
        current?: boolean;
      }) => {
        const node = document.createElement(disabled || current ? 'span' : 'a');
        const classes = ['insights-pagination__item'];

        if (!disabled && !current) {
          classes.push('insights-pagination__link');
          node.setAttribute('href', pageHref(page));
          node.setAttribute('data-pagination-page', String(page));
        }

        if (modifier) {
          classes.push(`insights-pagination__item--${modifier}`);
        }

        if (disabled) {
          classes.push('insights-pagination__item--disabled');
          node.setAttribute('aria-disabled', 'true');
        }

        if (current) {
          classes.push('insights-pagination__item--current');
          node.setAttribute('aria-current', 'page');
        }

        node.className = classes.join(' ');

        if (/^\d+$/.test(label)) {
          node.append(createScreenReaderLabel(), document.createTextNode(label));
        } else {
          node.textContent = label;
        }

        return node;
      };

      const render = () => {
        const activeFilter = getActiveFilter();
        const matchingCards = cards.filter((card) => {
          const categories = (card.dataset.category ?? '').split(/\s+/).filter(Boolean);
          return activeFilter === '__all' || categories.includes(activeFilter);
        });
        const totalPages = Math.max(1, Math.ceil(matchingCards.length / pageSize));

        currentPage = Math.min(Math.max(currentPage, 1), totalPages);

        const pageStart = (currentPage - 1) * pageSize;
        const pageEnd = pageStart + pageSize;
        const visibleCards = new Set(matchingCards.slice(pageStart, pageEnd));

        cards.forEach((card) => {
          card.hidden = !visibleCards.has(card);
        });

        pagination.dataset.currentPage = String(currentPage);
        pagination.dataset.totalPages = String(totalPages);
        pagination.hidden = totalPages <= 1;

        if (loadAnchor) {
          loadAnchor.dataset.page = String(currentPage);
          loadAnchor.dataset.maxPage = String(totalPages);

          if (currentPage < totalPages) {
            loadAnchor.dataset.nextPage = pageHref(currentPage + 1);
          } else {
            delete loadAnchor.dataset.nextPage;
          }
        }

        nav.replaceChildren();
        nav.append(
          createPageNode({
            page: Math.max(currentPage - 1, 1),
            label: 'Previous',
            modifier: 'previous',
            disabled: currentPage === 1,
          }),
        );

        Array.from({ length: totalPages }, (_, index) => index + 1).forEach((page) => {
          nav.append(createPageNode({ page, label: String(page), current: page === currentPage }));
        });

        nav.append(
          createPageNode({
            page: Math.min(currentPage + 1, totalPages),
            label: 'Next',
            modifier: 'next',
            disabled: currentPage === totalPages,
          }),
        );
      };

      nav.addEventListener('click', (event) => {
        const target = event.target instanceof Element ? event.target.closest<HTMLElement>('[data-pagination-page]') : null;

        if (!target) {
          return;
        }

        event.preventDefault();
        currentPage = Number(target.dataset.paginationPage) || 1;
        render();
      });

      filterButtons.forEach((button) => {
        button.addEventListener('click', () => {
          currentPage = 1;
          window.requestAnimationFrame(render);
        });
      });

      render();
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initInsightsArticlePagination, { once: true });
  } else {
    initInsightsArticlePagination();
  }

  document.addEventListener('astro:page-load', initInsightsArticlePagination);
</script>

<style>
  .insights-article-cards {
    --article-cards-accent: #8dc63f;
    --article-cards-text: #231f20;
    --article-cards-muted-text: #231f2099;
    --article-cards-columns: 3;
    --article-cards-column-gap: 30px;
    --article-cards-row-gap: 60px;
    --article-card-title-size: 30px;
    --article-card-title-line-height: 38px;
    --article-card-copy-size: 20px;
    --article-card-copy-line-height: 36px;
    --article-card-button-size: 15px;
    --article-card-button-line-height: 24px;

    inline-size: min(calc(100% - (2 * var(--page-gutter))), var(--content-max-width));
    margin-block: 0 100px;
    margin-inline: auto;
    background: #ffffff;
    color: var(--article-cards-text);
    font-family: var(--font-body, 'Poppins', sans-serif);
  }

  .insights-article-cards *,
  .insights-article-cards *::before,
  .insights-article-cards *::after {
    box-sizing: border-box;
  }

  .insights-article-cards a {
    box-shadow: none;
    text-decoration: none;
  }

  .insights-article-cards img:not(.insights-article-card__image) {
    max-width: 100%;
    height: auto;
    border: 0;
    border-radius: 0;
    box-shadow: none;
  }

  .insights-article-cards__grid {
    display: grid;
    grid-auto-rows: 0.5fr;
    grid-template-columns: repeat(var(--article-cards-columns), minmax(0, 1fr));
    column-gap: var(--article-cards-column-gap);
    row-gap: var(--article-cards-row-gap);
    align-items: stretch;
  }

  .insights-article-card {
    min-width: 0;
    position: relative;
    height: 100%;
  }

  .insights-article-card[hidden] {
    display: none;
  }

  .insights-article-card__inner {
    display: flex;
    flex-direction: column;
    gap: 20px 10px;
    height: 100%;
    margin-block-start: 25px;
    padding-inline: 10px;
  }

  .insights-article-card__image-link {
    display: block;
  }

  .insights-article-card__image {
    display: block;
    width: 100%;
    max-width: 100%;
    height: 280px;
    object-fit: cover;
    object-position: center center;
    border-radius: 40px;
  }

  .insights-article-card__categories {
    margin: 0;
    padding: 0 0 0 10px;
    list-style: none;
    border-style: solid;
    border-width: 0 0 0 4px;
    border-color: var(--article-cards-accent);
    color: var(--article-cards-text);
    font-family: var(--font-body, 'Poppins', sans-serif);
    font-size: 12px;
    font-weight: 300;
    text-transform: uppercase;
    line-height: 21px;
    letter-spacing: 3px;
  }

  .insights-article-card__category {
    display: inline;
  }

  .insights-article-card__category:not(:last-child)::after {
    content: ', ';
  }

  .insights-article-card__title {
    margin: 0;
    display: -webkit-box;
    overflow: hidden;
    text-overflow: ellipsis;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .insights-article-card__title-link {
    color: var(--article-cards-text);
    font-family: var(--font-body, 'Poppins', sans-serif);
    font-size: var(--article-card-title-size);
    font-weight: 700;
    line-height: var(--article-card-title-line-height);
    letter-spacing: -0.2px;
  }

  .insights-article-card__date {
    margin: 0;
    padding: 0;
    color: var(--article-cards-muted-text);
    font-family: var(--font-body, 'Poppins', sans-serif);
    font-size: 14px;
    line-height: 30px;
  }

  .insights-article-card__excerpt {
    margin: 0;
    display: -webkit-box;
    overflow: hidden;
    color: var(--article-cards-text);
    font-family: var(--font-body, 'Poppins', sans-serif);
    font-size: var(--article-card-copy-size);
    font-weight: 400;
    line-height: 29px;
    text-overflow: ellipsis;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .insights-article-card__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    align-self: flex-start;
    min-width: 170px;
    padding: 18px 36px;
    border-style: none;
    border-radius: 30px;
    background-color: #231f20;
    color: #ffffff;
    font-family: var(--font-body, 'Poppins', sans-serif);
    font-size: var(--article-card-button-size);
    font-weight: 500;
    text-transform: none;
    line-height: var(--article-card-button-line-height);
    text-align: center;
    transition: all 0.3s;
  }

  .insights-article-card__button:hover,
  .insights-article-card__button:focus {
    background-color: #353132;
    color: var(--article-cards-accent);
  }

  .insights-article-card__button:focus-visible {
    outline: 2px solid var(--article-cards-accent);
    outline-offset: 4px;
  }

  .insights-article-card__button-text {
    display: inline-block;
  }

  @media (max-width: 1599px) {
    .insights-article-card__image {
      height: 100%;
      object-position: center center;
      border-radius: 30px;
    }
  }

  @media (max-width: 1024px) {
    .insights-article-cards {
      --article-cards-columns: 2;
      --article-card-title-size: 24px;
      --article-card-title-line-height: 32px;
      --article-card-copy-size: 18px;
      --article-card-copy-line-height: 30px;
      --article-card-button-size: 16px;
      --article-card-button-line-height: 20px;

      margin-block-end: 50px;
      padding-block-end: 40px;
    }

    .insights-article-card__image {
      border-radius: 20px;
    }

    .insights-article-card__categories {
      font-size: 18px;
      line-height: 22px;
    }

    .insights-article-card__title {
      -webkit-line-clamp: 3;
    }

    .insights-article-card__title-link {
      letter-spacing: -0.5px;
    }

    .insights-article-card__excerpt {
      line-height: var(--article-card-copy-line-height);
      -webkit-line-clamp: 3;
    }
  }

  @media (max-width: 767px) {
    .insights-article-cards {
      --article-cards-columns: 1;

      margin-block-end: 0;
      padding-block: 0 50px;
    }

    .insights-article-cards__grid-region {
      padding: 0 0 50px 0;
    }

    .insights-article-card__inner {
      margin: 10px;
    }

    .insights-article-card__title,
    .insights-article-card__excerpt {
      display: block;
      overflow: visible;
      text-overflow: unset;
      white-space: normal;
      -webkit-line-clamp: unset;
      -webkit-box-orient: unset;
    }
  }
</style>

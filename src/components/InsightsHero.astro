---
import { Image } from 'astro:assets';
import bulb from '../assets/insights_bulb-1.webp';

interface Props {
  headline?: string;
  body?: string;
  imageAlt?: string;
}

const {
  headline = 'Where Bold Ideas Are Found.',
  body = 'Great performance begins by staying sharp. Tap into fresh insights, news, and forward-thinking strategies from our team and beyond.',
  imageAlt = '',
} = Astro.props;
---

<section class="insights-hero" aria-label={headline}>
  <div class="insights-hero__inner">
    <div class="insights-hero__copy">
      <h1 class="insights-hero__headline">{headline}</h1>
      <p class="insights-hero__body">{body}</p>
    </div>
    <figure class="insights-hero__figure" aria-hidden="true">
      <Image
        src={bulb}
        alt={imageAlt}
        widths={[300, 434, 600, 800]}
        sizes="(max-width: 767px) 60vw, 32rem"
        loading="eager"
      />
    </figure>
  </div>
</section>

<style>
  /* Values sourced from foundsm.wpress (page `data-elementor-id="2283"`,
     Elementor kit 5): section bg #000, margin-bottom 50px, gutter 25px, 100px
     column gap, copy column behavior, and heading Fraunces 60px/65px/900
     desktop and 38px/42px/900 tablet/mobile. Letter spacing is normalized
     to match the project CSS guidance. */

  .insights-hero {
    background-color: #000000;
    color: #ffffff;
    margin-block-end: 50px;
  }

  .insights-hero__inner {
    display: grid;
    grid-template-columns: minmax(0, 50%) minmax(0, calc(50% - 100px));
    align-items: center;
    column-gap: 100px;
    inline-size: min(calc(100% - (2 * var(--page-gutter))), var(--content-max-width));
    min-block-size: calc(609px + var(--header-height, 5.3125rem));
    margin-inline: auto;
    padding-block-start: var(--header-height, 5.3125rem);
  }

  .insights-hero__copy {
    min-inline-size: 0;
    padding: 10px;
  }

  .insights-hero__headline {
    margin: 0;
    color: #ffffff;
    font-family: 'Fraunces', Georgia, serif;
    font-size: 60px;
    font-weight: 900;
    line-height: 65px;
    letter-spacing: 0;
  }

  .insights-hero__body {
    margin: 20px 0;
    color: #ffffff;
    font-family: var(--font-body);
    font-size: 20px;
    line-height: 36px;
  }

  .insights-hero__figure {
    margin: 0;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .insights-hero__figure :global(img) {
    display: block;
    inline-size: 100%;
    max-inline-size: 434px;
    block-size: auto;
  }

  @media (max-width: 1024px) {
    .insights-hero__inner {
      display: block;
      min-block-size: 0;
      padding-block: var(--header-height, 5.3125rem) 55px;
    }

    .insights-hero__headline {
      font-size: 38px;
      line-height: 42px;
      letter-spacing: 0;
    }

    .insights-hero__body {
      font-size: 18px;
      line-height: 30px;
    }

    .insights-hero__figure {
      display: none;
    }
  }

  @media (max-width: 767px) {
    .insights-hero__inner {
      inline-size: min(calc(100% - (2 * var(--page-gutter))), var(--content-max-width));
    }
  }
</style>

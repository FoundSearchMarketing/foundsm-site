---
import { Image } from 'astro:assets';
import bulb from '../assets/insights_bulb-1.webp';

interface Props {
  headline?: string;
  body?: string;
  imageAlt?: string;
}

const {
  headline = 'Where Bold Ideas Are Found.',
  body = 'Great performance begins by staying sharp. Tap into fresh insights, news, and forward-thinking strategies from our team and beyond.',
  imageAlt = '',
} = Astro.props;
---

<section class="insights-hero" aria-label={headline}>
  <div class="insights-hero__inner">
    <div class="insights-hero__copy">
      <h1 class="insights-hero__headline">{headline}</h1>
      <p class="insights-hero__body">{body}</p>
    </div>
    <figure class="insights-hero__figure" aria-hidden="true">
      <Image
        src={bulb}
        alt={imageAlt}
        widths={[300, 434, 600, 800]}
        sizes="(max-width: 767px) 60vw, 32rem"
        loading="eager"
      />
    </figure>
  </div>
</section>

<style>
  /* Values sourced from foundsm.wpress (page `data-elementor-id="2283"`,
     Elementor kit 5): section bg #000, margin-bottom 50px, gutter 25px, 100px
     column gap, copy column 45% desktop / 50% tablet / 100% mobile, heading
     Fraunces 60px/65px/-1.5px/900 desktop and 38px/42px/-1.2px mobile.
     Applied with a saner grid layout than the original Elementor flex hacks. */

  .insights-hero {
    background-color: #000000;
    color: #ffffff;
    margin-block-end: 50px;
    padding-inline: 25px;
  }

  .insights-hero__inner {
    display: grid;
    grid-template-columns: 45fr 55fr;
    align-items: center;
    gap: 100px;
    max-inline-size: 1400px;
    margin-inline: auto;
    padding-block:
      calc(var(--header-height, 5.3125rem) + clamp(2rem, 4vw, 4rem))
      clamp(3rem, 6vw, 5.5rem);
  }

  .insights-hero__copy {
    min-inline-size: 0;
  }

  .insights-hero__headline {
    margin: 0;
    color: #ffffff;
    font-family: 'Fraunces', Georgia, serif;
    font-size: 60px;
    font-weight: 900;
    line-height: 65px;
    letter-spacing: -1.5px;
  }

  .insights-hero__body {
    margin: 24px 0 0;
    color: #ffffff;
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1.6;
  }

  .insights-hero__figure {
    margin: 0;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .insights-hero__figure :global(img) {
    display: block;
    inline-size: 100%;
    max-inline-size: 32rem;
    block-size: auto;
  }

  @media (max-width: 1024px) {
    .insights-hero__inner {
      grid-template-columns: 50fr 50fr;
      gap: 60px;
    }

    .insights-hero__headline {
      font-size: 48px;
      line-height: 54px;
      letter-spacing: -1.2px;
    }
  }

  @media (max-width: 767px) {
    .insights-hero {
      padding-inline: 20px;
    }

    .insights-hero__inner {
      grid-template-columns: 1fr;
      gap: 32px;
      padding-block:
        calc(var(--header-height, 5.3125rem) + 1.5rem)
        2rem;
    }

    .insights-hero__headline {
      font-size: 38px;
      line-height: 42px;
      letter-spacing: -1.2px;
    }

    .insights-hero__figure :global(img) {
      max-inline-size: 18rem;
    }
  }
</style>

---
import { urlFor } from '../lib/sanity';

interface Props {
  value?: any[];
}

const { value = [] } = Astro.props;

type Span = { _key: string; _type: 'span'; text: string; marks?: string[] };
type MarkDef = { _key: string; _type: string; href?: string };
type Block = {
  _key: string;
  _type: string;
  style?: string;
  children?: Span[];
  markDefs?: MarkDef[];
  listItem?: 'bullet' | 'number';
  level?: number;
  asset?: { _ref: string };
  alt?: string;
  caption?: string;
};

function escapeHtml(s: string): string {
  return s
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;');
}

function renderSpan(span: Span, markDefs: MarkDef[]): string {
  let text = escapeHtml(span.text || '').replace(/\n/g, '<br>');
  const marks = span.marks || [];
  for (const mark of marks) {
    if (mark === 'strong') text = `<strong>${text}</strong>`;
    else if (mark === 'em') text = `<em>${text}</em>`;
    else if (mark === 'underline') text = `<u>${text}</u>`;
    else if (mark === 'code') text = `<code>${text}</code>`;
    else {
      const def = markDefs.find((d) => d._key === mark);
      if (def && def._type === 'link' && def.href) {
        const href = escapeHtml(def.href);
        const external = /^https?:\/\//i.test(def.href);
        const rel = external ? ' rel="noopener noreferrer" target="_blank"' : '';
        text = `<a href="${href}"${rel}>${text}</a>`;
      }
    }
  }
  return text;
}

function renderChildren(block: Block): string {
  const markDefs = block.markDefs || [];
  return (block.children || []).map((c) => renderSpan(c, markDefs)).join('');
}

type Group = { type: 'block'; block: Block } | { type: 'list'; listType: 'bullet' | 'number'; items: Block[] };

function groupBlocks(blocks: Block[]): Group[] {
  const groups: Group[] = [];
  for (const block of blocks) {
    if (block._type === 'block' && block.listItem) {
      const last = groups[groups.length - 1];
      if (last && last.type === 'list' && last.listType === block.listItem) {
        last.items.push(block);
      } else {
        groups.push({ type: 'list', listType: block.listItem, items: [block] });
      }
    } else {
      groups.push({ type: 'block', block });
    }
  }
  return groups;
}

function renderBlock(block: Block): string {
  if (block._type === 'block') {
    const style = block.style || 'normal';
    const inner = renderChildren(block);
    if (style === 'blockquote') return `<blockquote><p>${inner}</p></blockquote>`;
    if (/^h[1-6]$/.test(style)) return `<${style}>${inner}</${style}>`;
    return `<p>${inner}</p>`;
  }
  return '';
}

function renderGroup(group: Group): string {
  if (group.type === 'list') {
    const tag = group.listType === 'bullet' ? 'ul' : 'ol';
    const items = group.items.map((b) => `<li>${renderChildren(b)}</li>`).join('');
    return `<${tag}>${items}</${tag}>`;
  }
  return renderBlock(group.block);
}

const groups = groupBlocks(value as Block[]);

const imageBlocks = (value as Block[]).filter((b) => b._type === 'image' && b.asset);
---

<div class="portable-text">
  {groups.map((group) => {
    if (group.type === 'block' && group.block._type === 'image' && group.block.asset) {
      const img = group.block;
      const url = urlFor(img as any).width(1200).auto('format').url();
      return (
        <figure>
          <img src={url} alt={img.alt || ''} loading="lazy" />
          {img.caption && <figcaption>{img.caption}</figcaption>}
        </figure>
      );
    }
    return <Fragment set:html={renderGroup(group)} />;
  })}
</div>

<style>
  .portable-text :global(h2) { margin-top: 2rem; }
  .portable-text :global(h3) { margin-top: 1.5rem; }
  .portable-text :global(p) { margin-bottom: 1rem; line-height: 1.7; }
  .portable-text :global(ul),
  .portable-text :global(ol) { margin: 1rem 0 1.25rem 1.5rem; }
  .portable-text :global(li) { margin-bottom: 0.5rem; line-height: 1.65; }
  .portable-text :global(blockquote) {
    margin: 1.5rem 0;
    padding: 1rem 1.25rem;
    border-left: 4px solid var(--color-primary, #0AADEF);
    background: var(--color-light, #f6f7f9);
    font-style: italic;
  }
  .portable-text :global(a) { color: var(--color-primary, #0AADEF); text-decoration: underline; }
  .portable-text :global(figure) { margin: 1.5rem 0; }
  .portable-text :global(figure img) { width: 100%; height: auto; border-radius: var(--radius-md, 8px); }
  .portable-text :global(figcaption) {
    margin-top: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-mid, #666);
    text-align: center;
  }
</style>

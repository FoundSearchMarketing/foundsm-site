---
import { resolveSeo, type JsonLd } from '../lib/seo';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  canonicalUrl?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
  ogType?: string;
  robots?: string;
  twitterCard?: string;
  twitterSite?: string;
  twitterTitle?: string;
  twitterDescription?: string;
  twitterImage?: string;
  publishedAt?: string;
  modifiedAt?: string;
  schema?: JsonLd;
  schemaJson?: string;
  colorScheme?: 'light' | 'dark';
  fontHref?: string;
}

const seo = resolveSeo(Astro.url.pathname, Astro.props);
const {
  colorScheme = 'light',
  fontHref = 'https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600;9..144,700;9..144,900&family=Poppins:wght@400;500;600;700&display=swap',
} = Astro.props;

const enableThirdPartyScripts = import.meta.env.PROD;
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="color-scheme" content={colorScheme} />

<title>{seo.title}</title>

{seo.description && <meta name="description" content={seo.description} />}
<meta name="robots" content={seo.robots} />

<link rel="canonical" href={seo.canonical} />

<!-- Open Graph -->
<meta property="og:locale" content={seo.ogLocale} />
<meta property="og:title" content={seo.ogTitle} />
{seo.ogDescription && <meta property="og:description" content={seo.ogDescription} />}
<meta property="og:type" content={seo.ogType} />
<meta property="og:url" content={seo.canonical} />
<meta property="og:image" content={seo.ogImage} />
{seo.ogImageWidth && <meta property="og:image:width" content={String(seo.ogImageWidth)} />}
{seo.ogImageHeight && <meta property="og:image:height" content={String(seo.ogImageHeight)} />}
<meta property="og:site_name" content={seo.siteName} />
<meta property="article:publisher" content="https://www.facebook.com/foundsm/" />
{seo.publishedAt && <meta property="article:published_time" content={seo.publishedAt} />}
{seo.modifiedAt && <meta property="article:modified_time" content={seo.modifiedAt} />}

<!-- Twitter Card -->
<meta name="twitter:card" content={seo.twitterCard} />
<meta name="twitter:site" content={seo.twitterSite} />
<meta name="twitter:title" content={seo.twitterTitle} />
{seo.twitterDescription && <meta name="twitter:description" content={seo.twitterDescription} />}
<meta name="twitter:image" content={seo.twitterImage} />

<!-- Google Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href={fontHref}
  rel="stylesheet"
/>

<!-- OneTrust Cookie Consent placeholder -->

<!-- Google Tag Manager -->
{enableThirdPartyScripts && (
<script is:inline>
(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://sst.foundsm.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','GTM-PG7TGGG');
</script>
)}

{seo.schema && (
  <script type="application/ld+json" class="yoast-schema-graph" set:html={JSON.stringify(seo.schema)} />
)}

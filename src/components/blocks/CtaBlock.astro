---
interface Props {
  headline?: string;
  ctaText?: string;
  ctaUrl?: string;
  theme?: 'light' | 'dark' | 'green';
}

const { headline, ctaText, ctaUrl, theme = 'dark' } = Astro.props;
---

<section class="cta-banner" aria-label="Call to action">
  <div class="cta-banner__bg" aria-hidden="true"></div>
  <div class="container cta-banner__inner fade-in-up">
    {headline && <h2 class="cta-banner__headline">{headline}</h2>}
    {ctaText && ctaUrl && (
      <a href={ctaUrl} class="btn btn--green btn--lg">{ctaText}</a>
    )}
  </div>
</section>

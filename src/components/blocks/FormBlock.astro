---
interface Props {
  heading?: string;
  subheading?: string;
  hubspotFormId?: string;
  theme?: 'light' | 'dark';
}

const { heading, subheading, hubspotFormId, theme = 'light' } = Astro.props;
const isDark = theme === 'dark';
const containerId = `hs-form-${hubspotFormId || 'placeholder'}`;
---

<section class={`section ${isDark ? 'section--dark' : 'section--light'}`} aria-label={heading || 'Form'}>
  <div class="container">
    <div class="lp-form-block">
      {(heading || subheading) && (
        <div class="section-header section-header--center fade-in-up">
          {heading && <h2>{heading}</h2>}
          {subheading && <p class="section-header__text">{subheading}</p>}
        </div>
      )}
      <div id={containerId} class="lp-form-block__container fade-in-up"></div>
    </div>
  </div>
  {hubspotFormId && (
    <script is:inline define:vars={{ hubspotFormId, containerId }}>
      (function() {
        function loadForm() {
          if (window.hbspt) {
            window.hbspt.forms.create({
              region: "na1",
              portalId: "5045186",
              formId: hubspotFormId,
              target: "#" + containerId
            });
          } else {
            setTimeout(loadForm, 500);
          }
        }
        if (document.readyState === 'complete') { loadForm(); }
        else { window.addEventListener('load', loadForm); }
      })();
    </script>
  )}
</section>

---
import CtaPanel from '../modern/CtaPanel.astro';
import { richHtml, richText } from '../../lib/fixedPageRender';

interface Props {
  title?: string;
  body?: any[];
  cta?: { label?: string; href?: string };
  theme?: 'dark' | 'green' | 'light' | 'white';
  align?: 'split' | 'centered';
}

const { title, body = [], cta, theme = 'dark', align = 'split' } = Astro.props;
---

<CtaPanel
  title={title}
  body={richText(body)}
  bodyHtml={richHtml(body)}
  ctaLabel={cta?.label}
  ctaHref={cta?.href}
  theme={theme}
  align={align}
/>

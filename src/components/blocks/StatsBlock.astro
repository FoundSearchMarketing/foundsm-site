---
interface StatItem {
  value: string;
  label: string;
}

interface Props {
  stats?: StatItem[];
  theme?: 'light' | 'dark';
}

const { stats = [], theme = 'dark' } = Astro.props;
const isDark = theme === 'dark';
---

<section class={`stats ${!isDark ? 'lp-stats--light' : ''}`} aria-label="Key statistics">
  <div class="container stats__grid">
    {stats.map((stat) => (
      <div class="stats__item fade-in-up">
        <span class="stats__number">
          <span class="stats__value">{stat.value}</span>
        </span>
        <span class="stats__label">{stat.label}</span>
      </div>
    ))}
  </div>
</section>

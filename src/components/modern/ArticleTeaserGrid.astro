---
interface ArticleImage {
  src: string;
  srcset?: string;
  sizes?: string;
  width?: number;
  height?: number;
  alt?: string;
}

interface ArticleTeaser {
  title: string;
  href: string;
  categories: string[];
  dateLabel: string;
  datetime?: string;
  excerpt: string;
  image?: ArticleImage;
  ctaLabel?: string;
}

interface Props {
  articles: ArticleTeaser[];
}

const { articles } = Astro.props;
---

<div class="article-teaser-grid" role="list">
  {articles.map((article, index) => (
    <article class="article-teaser" role="listitem">
      {article.image && (
        <a class="article-teaser__image" href={article.href} aria-label={article.title}>
          <img
            src={article.image.src}
            srcset={article.image.srcset}
            sizes={article.image.sizes}
            width={article.image.width}
            height={article.image.height}
            alt={article.image.alt ?? article.title}
            loading={index === 0 ? 'eager' : 'lazy'}
            decoding="async"
          />
        </a>
      )}
      <div class="article-teaser__body">
        {article.categories.length > 0 && (
          <p class="article-teaser__categories">{article.categories.join(', ')}</p>
        )}
        <h3><a href={article.href}>{article.title}</a></h3>
        <p class="article-teaser__date">
          {article.datetime ? <time datetime={article.datetime}>{article.dateLabel}</time> : article.dateLabel}
        </p>
        <p class="article-teaser__excerpt">{article.excerpt}</p>
        <a class="article-teaser__link" href={article.href}>{article.ctaLabel ?? 'Read Article'} &rarr;</a>
      </div>
    </article>
  ))}
</div>

<style>
  .article-teaser-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.75rem;
  }

  .article-teaser {
    display: grid;
    grid-template-rows: auto 1fr;
    min-inline-size: 0;
    overflow: hidden;
    border: 1px solid rgba(26, 26, 26, 0.12);
    border-radius: 0.5rem;
    background: #ffffff;
    box-shadow: 0 16px 34px rgba(26, 26, 26, 0.06);
  }

  .article-teaser__image {
    display: block;
    overflow: hidden;
    background: #e8ebe6;
  }

  .article-teaser__image img {
    inline-size: 100%;
    aspect-ratio: 3 / 2;
    block-size: auto;
    object-fit: cover;
  }

  .article-teaser__body {
    display: grid;
    align-content: start;
    gap: 0.625rem;
    padding: 1.375rem;
  }

  .article-teaser__categories,
  .article-teaser__date {
    margin: 0;
    color: rgba(26, 26, 26, 0.62);
    font-size: 0.8125rem;
    font-weight: 700;
    line-height: 1.35;
    text-transform: uppercase;
  }

  .article-teaser h3 {
    margin: 0;
    font-size: 1.25rem;
    line-height: 1.28;
  }

  .article-teaser h3 a {
    color: var(--color-dark);
  }

  .article-teaser h3 a:hover,
  .article-teaser h3 a:focus-visible {
    color: var(--color-primary);
  }

  .article-teaser__excerpt {
    margin: 0;
    color: rgba(26, 26, 26, 0.76);
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .article-teaser__link {
    align-self: end;
    margin-block-start: 0.25rem;
    color: var(--color-dark);
    font-size: 0.9375rem;
    font-weight: 700;
  }

  .article-teaser__link:hover,
  .article-teaser__link:focus-visible {
    color: var(--color-primary);
  }

  @media (max-width: 1024px) {
    .article-teaser-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .article-teaser-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

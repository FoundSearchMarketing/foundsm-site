---
interface CardItem {
  title: string;
  body: string;
  bodyHtml?: string;
  lead?: string;
  icon?: string;
  image?: string;
  imageAlt?: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  cards: CardItem[];
  columns?: 2 | 3 | 4;
  theme?: 'light' | 'muted' | 'dark';
}

const {
  title,
  subtitle,
  cards,
  columns = 3,
  theme = 'light',
} = Astro.props;
---

<section class={`card-grid-section card-grid-section--${theme}`} aria-labelledby={title ? `${title.toLowerCase().replace(/[^a-z0-9]+/g, '-')}-heading` : undefined}>
  <div class="card-grid-section__inner">
    {(title || subtitle) && (
      <div class="card-grid-section__header">
        {title && <h2 id={`${title.toLowerCase().replace(/[^a-z0-9]+/g, '-')}-heading`}>{title}</h2>}
        {subtitle && <p>{subtitle}</p>}
      </div>
    )}

    <div class={`card-grid card-grid--${columns}`}>
      {cards.map((card) => (
        <article class="modern-card">
          {card.image && (
            <div class="modern-card__image">
              <img src={card.image} alt={card.imageAlt ?? ''} loading="lazy" decoding="async" />
            </div>
          )}
          {card.icon && (
            <img class="modern-card__icon" src={card.icon} alt="" loading="lazy" decoding="async" />
          )}
          <h3>{card.title}</h3>
          {card.lead && <p class="modern-card__lead">{card.lead}</p>}
          {card.bodyHtml ? <div class="modern-card__body" set:html={card.bodyHtml} /> : <p class="modern-card__body">{card.body}</p>}
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .card-grid-section {
    padding: 5rem var(--gutter);
  }

  .card-grid-section--muted {
    background: #f2f3f2;
  }

  .card-grid-section--dark {
    background: #1a1a1a;
    color: #ffffff;
  }

  .card-grid-section__inner {
    inline-size: min(100%, var(--content-max-width));
    margin-inline: auto;
  }

  .card-grid-section__header {
    max-inline-size: 48rem;
    margin-block-end: 2.25rem;
  }

  .card-grid-section__header h2 {
    margin: 0;
    font-size: 2.7rem;
    line-height: 1.12;
    letter-spacing: 0;
  }

  .card-grid-section--dark .card-grid-section__header h2 {
    color: #ffffff;
  }

  .card-grid-section__header p {
    margin-block-start: 0.75rem;
    color: rgba(26, 26, 26, 0.72);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .card-grid-section--dark .card-grid-section__header p {
    color: rgba(255, 255, 255, 0.74);
  }

  .card-grid {
    display: grid;
    gap: 1.25rem;
  }

  .card-grid--2 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .card-grid--3 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .card-grid--4 {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .modern-card {
    display: grid;
    align-content: start;
    gap: 0.75rem;
    min-block-size: 100%;
    padding: 1.45rem;
    border: 1px solid rgba(26, 26, 26, 0.12);
    border-radius: 0.5rem;
    background: #ffffff;
    box-shadow: 0 16px 34px rgba(26, 26, 26, 0.06);
  }

  .card-grid-section--dark .modern-card {
    border-color: rgba(255, 255, 255, 0.16);
    background: rgba(255, 255, 255, 0.07);
    box-shadow: none;
  }

  .modern-card__image {
    overflow: hidden;
    margin: -1.45rem -1.45rem 0;
    aspect-ratio: 4 / 3;
    background: #e8ebe6;
  }

  .modern-card__image img {
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
  }

  .modern-card__icon {
    inline-size: 3.25rem;
    block-size: 3.25rem;
    object-fit: contain;
  }

  .modern-card h3 {
    margin: 0;
    font-size: 1.25rem;
    line-height: 1.3;
  }

  .card-grid-section--dark .modern-card h3 {
    color: #ffffff;
  }

  .modern-card__lead {
    color: #1a1a1a;
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.55;
  }

  .card-grid-section--dark .modern-card__lead {
    color: #ffffff;
  }

  .modern-card__body {
    color: rgba(26, 26, 26, 0.72);
    font-size: 0.95rem;
    line-height: 1.68;
  }

  .card-grid-section--dark .modern-card__body {
    color: rgba(255, 255, 255, 0.76);
  }

  @media (max-width: 1024px) {
    .card-grid--3,
    .card-grid--4 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .card-grid-section {
      padding-block: 3.5rem;
    }

    .card-grid--2,
    .card-grid--3,
    .card-grid--4 {
      grid-template-columns: 1fr;
    }

    .card-grid-section__header h2 {
      font-size: 2.1rem;
    }
  }
</style>

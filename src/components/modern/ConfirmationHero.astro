---
interface Props {
  title: string;
  intro?: string | string[];
  className?: string;
}

const { title, intro, className } = Astro.props;
const paragraphs = Array.isArray(intro) ? intro : intro ? [intro] : [];
const headingId = `${title.toLowerCase().replace(/[^a-z0-9]+/g, '-')}-heading`;
---

<section class={`confirmation-hero ${className ?? ''}`} aria-labelledby={headingId}>
  <div class="confirmation-hero__inner">
    <svg class="confirmation-hero__icon" aria-hidden="true" viewBox="0 0 512 512">
      <path d="M256 8C119 8 8 119 8 256s111 248 248 248 248-111 248-248S393 8 256 8Zm0 48c111 0 200 89 200 200s-89 200-200 200S56 367 56 256 145 56 256 56Zm140 130-23-23c-5-5-12-5-17 0L215 304l-60-61c-5-5-12-5-17 0l-23 23c-5 5-5 12 0 17l91 92c5 5 12 5 17 0l173-172c5-5 5-12 0-17Z" />
    </svg>
    <h1 id={headingId}>{title}</h1>
    {paragraphs.length > 0 && (
      <div class="confirmation-hero__intro">
        {paragraphs.map((item) => <p>{item}</p>)}
      </div>
    )}
  </div>
</section>

<style>
  .confirmation-hero {
    padding: 4.875rem var(--gutter) 2.75rem;
    background: #ffffff;
    text-align: center;
  }

  .confirmation-hero__inner {
    display: grid;
    justify-items: center;
    gap: 1rem;
    inline-size: min(100%, 64rem);
    margin-inline: auto;
  }

  .confirmation-hero__icon {
    inline-size: 5.125rem;
    block-size: 5.125rem;
    color: var(--color-primary);
    fill: currentColor;
  }

  .confirmation-hero h1 {
    max-inline-size: 50rem;
    margin: 0.5rem 0 0;
    font-size: 4rem;
    line-height: 1.08;
    letter-spacing: 0;
  }

  .confirmation-hero__intro {
    display: grid;
    gap: 0.65rem;
    max-inline-size: 49rem;
    color: rgba(26, 26, 26, 0.78);
    font-size: 1.25rem;
    line-height: 1.75;
  }

  @media (max-width: 700px) {
    .confirmation-hero {
      padding-block: 3.5rem 2rem;
    }

    .confirmation-hero h1 {
      font-size: 2.75rem;
      line-height: 1.1;
    }

    .confirmation-hero__intro {
      font-size: 1rem;
      line-height: 1.65;
    }
  }
</style>

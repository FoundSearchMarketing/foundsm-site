---
interface Props {
  eyebrow?: string;
  title: string;
  intro: string | string[];
  introHtml?: string;
  lead?: string;
  formId: string;
  portalId?: string;
  summary?: string;
  summaryHtml?: string;
  variant?: 'contact' | 'newsletter' | 'dataconnect';
  loadFormScript?: boolean;
  showFormCard?: boolean;
}

const {
  eyebrow,
  title,
  intro,
  introHtml,
  lead,
  formId,
  portalId = '5045186',
  summary,
  summaryHtml,
  variant = 'contact',
  loadFormScript = true,
  showFormCard = true,
} = Astro.props;
const introParagraphs = Array.isArray(intro) ? intro : [intro];
---

<section class:list={['form-landing', `form-landing--${variant}`, { 'form-landing--loads-form': loadFormScript }]} aria-labelledby={`${variant}-form-heading`}>
  <div class="form-landing__inner">
    <div class="form-landing__copy">
      {eyebrow && <p class="form-landing__eyebrow">{eyebrow}</p>}
      <h1 id={`${variant}-form-heading`}>{title}</h1>
      {lead && <p class="form-landing__lead"><strong>{lead}</strong></p>}
      {introHtml ? <div class="form-landing__intro" set:html={introHtml} /> : introParagraphs.map((item) => <p>{item}</p>)}
    </div>

    <div class:list={['form-landing__form-card', { 'form-landing__form-card--bare': !showFormCard }]}>
      <div class="hs-form-frame form-landing__frame" data-region="na1" data-form-id={formId} data-portal-id={portalId}></div>
    </div>
  </div>
</section>

{(summary || summaryHtml) && (
  <section class={`form-landing-summary form-landing-summary--${variant}`}>
    <div class="form-landing-summary__inner">
      {summaryHtml ? <div set:html={summaryHtml} /> : <p>{summary}</p>}
    </div>
  </section>
)}

{loadFormScript && <script is:inline src="https://js.hsforms.net/forms/embed/5045186.js" defer></script>}

<style>
  .form-landing {
    position: relative;
    overflow: hidden;
    padding: 5rem var(--gutter);
    background: #f2f3f2;
  }

  .form-landing--contact {
    min-block-size: 56.25rem;
    background-color: #231f20;
    background-image: url("/images/pages/our-approach/contact-bg-fc.svg");
    background-repeat: no-repeat;
    background-size: cover;
    color: #ffffff;
  }

  .form-landing--dataconnect {
    min-block-size: 30.1875rem;
    padding: 0 1.5625rem;
    background-color: #231f20;
    background-image:
      linear-gradient(rgba(35, 31, 32, 0.9), rgba(35, 31, 32, 0.9)),
      url("/images/pages/performance-creative/map.png");
    background-repeat: no-repeat;
    background-size: cover;
    background-position: center;
    color: #ffffff;
  }

  .form-landing__inner {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(20rem, 1.1fr);
    align-items: start;
    gap: 3rem;
    inline-size: min(100%, var(--content-max-width));
    margin-inline: auto;
  }

  .form-landing__copy {
    display: grid;
    gap: 1rem;
    padding-block-start: 2rem;
  }

  .form-landing--dataconnect .form-landing__inner {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    align-items: flex-start;
    gap: 1.25rem;
    inline-size: min(100%, 87.5rem);
    padding-block-start: 3.125rem;
  }

  .form-landing--dataconnect .form-landing__copy {
    gap: 1.25rem;
    padding: 0.625rem;
  }

  .form-landing__eyebrow {
    color: var(--color-primary);
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .form-landing h1 {
    max-inline-size: 42rem;
    margin: 0;
    font-size: 4.375rem;
    line-height: 1.071;
    letter-spacing: 0;
  }

  .form-landing--newsletter h1 {
    font-family: var(--font-body);
    font-size: 3.375rem;
    font-weight: 700;
    line-height: 1.111;
  }

  .form-landing--contact h1,
  .form-landing--dataconnect h1 {
    color: #ffffff;
  }

  .form-landing--dataconnect h1 {
    max-inline-size: none;
    font-size: 4.375rem;
    font-weight: 900;
    line-height: 1.071;
    margin-block-end: 1.25rem;
  }

  .form-landing__copy > p,
  .form-landing__intro {
    max-inline-size: 40rem;
    color: rgba(26, 26, 26, 0.78);
    font-size: 1.25rem;
    line-height: 1.8;
  }

  .form-landing__intro :global(p + p) {
    margin-top: 1rem;
  }

  .form-landing__lead {
    margin-block-end: -0.25rem;
  }

  .form-landing--dataconnect .form-landing__lead {
    margin: 0;
    color: #ffffff;
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.8;
  }

  .form-landing--contact .form-landing__copy > p,
  .form-landing--contact .form-landing__intro,
  .form-landing--dataconnect .form-landing__copy > p,
  .form-landing--dataconnect .form-landing__intro {
    color: rgba(255, 255, 255, 0.82);
  }

  .form-landing--dataconnect .form-landing__copy > p,
  .form-landing--dataconnect .form-landing__intro {
    max-inline-size: none;
    font-size: 1.25rem;
    line-height: 1.8;
  }

  .form-landing--newsletter .form-landing__eyebrow {
    color: #231f20;
    font-family: var(--font-heading);
    font-size: 7.9375rem;
    font-weight: 700;
    line-height: 0.9;
    text-transform: none;
  }

  .form-landing__form-card {
    min-block-size: 28rem;
    padding: 1.5rem;
    border: 1px solid rgba(26, 26, 26, 0.12);
    border-radius: 2.5rem;
    background: #ffffff;
    box-shadow: 0 18px 42px rgba(26, 26, 26, 0.08);
  }

  .form-landing__form-card--bare {
    min-block-size: 0;
    padding: 0.625rem;
    border: 0;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
  }

  .form-landing__frame {
    min-block-size: 25rem;
  }

  .form-landing__form-card--bare .form-landing__frame {
    min-block-size: 0;
  }

  .form-landing-summary {
    padding: 3rem var(--gutter);
    background: #1a1a1a;
    color: #ffffff;
  }

  .form-landing-summary--dataconnect {
    margin-block-end: 6.25rem;
    padding-block: 6.25rem 1.25rem;
    background: #ffffff;
    color: #231f20;
  }

  .form-landing-summary__inner {
    inline-size: min(100%, 64rem);
    margin-inline: auto;
    text-align: center;
  }

  .form-landing-summary :global(p) {
    font-size: 1.25rem;
    line-height: 1.8;
  }

  .form-landing-summary--dataconnect .form-landing-summary__inner {
    inline-size: min(100%, 62.5rem);
  }

  .form-landing-summary--dataconnect :global(p) {
    margin: 0;
    font-size: 1.25rem;
    line-height: 1.8;
    text-align: center;
  }

  :global(.form-landing__frame iframe) {
    inline-size: 100%;
  }

  @media (max-width: 900px) {
    .form-landing__inner {
      grid-template-columns: 1fr;
    }

    .form-landing--dataconnect {
      min-block-size: 26.875rem;
      padding-inline: 1.25rem;
    }

    .form-landing--dataconnect .form-landing__inner {
      grid-template-columns: 1fr;
      gap: 1.25rem;
      padding-block-start: 1.25rem;
    }

    .form-landing--dataconnect .form-landing__copy {
      gap: 0;
      margin-block-end: -1.25rem;
      padding: 0.625rem;
    }

    .form-landing__copy {
      padding-block-start: 0;
    }

    .form-landing h1 {
      font-size: 2.8125rem;
      line-height: 1.111;
    }

    .form-landing--dataconnect h1 {
      font-size: 2.8125rem;
      line-height: 1.111;
    }

    .form-landing-summary--dataconnect {
      margin-block: 2.5rem;
      padding: 3.125rem 1.5625rem 4.125rem;
    }

    .form-landing-summary--dataconnect :global(p) {
      font-size: 1.125rem;
      line-height: 1.667;
    }

    .form-landing--newsletter .form-landing__eyebrow {
      font-size: 5rem;
    }
  }

  @media (max-width: 640px) {
    .form-landing {
      padding-block: 3rem;
    }

    .form-landing--dataconnect {
      block-size: 26.875rem;
      min-block-size: 0;
      padding-block: 0;
    }

    .form-landing--dataconnect.form-landing--loads-form {
      block-size: auto;
      min-block-size: 26.875rem;
      overflow: visible;
      padding-block-end: 2rem;
    }

    .form-landing h1 {
      font-size: 2.375rem;
      line-height: 1.105;
    }

    .form-landing--dataconnect h1 {
      font-size: 2.8125rem;
      line-height: 1.111;
      margin-block-end: 0;
    }

    .form-landing--dataconnect .form-landing__lead,
    .form-landing--dataconnect .form-landing__copy > p {
      font-size: 1.125rem;
      line-height: 1.667;
    }

    .form-landing--newsletter .form-landing__eyebrow {
      font-size: 3.5rem;
    }

    .form-landing__form-card {
      padding: 1rem;
      border-radius: 1.875rem;
    }

    .form-landing--dataconnect .form-landing__form-card--bare {
      padding: 1.25rem 0 0;
    }
  }
</style>

---
import MediaAsset from '../MediaAsset.astro';

interface Leader {
  name: string;
  role: string;
  image?: string;
  videoUrl?: string;
  videoPoster?: string;
}

interface Props {
  title: string;
  intro: string | string[];
  introHtml?: string;
  leaders: Leader[];
  layout?: 'split' | 'centered';
  showImages?: boolean;
}

const { title, intro, introHtml, leaders, layout = 'split', showImages = true } = Astro.props;
const paragraphs = Array.isArray(intro) ? intro : [intro];
const sectionClass = ['leadership-section', `leadership-section--${layout}`].join(' ');
---

<section class={sectionClass} aria-labelledby="leadership-heading">
  <div class="leadership-section__inner">
    <div class="leadership-section__header">
      <h2 id="leadership-heading">{title}</h2>
      {introHtml ? (
        <div set:html={introHtml} />
      ) : (
        <div>
          {paragraphs.map((paragraph) => <p>{paragraph}</p>)}
        </div>
      )}
    </div>

    <div class="leadership-grid">
      {leaders.map((leader) => {
        const mediaSrc = leader.videoUrl || leader.image;
        const hasMedia = showImages && Boolean(mediaSrc);
        const cardClass = hasMedia
          ? 'leader-card'
          : showImages
            ? 'leader-card leader-card--no-image'
            : 'leader-card leader-card--text-only';

        return (
          <article class={cardClass}>
            {hasMedia && (
              <MediaAsset
                src={mediaSrc}
                alt={`${leader.name}, ${leader.role}`}
                width="450"
                height="399"
                loading="lazy"
                poster={leader.videoPoster || leader.image}
              />
            )}
            <div class="leader-card__overlay">
              <h3>{leader.name}</h3>
              <p>{leader.role}</p>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>

<style>
  .leadership-section {
    padding: 5rem var(--gutter);
    background: #ffffff;
  }

  .leadership-section--centered {
    padding-block: 3.125rem 5.5rem;
  }

  .leadership-section__inner {
    inline-size: min(100%, var(--content-max-width));
    margin-inline: auto;
  }

  .leadership-section__header {
    display: grid;
    grid-template-columns: minmax(0, 0.7fr) minmax(0, 1.3fr);
    gap: 2rem;
    margin-block-end: 2.5rem;
  }

  .leadership-section--centered .leadership-section__header {
    grid-template-columns: 1fr;
    justify-items: center;
    gap: 2rem;
    max-inline-size: 80rem;
    margin-inline: auto;
    margin-block-end: 5rem;
    text-align: center;
  }

  .leadership-section h2 {
    margin: 0;
    font-size: 2.8rem;
    line-height: 1.12;
    letter-spacing: 0;
  }

  .leadership-section--centered h2 {
    font-size: clamp(2.375rem, 4vw, 3.75rem);
    font-weight: 900;
    line-height: 1.083;
  }

  .leadership-section__header div {
    display: grid;
    gap: 0.85rem;
    color: rgba(26, 26, 26, 0.76);
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .leadership-section--centered .leadership-section__header div {
    max-inline-size: 80rem;
    color: #231f20;
    font-size: 1rem;
    line-height: 1.875;
  }

  .leadership-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 21rem));
    justify-content: center;
    gap: 1.5rem;
  }

  .leader-card {
    display: grid;
    grid-template-rows: auto auto;
    min-block-size: 0;
    overflow: visible;
    border-radius: 1.5rem;
    background: transparent;
  }

  .leader-card--no-image {
    display: block;
  }

  .leader-card--no-image .leader-card__overlay {
    margin-block-start: 0;
  }

  .leader-card--text-only {
    background: transparent;
  }

  :global(.leader-card .media-asset) {
    inline-size: 100%;
    block-size: auto;
    aspect-ratio: 450 / 399;
    border-radius: 1.5rem;
    background: #e8ebe6;
    object-fit: cover;
    object-position: center;
  }

  .leader-card__overlay {
    display: grid;
    gap: 0.25rem;
    inline-size: calc(100% - 1.5rem);
    margin-block-start: -0.5rem;
    min-block-size: 0;
    padding: 0.85rem 1rem;
    border-radius: 0 1.25rem 1.25rem 0;
    background: #f2f3f2;
    color: #1a1a1a;
  }

  .leader-card h3 {
    margin: 0;
    color: #1a1a1a;
    font-size: 1rem;
    line-height: 1.25;
  }

  .leader-card p {
    color: rgba(26, 26, 26, 0.78);
    font-size: 0.875rem;
    line-height: 1.25;
  }

  @media (max-width: 1024px) {
    .leadership-grid {
      grid-template-columns: repeat(2, minmax(0, 21rem));
    }

    .leadership-section--centered .leadership-section__header {
      margin-block-end: 4rem;
    }
  }

  @media (max-width: 700px) {
    .leadership-section {
      padding-block: 3.5rem;
    }

    .leadership-section__header,
    .leadership-grid {
      grid-template-columns: 1fr;
    }

    .leadership-section--centered .leadership-section__header {
      gap: 1.6rem;
      margin-block-end: 4.5rem;
    }

    .leader-card {
      inline-size: min(100%, 21rem);
      justify-self: center;
    }

    .leader-card__overlay {
      inline-size: calc(100% - 1rem);
    }
  }
</style>

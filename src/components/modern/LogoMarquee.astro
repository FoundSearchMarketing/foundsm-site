---
interface LogoItem {
  src: string;
  alt: string;
  width?: number;
  height?: number;
}

interface Props {
  title?: string;
  logos: LogoItem[];
  theme?: 'light' | 'muted';
}

const { title, logos, theme = 'light' } = Astro.props;
const tracks = [...logos, ...logos];
---

<section class={`modern-marquee modern-marquee--${theme}`} aria-label={title ?? 'Partner logos'}>
  <div class="modern-marquee__inner">
    {title && <h2>{title}</h2>}
    <div class="modern-marquee__viewport">
      <div class="modern-marquee__track">
        {tracks.map((logo, index) => (
          <figure class="modern-marquee__item" aria-hidden={index >= logos.length ? 'true' : undefined}>
            <img src={logo.src} alt={index >= logos.length ? '' : logo.alt} width={logo.width} height={logo.height} loading="lazy" decoding="async" />
          </figure>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .modern-marquee {
    overflow: hidden;
    padding: 3rem 0;
    background: #ffffff;
  }

  .modern-marquee--muted {
    background: #f2f3f2;
  }

  .modern-marquee__inner {
    display: grid;
    gap: 1.75rem;
  }

  .modern-marquee h2 {
    margin: 0;
    padding-inline: var(--gutter);
    text-align: center;
    font-size: 2rem;
    line-height: 1.2;
  }

  .modern-marquee__viewport {
    overflow: hidden;
  }

  .modern-marquee__track {
    display: flex;
    align-items: center;
    gap: 3rem;
    inline-size: max-content;
    animation: modern-marquee-scroll 34s linear infinite;
  }

  .modern-marquee__track:hover {
    animation-play-state: paused;
  }

  .modern-marquee__item {
    display: grid;
    place-items: center;
    min-inline-size: 8rem;
    block-size: 5rem;
    margin: 0;
    padding: 0 1rem;
  }

  .modern-marquee__item img {
    max-inline-size: 11rem;
    max-block-size: 4rem;
    object-fit: contain;
    filter: grayscale(1);
    opacity: 0.72;
  }

  @keyframes modern-marquee-scroll {
    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .modern-marquee__track {
      animation: none;
      flex-wrap: wrap;
      justify-content: center;
      inline-size: 100%;
      padding-inline: var(--gutter);
    }
  }
</style>

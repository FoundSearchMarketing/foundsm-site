---
import ArticleTeaserGrid from './ArticleTeaserGrid.astro';
import { localizedHref, type LegacyResourceHub } from '../../data/legacyResources';

interface Props {
  hub: LegacyResourceHub;
}

const { hub } = Astro.props;
const headingId = `${hub.title.toLowerCase().replace(/[^a-z0-9]+/g, '-')}-heading`;
const articles = hub.cards.map((card) => ({
  ...card,
  href: localizedHref(card.href),
  ctaLabel: card.ctaLabel,
}));
---

<section class="resource-hub-hero" aria-labelledby={headingId}>
  <div class="resource-hub-hero__inner">
    <div class="resource-hub-hero__copy">
      {hub.eyebrow && <p class="resource-hub-hero__eyebrow">{hub.eyebrow}</p>}
      <h1 id={headingId}>{hub.title}</h1>
      <p>{hub.intro}</p>
    </div>

    <div class="resource-hub-hero__media">
      <img
        src={hub.image.src}
        width={hub.image.width}
        height={hub.image.height}
        alt={hub.image.alt}
        loading="eager"
        decoding="async"
      />
    </div>
  </div>
</section>

{hub.filters && hub.filters.length > 0 && (
  <nav class="resource-hub-filters" aria-label="Resource categories">
    <div class="resource-hub-filters__inner">
      {hub.filters.map((filter) => <a href="#resource-list">{filter}</a>)}
    </div>
  </nav>
)}

<section class="resource-hub-list" id="resource-list" aria-label="Resource list">
  <div class="resource-hub-list__inner">
    <ArticleTeaserGrid articles={articles} />
  </div>
</section>

<style>
  .resource-hub-hero {
    overflow: hidden;
    padding: 5rem var(--gutter);
    background: #f2f3f2;
  }

  .resource-hub-hero__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(14rem, 26rem);
    align-items: center;
    gap: 3rem;
    inline-size: min(100%, var(--content-max-width));
    margin-inline: auto;
  }

  .resource-hub-hero__copy {
    display: grid;
    gap: 1.25rem;
  }

  .resource-hub-hero__eyebrow {
    margin: 0;
    color: var(--color-primary);
    font-size: 0.875rem;
    font-weight: 800;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .resource-hub-hero h1 {
    max-inline-size: 46rem;
    margin: 0;
    font-size: 4.375rem;
    line-height: 1.071;
    letter-spacing: 0;
  }

  .resource-hub-hero p {
    max-inline-size: 44rem;
    margin: 0;
    color: rgba(26, 26, 26, 0.76);
    font-size: 1.25rem;
    line-height: 1.8;
  }

  .resource-hub-hero__media {
    display: grid;
    place-items: center;
  }

  .resource-hub-hero__media img {
    inline-size: min(100%, 27.125rem);
    filter: drop-shadow(0 18px 30px rgba(26, 26, 26, 0.14));
  }

  .resource-hub-filters {
    padding: 1.25rem var(--gutter);
    background: #ffffff;
    border-block: 1px solid rgba(26, 26, 26, 0.1);
  }

  .resource-hub-filters__inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.25rem 2rem;
    inline-size: min(100%, var(--content-max-width));
    margin-inline: auto;
  }

  .resource-hub-filters a {
    color: #231f20;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0;
    line-height: 1.3;
    text-transform: uppercase;
  }

  .resource-hub-filters a:hover,
  .resource-hub-filters a:focus-visible {
    color: var(--color-primary);
  }

  .resource-hub-list {
    padding: 4rem var(--gutter) 6rem;
    background: #ffffff;
  }

  .resource-hub-list__inner {
    inline-size: min(100%, var(--content-max-width));
    margin-inline: auto;
  }

  @media (max-width: 900px) {
    .resource-hub-hero__inner {
      grid-template-columns: 1fr;
    }

    .resource-hub-hero__media {
      justify-items: start;
    }

    .resource-hub-hero h1 {
      font-size: 3.25rem;
      line-height: 1.08;
    }
  }

  @media (max-width: 640px) {
    .resource-hub-hero {
      padding-block: 3.5rem;
    }

    .resource-hub-hero h1 {
      font-size: 2.5rem;
    }

    .resource-hub-hero p {
      font-size: 1.125rem;
      line-height: 1.65;
    }

    .resource-hub-list {
      padding-block: 3rem 4rem;
    }
  }
</style>

---
import { type LegacyLandingPage } from '../../data/legacyResources';

interface Props {
  page: LegacyLandingPage;
}

const { page } = Astro.props;
const headingId = `${page.title.toLowerCase().replace(/[^a-z0-9]+/g, '-')}-heading`;
---

<section class="resource-landing-hero" aria-labelledby={headingId}>
  <div class="resource-landing-hero__inner">
    <div class="resource-landing-hero__copy">
      {page.eyebrow && <p class="resource-landing-hero__eyebrow">{page.eyebrow}</p>}
      <h1 id={headingId}>{page.title}</h1>
      <p class="resource-landing-hero__lead">{page.lead}</p>
      {page.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
      {page.cta && (
        <a class="resource-landing-hero__button" href={page.cta.href}>{page.cta.label}</a>
      )}
    </div>

    <aside class="resource-landing-form" aria-labelledby={`${headingId}-form`}>
      {page.image && (
        <img
          src={page.image.src}
          width={page.image.width}
          height={page.image.height}
          alt={page.image.alt}
          loading="eager"
          decoding="async"
        />
      )}
      <h2 id={`${headingId}-form`}>{page.formTitle}</h2>
      <div class="hs-form-frame resource-landing-form__frame" data-region="na1" data-form-id={page.formId} data-portal-id="5045186"></div>
    </aside>
  </div>
</section>

<section class="resource-landing-details" aria-label="Resource details">
  <div class="resource-landing-details__inner">
    {page.sections.map((section) => (
      <section class="resource-landing-details__section">
        <h2>{section.title}</h2>
        {section.intro && <p>{section.intro}</p>}
        {section.paragraphs?.map((paragraph) => <p>{paragraph}</p>)}
        {section.items && (
          <ul>
            {section.items.map((item) => <li>{item}</li>)}
          </ul>
        )}
      </section>
    ))}
  </div>
</section>

<script is:inline src="https://js.hsforms.net/forms/embed/5045186.js" defer></script>

<style>
  .resource-landing-hero {
    padding: 5rem var(--gutter);
    background: #f2f3f2;
  }

  .resource-landing-hero__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(20rem, 31.25rem);
    align-items: start;
    gap: 3rem;
    inline-size: min(100%, var(--content-max-width));
    margin-inline: auto;
  }

  .resource-landing-hero__copy {
    display: grid;
    gap: 1rem;
  }

  .resource-landing-hero__eyebrow {
    margin: 0;
    color: var(--color-primary);
    font-size: 0.875rem;
    font-weight: 800;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .resource-landing-hero h1 {
    max-inline-size: 48rem;
    margin: 0;
    font-size: 4rem;
    line-height: 1.08;
    letter-spacing: 0;
  }

  .resource-landing-hero__lead {
    margin: 0;
    color: #231f20;
    font-size: 1.375rem;
    font-weight: 700;
    line-height: 1.45;
  }

  .resource-landing-hero p:not(.resource-landing-hero__lead) {
    max-inline-size: 46rem;
    margin: 0;
    color: rgba(26, 26, 26, 0.78);
    font-size: 1.0625rem;
    line-height: 1.75;
  }

  .resource-landing-hero__button {
    display: inline-flex;
    justify-content: center;
    justify-self: start;
    min-block-size: 3.25rem;
    margin-block-start: 0.5rem;
    padding: 0.875rem 1.5rem;
    border-radius: 999px;
    background: var(--color-primary);
    color: #1a1a1a;
    font-size: 1rem;
    font-weight: 800;
    line-height: 1.3;
    text-align: center;
  }

  .resource-landing-form {
    position: sticky;
    inset-block-start: calc(var(--header-height) + 1rem);
    display: grid;
    gap: 1.25rem;
    padding: 1.5rem;
    border: 1px solid rgba(26, 26, 26, 0.12);
    border-radius: 0.5rem;
    background: #ffffff;
    box-shadow: 0 18px 42px rgba(26, 26, 26, 0.08);
  }

  .resource-landing-form img {
    inline-size: 100%;
    border-radius: 0.5rem;
  }

  .resource-landing-form h2 {
    margin: 0;
    font-family: var(--font-body);
    font-size: 1.375rem;
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .resource-landing-form__frame {
    min-block-size: 24rem;
  }

  :global(.resource-landing-form__frame iframe) {
    inline-size: 100%;
  }

  .resource-landing-details {
    padding: 4rem var(--gutter) 6rem;
    background: #ffffff;
  }

  .resource-landing-details__inner {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 2rem;
    inline-size: min(100%, var(--content-max-width));
    margin-inline: auto;
  }

  .resource-landing-details__section {
    padding-block-start: 0.75rem;
    border-block-start: 3px solid var(--color-primary);
  }

  .resource-landing-details h2 {
    margin: 0 0 1rem;
    font-size: 2rem;
    line-height: 1.18;
  }

  .resource-landing-details p {
    margin: 0 0 1rem;
    color: rgba(26, 26, 26, 0.78);
    font-size: 1rem;
    line-height: 1.75;
  }

  .resource-landing-details ul {
    display: grid;
    gap: 0.875rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .resource-landing-details li {
    position: relative;
    padding-inline-start: 1.5rem;
    color: rgba(26, 26, 26, 0.82);
    font-size: 1rem;
    line-height: 1.65;
  }

  .resource-landing-details li::before {
    content: "";
    position: absolute;
    inset-block-start: 0.65rem;
    inset-inline-start: 0;
    inline-size: 0.55rem;
    block-size: 0.55rem;
    border-radius: 999px;
    background: var(--color-primary);
  }

  @media (max-width: 980px) {
    .resource-landing-hero__inner,
    .resource-landing-details__inner {
      grid-template-columns: 1fr;
    }

    .resource-landing-form {
      position: relative;
      inset-block-start: auto;
    }

    .resource-landing-hero h1 {
      font-size: 3rem;
    }
  }

  @media (max-width: 640px) {
    .resource-landing-hero {
      padding-block: 3.5rem;
    }

    .resource-landing-hero h1 {
      font-size: 2.375rem;
    }

    .resource-landing-details {
      padding-block: 3rem 4rem;
    }
  }
</style>

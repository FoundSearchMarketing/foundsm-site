---
import { type LegacyVideoPage } from '../../data/legacyResources';

interface Props {
  page: LegacyVideoPage;
}

const { page } = Astro.props;
const headingId = `${page.title.toLowerCase().replace(/[^a-z0-9]+/g, '-')}-heading`;
const embedSrc = `https://www.youtube.com/embed/${page.youtubeId}`;
---

<section class={`resource-video resource-video--${page.tone ?? 'watch'}`} aria-labelledby={headingId}>
  <div class="resource-video__inner">
    <div class="resource-video__copy">
      <p class="resource-video__eyebrow">{page.tone === 'thank-you' ? 'Registered' : 'On-Demand Webinar'}</p>
      <h1 id={headingId}>{page.title}</h1>
      {page.intro && (
        <p>
          {page.intro}
          {page.fallbackHref && <a href={page.fallbackHref}> Open the video link.</a>}
        </p>
      )}
    </div>

    <div class="resource-video__frame">
      <iframe
        src={embedSrc}
        title={page.title}
        loading="lazy"
        allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>
  </div>
</section>

<style>
  .resource-video {
    min-block-size: 46rem;
    padding: 5rem var(--gutter);
    background: #f2f3f2;
  }

  .resource-video--watch {
    background: #1a1a1a;
    color: #ffffff;
  }

  .resource-video__inner {
    display: grid;
    gap: 2rem;
    inline-size: min(100%, 68rem);
    margin-inline: auto;
  }

  .resource-video__copy {
    display: grid;
    justify-items: center;
    gap: 0.85rem;
    text-align: center;
  }

  .resource-video__eyebrow {
    margin: 0;
    color: var(--color-primary);
    font-size: 0.875rem;
    font-weight: 800;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .resource-video h1 {
    max-inline-size: 56rem;
    margin: 0;
    font-size: 3.75rem;
    line-height: 1.08;
    letter-spacing: 0;
  }

  .resource-video--watch h1 {
    color: #ffffff;
  }

  .resource-video p:not(.resource-video__eyebrow) {
    max-inline-size: 48rem;
    margin: 0;
    color: rgba(26, 26, 26, 0.78);
    font-size: 1.125rem;
    line-height: 1.7;
  }

  .resource-video--watch p:not(.resource-video__eyebrow) {
    color: rgba(255, 255, 255, 0.82);
  }

  .resource-video a {
    color: #1a1a1a;
    font-weight: 800;
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .resource-video__frame {
    overflow: hidden;
    border-radius: 0.5rem;
    background: #000000;
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.18);
  }

  .resource-video__frame iframe {
    display: block;
    inline-size: 100%;
    aspect-ratio: 16 / 9;
    border: 0;
  }

  @media (max-width: 640px) {
    .resource-video {
      min-block-size: 36rem;
      padding-block: 3.5rem;
    }

    .resource-video h1 {
      font-size: 2.375rem;
    }
  }
</style>

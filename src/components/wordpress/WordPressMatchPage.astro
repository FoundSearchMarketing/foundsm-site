  },
  {
    title: 'Closing the Loop: How Conversion APIs and Value-Based Bidding Transform Performance Marketing',
    href: '/insights/closing-the-loop-how-conversion-apis-and-value-based-bidding-transform-performance-marketing/',
    imageSrc: 'https://foundsm.com/found2025/wp-content/uploads/2026/01/closing-the-loop-main-768x768.webp',
    imageAlt: '',
    categories: [{ label: 'AI' }, { label: 'Paid Media Strategy' }],
    publishedLabel: 'January 23, 2026',
    excerpt: 'Unlock the next evolution in performance marketing by moving beyond basic pixel tracking and embracing Conversion APIs.',
  },

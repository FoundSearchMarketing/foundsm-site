const insightPosts = posts.length ? posts.slice(0, 6) : fallbackPosts;

const firstPartyBullets = [
  {
    lead: 'Why browser-side tracking is collapsing',
    body: ' and how to build a signal-resilient infrastructure that survives ITP, ETP, and cookie loss.',
  },
  {
    lead: 'How to design a first-party data capture layer',
    body: ' that collects the identifiers AI algorithms need to optimize correctly.',
  },
  {
    lead: 'How to unify marketing and sales data',
    body: ' so that revenue (not form fills) becomes the core training signal for your ad platforms.',
  },
  {
    lead: 'How server-to-server APIs transform campaign performance',
    body: ', attribution accuracy, and bidding efficiency.',
  },
  {
    lead: 'How to implement value-based and propensity-based bidding',
    body: ', enabling algorithms to prioritize high-value customers over low-intent noise.',
  },
  {
    lead: 'A full technical readiness audit',
    body: ' to assess whether your organization is structurally prepared for AI-era advertising.',
  },
];
---

{variant === 'newsletter' && (
  <>
    <section class="wp-newsletter-hero" aria-labelledby="newsletter-title">
      <div class="wp-shell wp-newsletter-hero__grid">
        <div class="wp-newsletter-copy">
          <p class="wp-newsletter-kicker">Get Found<br />in Your<br />Inbox</p>
          <h1 id="newsletter-title">Sign Up for Our<br class="desktop-break" /> Newsletter</h1>
        </div>
        <aside class="wp-newsletter-form" aria-label="Newsletter signup form">
          <div class="hs-form-frame" data-region="na1" data-form-id="f757bd34-b8c5-4f2a-a1ef-19c3a364683b" data-portal-id="5045186"></div>
        </aside>
      </div>
    </section>
    <section class="wp-dark-strip wp-newsletter-summary">
      <p>Get monthly insights, real-world strategies, and expert takes from the Found team — plus the latest on upcoming events and recaps on any you missed.</p>
    </section>
  </>
)}

{variant === 'privacy' && (
  <section class="wp-title-page wp-privacy-page" aria-labelledby="privacy-title">
    <div class="wp-shell">
      <h1 id="privacy-title">Privacy Policy</h1>
      <div class="wp-privacy-notice">
        <div class="ot-privacy-notice-language-dropdown-container"></div>
        <div id="otnotice-d5d58139-f0ee-4386-8325-1f3dec8dc14f" class="otnotice"></div>
      </div>
    </div>
  </section>
)}

{variant === 'signal-quiz' && (
  <section class="wp-dark-hero wp-signal-hero" aria-labelledby="signal-title">
    <div class="wp-shell wp-centered">
      <h1 id="signal-title">Curious where your organization<br class="desktop-break" /> stands?</h1>
      <p>Take the quiz to find out.</p>
      <div class="wp-signal-embed involveme_embed" data-project="quiz" data-title="Revenue Engineering Assessment - Embedded">
        <script is:inline src="https://datasignals.foundsm.com/embed" defer></script>
      </div>
    </div>
  </section>
)}

{variant === 'whitepapers-index' && (
  <section class="wp-dark-hero wp-whitepaper-index" aria-labelledby="whitepapers-title">
    <div class="wp-shell wp-centered">
      <h1 id="whitepapers-title">You've built something great.<br />Now let data fuel your growth.</h1>
      <p>Found turns your data into a growth engine for smarter targeting and faster ROI.</p>
      <a class="wp-green-pill" href="/contact-us/">Let's Chat Data — Grab a Spot on Our Calendar →</a>
    </div>
  </section>
)}

{variant === 'safelist' && (
  <>
    <section class="wp-safelist-hero" aria-labelledby="safelist-title">
      <div class="wp-shell wp-centered">
        <span class="wp-check" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M20.3 6.3 9.5 17.1l-5.1-5.1 2.1-2.1 3 3L18.2 4.2l2.1 2.1Z"/></svg>
        </span>
        <h1 id="safelist-title">Thank You for Signing Up!</h1>
        <p>So glad you've found your way to us—welcome aboard! To make sure our emails land straight in your inbox and not your spam or junk folder, follow these quick steps to safelist us:</p>
      </div>
    </section>
    <section class="wp-dark-strip wp-safelist-steps" aria-labelledby="safelist-steps-title">
      <div class="wp-shell">
        <h2 id="safelist-steps-title">How to Safelist Our Emails</h2>
        <div class="wp-safelist-columns">
          {safelistColumns.map((column) => (
            <article>
              <h3>{column.title}</h3>
              <ol>
                {column.steps.map((step) => <li>{step}</li>)}
              </ol>
            </article>
          ))}
        </div>
      </div>
    </section>
    <section class="wp-safelist-outro">
      <div class="wp-shell wp-centered">
        <p>That's it! You're all set to stay updated with our latest news, tips, and exclusive content. If you don't see our emails, check your spam folder just in case.</p>
        <h2>Happy reading!</h2>
      </div>
    </section>
  </>
)}

{variant === 'thank-you' && (
  <>
    <section class="wp-thanks-hero" aria-labelledby="thanks-title">
      <div class="wp-shell wp-centered">
        <span class="wp-check" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M20.3 6.3 9.5 17.1l-5.1-5.1 2.1-2.1 3 3L18.2 4.2l2.1 2.1Z"/></svg>
        </span>
        <h1 id="thanks-title">You've Just Made a Smart Move.</h1>
        <p>Thanks for connecting with Found!</p>
        <p>Someone from our team will reach out within 1–2 business days to talk about how we can help you grow faster, smarter, and with data on your side.</p>
      </div>
    </section>
    <section class="wp-insights" aria-labelledby="thanks-insights-title">
      <div class="wp-shell">
        <h2 id="thanks-insights-title">Curious? Dive Into Our Latest Insights Below.</h2>
        <div class="wp-insights-grid">
          {insightPosts.map((post) => (
            <article class="wp-insight-card">
              {post.imageSrc && <img src={post.imageSrc} alt={post.imageAlt || ''} loading="lazy" decoding="async" />}
              <p class="wp-insight-card__meta">{(post.categories || []).map((category) => category.label).join(', ')}</p>
              <h3><a href={post.href}>{post.title}</a></h3>
              {post.publishedLabel && <time>{post.publishedLabel}</time>}
              {post.excerpt && <p class="wp-insight-card__excerpt">{post.excerpt}</p>}
              <a class="wp-dark-pill" href={post.href}>Read Article →</a>
            </article>
          ))}
        </div>
        <div class="wp-load-more"><a class="wp-green-pill" href="/insights/">Load More</a></div>
      </div>
    </section>
  </>
)}

{variant === 'first-party-data' && (
  <>
    <section class="wp-first-party-hero" aria-labelledby="first-party-title">
      <div class="wp-first-party-hero__bg" aria-hidden="true"></div>
      <div class="wp-first-party-hero__inner">
        <h1 id="first-party-title">Why First-Party Data Is<br />Your Most Valuable<br />Profit Lever</h1>
        <aside class="wp-download-card" aria-labelledby="download-title">
          <h2 id="download-title">Download Now</h2>
          <div class="hs-form-frame" data-region="na1" data-form-id="2c65e995-aba0-4239-955c-9beb15b0791d" data-portal-id="5045186"></div>
        </aside>
      </div>
    </section>
    <section class="wp-first-party-body">
      <div class="wp-first-party-copy">
        <h2>Unlock the Profit Potential of Your<br />First-Party Data</h2>
        <a class="wp-green-pill" href="/contact-us/">Schedule a Call with our Team</a>
        <p>AI has permanently rewritten the rules of digital advertising. With Google, Meta, and other major ad platforms shifting to black-box, machine-learning systems, marketers can no longer rely on manual optimization, pixel-based tracking, or surface-level conversion events. The brands that win in this new landscape will be the ones that control and activate their own first-party data.</p>
        <p><strong><em>This white paper is your blueprint for doing exactly that.</em></strong><br />In this comprehensive technical guide, you'll learn how to architect a closed-loop data system that feeds real revenue intelligence (not noisy browser signals) back into your ad platforms. You'll discover how to capture durable identifiers, store them in a resilient first-party framework, and push enriched, truth-based events directly into Google, Meta, LinkedIn, and beyond.</p>
        <h2>What You'll Gain</h2>
        <p>Marketers, revenue leaders, and technical operators will walk away with a deep understanding of:</p>
        <ul>
          {firstPartyBullets.map((item) => <li><strong>{item.lead}</strong>{item.body}</li>)}
        </ul>
        <h2>Who This Is For</h2>
        <p>This resource is designed for <strong>Revenue Operations, Marketing Operations, Data Engineering, and Paid Media leaders</strong> who need more than conceptual advice and recognize the need for a detailed architectural plan.</p>
        <p>If you're responsible for scaling revenue, improving measurement, or modernizing your marketing infrastructure, this white paper will give you the strategic clarity and technical depth required to build an AI-ready organization.</p>
        <p><strong>Download the white paper to learn how first-party data becomes your most powerful profit lever and how to engineer the closed-loop system that drives sustainable, measurable growth.</strong></p>
      </div>
    </section>
  </>
)}

{(variant === 'newsletter' || variant === 'first-party-data') && (
  <script is:inline src="https://js.hsforms.net/forms/embed/5045186.js" defer></script>
)}

{variant === 'privacy' && (
  <>
    <script
      is:inline
      id="otprivacy-notice-script"
      type="text/javascript"
      src="https://privacyportal-cdn.onetrust.com/privacy-notice-scripts/otnotice-1.0.min.js"
      charset="UTF-8"
      defer
    >
      settings=""
    </script>
    <script is:inline>
      (() => {
        const noticeUrl = 'https://privacyportal-cdn.onetrust.com/storage-container/39f3b408-e620-42ee-94e1-d0ee54b3c108/privacy-notices/d5d58139-f0ee-4386-8325-1f3dec8dc14f/published/privacynotice.json';
        let attempts = 0;
        const loadNotice = () => {
          const api = window.OneTrust && window.OneTrust.NoticeApi;
          if (api && api.Initialized && typeof api.Initialized.then === 'function') {
            api.Initialized.then(() => api.LoadNotices([noticeUrl]));
            return;
          }
          attempts += 1;
          if (attempts < 40) {
            window.setTimeout(loadNotice, 250);
          }
        };
        loadNotice();
      })();
    </script>
  </>
)}

<style>
  .wp-shell {
    inline-size: min(calc(100% - (2 * var(--page-gutter))), var(--content-max-width));
    margin-inline: auto;
  }

  .wp-centered {
    text-align: center;
  }

  .desktop-break {
    display: block;
  }

  .wp-newsletter-hero {
    padding-block: 6.1rem 6rem;
    background: #fff;
  }

  .wp-newsletter-hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(24rem, 0.65fr);
    align-items: start;
    gap: 4rem;
  }

  .wp-newsletter-copy {
    min-inline-size: 0;
  }

  .wp-newsletter-kicker {
    max-inline-size: 40rem;
    margin: 0 0 2.5rem;
    color: #231f20;
    font-family: var(--font-heading);
    font-size: clamp(4.5rem, 8.8vw, 8rem);
    font-weight: 700;
    line-height: 0.9;
  }

  .wp-newsletter-hero h1 {
    margin: 0;
    color: var(--color-primary);
    font-family: var(--font-body);
    font-size: clamp(2.5rem, 4vw, 4rem);
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: 0;
  }

  .wp-newsletter-form {
    min-block-size: 34rem;
    padding-block-start: 1rem;
  }

  .wp-newsletter-form .hs-form-frame {
    inline-size: 100%;
    min-block-size: 34rem;
  }

  .wp-dark-strip {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    background: #231f20;
    color: #fff;
  }

  .wp-dark-strip::before,
  .wp-dark-hero::before {
    position: absolute;
    inset: 0;
    z-index: -1;

    imageSrc: 'https://foundsm.com/found2025/wp-content/uploads/2026/03/GA-API-update-hero-768x513.webp',
    imageAlt: '',
    categories: [{ label: 'Industry Insights' }, { label: 'Marketing Analytics & Tracking' }],

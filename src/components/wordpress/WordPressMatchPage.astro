  }

  .wp-safelist-columns li::before {
    position: absolute;
    inset-block-start: 0.1rem;
    inset-inline-start: 0;
    display: grid;
    place-items: center;
    inline-size: 1.9rem;
    block-size: 1.9rem;
    border-radius: 50%;
    background: #c6e89d;
    color: #231f20;
    content: counter(safelist);
    font-weight: 900;
  }

  .wp-safelist-outro {
    padding: 6.25rem var(--gutter);
    text-align: center;
  }

  .wp-safelist-outro p {
    max-inline-size: 74rem;
    margin: 0 auto;
    font-size: 1.35rem;
    line-height: 1.6;
  }

  .wp-safelist-outro h2 {
    margin-block-start: 1.75rem;
    font-size: 3rem;
    line-height: 1.1;
  }

  .wp-thanks-hero {
    padding-block: 13rem 7rem;
  }

  .wp-insights {
    padding: 3rem var(--gutter) 10rem;
    background: #fff;
  }

  .wp-insights h2 {
    margin: 0 0 6rem;
    font-size: 2rem;
    line-height: 1.2;
    text-align: center;
  }

  .wp-insights-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 5rem 3.125rem;
  }

  .wp-insight-card {
    display: grid;
    align-content: start;
    gap: 1.25rem;
  }

  .wp-insight-card img {
    inline-size: 100%;
    aspect-ratio: 1.5;
    border-radius: 1rem;
    object-fit: cover;
  }

  .wp-insight-card__meta {
    margin: 0;
    padding-inline-start: 0.85rem;
    border-inline-start: 4px solid var(--color-primary);
    color: #4d4d4d;
    font-size: 0.75rem;
    letter-spacing: 0.22em;
    line-height: 1.6;
    text-transform: uppercase;
  }


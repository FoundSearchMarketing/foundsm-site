  }

  .wp-newsletter-summary {
    padding: 5rem var(--gutter);
    text-align: center;
  }

  .wp-newsletter-summary p {
    max-inline-size: 62rem;
    margin: 0 auto;
    font-size: 1.25rem;
    line-height: 1.8;
  }

  .wp-title-page {
    min-block-size: 7.75rem;
    padding: 2.6rem 0 2.4rem;
    background: #fff;
  }

  .wp-title-page .wp-shell {
    inline-size: min(calc(100% - 40px), var(--content-max-width));
  }

  .wp-title-page h1 {
    margin: 0;
    font-size: clamp(2rem, 3vw, 2.75rem);
    line-height: 1.1;
    letter-spacing: 0;
  }

  .wp-privacy-page {
    padding-block-end: 5rem;
  }

  .wp-privacy-notice {
    margin-block-start: 2.5rem;
    color: #231f20;
    font-size: 1rem;
    line-height: 1.65;
  }

  .wp-dark-hero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    background: #231f20;
    color: #fff;
  }

  .wp-signal-hero {
    padding-block: 13.8rem 10.7rem;
  }

  .wp-dark-hero h1 {
    margin: 0;
    color: #fff;
    font-size: clamp(2.8rem, 5vw, 3.85rem);
    line-height: 1.1;
    letter-spacing: 0;
  }

  .wp-dark-hero p {

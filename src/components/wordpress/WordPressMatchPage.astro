    font-size: 0.925rem;
    line-height: 1.7;
  }

  .wp-safelist-steps {
    padding: 3.75rem var(--gutter) 7rem;
  }

  .wp-safelist-steps h2 {
    color: #fff;
    font-family: var(--font-body);
    font-size: clamp(2rem, 3vw, 3rem);
    font-weight: 900;
    line-height: 1.15;
    text-align: center;
  }

  .wp-safelist-columns {

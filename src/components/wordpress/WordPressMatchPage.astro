    imageSrc: 'https://foundsm.com/found2025/wp-content/uploads/2026/03/bot-traffic-sm-768x513.webp',
    imageAlt: '',
    categories: [{ label: 'Marketing Analytics & Tracking' }, { label: 'Paid Media Strategy' }],
    publishedLabel: 'March 20, 2026',
    excerpt: 'Leads are up. Pipeline quality is down. Dirty signals can poison optimization and steer budget to the wrong audiences.',

---
interface InsightPost {
  title: string;
  href: string;
  imageSrc?: string;
  imageAlt?: string;
  categories?: { label: string }[];
  publishedLabel?: string;
  excerpt?: string;
}

interface Props {
  variant:
    | 'newsletter'
    | 'privacy'
    | 'signal-quiz'
    | 'safelist'
    | 'thank-you'
    | 'whitepapers-index'
    | 'first-party-data';
  posts?: InsightPost[];
}

const { variant, posts = [] } = Astro.props;

const safelistColumns = [
  {
    title: 'Gmail',
    steps: [
      'Open Gmail and go to Settings > See all settings.',
      'Click the Filters and Blocked Addresses tab and select Create a new filter.',
      'Add our email (marketing@foundsm.com) in the From field and click Create filter.',
      'Check Never send it to Spam, then hit Create filter again.',
    ],
  },
  {
    title: 'Outlook',
    steps: [
      'Open Outlook and go to Settings > View all Outlook settings.',
      'Navigate to Mail > Junk email.',
      'Under Safe senders and domains, click Add and enter our email (marketing@foundsm.com) or domain (foundsm.com).',
      'Hit Save to confirm.',
    ],
  },
  {
    title: 'Yahoo',
    steps: [
      'Go to Settings > More Settings > Filters.',
      'Click Add new filters and name it (e.g., "Newsletter").',
      'Add our email (marketing@foundsm.com) under the From field and set it to send to your Inbox.',
      'Click Save.',
    ],
  },
];

const fallbackPosts: InsightPost[] = [
  {

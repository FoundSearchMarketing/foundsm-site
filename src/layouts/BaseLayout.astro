---
import SEOHead from '../components/SEOHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { resolveSeo, type JsonLd } from '../lib/seo';
import { enableThirdPartyScripts } from '../lib/thirdPartyScripts';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  canonicalUrl?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
  ogType?: string;
  robots?: string;
  twitterCard?: string;
  twitterSite?: string;
  twitterTitle?: string;
  twitterDescription?: string;
  twitterImage?: string;
  publishedAt?: string;
  modifiedAt?: string;
  schema?: JsonLd;
  schemaJson?: string;
  hideNavigation?: boolean;
  hideFooter?: boolean;
  bodyClass?: string;
}

const {
  hideNavigation = false,
  hideFooter = false,
  bodyClass,
  ...seoProps
} = Astro.props;
const seo = resolveSeo(Astro.url.pathname, seoProps);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <SEOHead
    title={seo.title}
    description={seo.description}
    canonical={seo.canonical}
    ogTitle={seo.ogTitle}
    ogDescription={seo.ogDescription}
    ogImage={seo.ogImage}
    ogImageWidth={seo.ogImageWidth}
    ogImageHeight={seo.ogImageHeight}
    ogType={seo.ogType}
    robots={seo.robots}
    twitterCard={seo.twitterCard}
    twitterSite={seo.twitterSite}
    twitterTitle={seo.twitterTitle}
    twitterDescription={seo.twitterDescription}
    twitterImage={seo.twitterImage}
    publishedAt={seo.publishedAt}
    modifiedAt={seo.modifiedAt}
    schema={seo.schema}
  />
  <!-- A/B Test: push variants to GTM dataLayer -->
  <script is:inline>
  (function() {
    var cookies = document.cookie.split(';');
    var abTests = {};
    cookies.forEach(function(cookie) {
      var parts = cookie.trim().split('=');
      if (parts[0].startsWith('ab-')) {
        abTests[parts[0]] = parts[1];
      }
    });
    if (Object.keys(abTests).length > 0) {
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: 'ab_test_loaded',
        abTests: abTests
      });
    }
  })();
  </script>
</head>
<body class={bodyClass}>
  <!-- Google Tag Manager (noscript) -->
  {enableThirdPartyScripts && (
    <noscript><iframe src="https://sst.foundsm.com/ns.html?id=GTM-PG7TGGG" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  )}

  {!hideNavigation && <Header />}
  <main id="main-content">
    <slot />
  </main>
  {!hideFooter && <Footer />}

  <script is:inline src="/scripts/main.js"></script>

  <!-- HubSpot Tracking Code — injected on first interaction (5s fallback) to keep its ~1.4s of JS execution off the critical rendering path on mobile -->
  {enableThirdPartyScripts && (
    <script is:inline>
      (function () {
        var events = ['scroll', 'pointerdown', 'keydown', 'touchstart'];
        var loaded = false;
        function loadHubSpot() {
          if (loaded) return;
          loaded = true;
          var s = document.createElement('script');
          s.id = 'hs-script-loader';
          s.async = true;
          s.defer = true;
          s.src = '//js.hs-scripts.com/5045186.js';
          document.body.appendChild(s);
          events.forEach(function (e) { window.removeEventListener(e, loadHubSpot); });
        }
        events.forEach(function (e) { window.addEventListener(e, loadHubSpot, { passive: true }); });
        setTimeout(loadHubSpot, 5000);
      })();
    </script>
  )}
</body>
</html>

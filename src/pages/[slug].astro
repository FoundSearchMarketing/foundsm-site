---
import BaseLayout from '../layouts/BaseLayout.astro';
import FormLanding from '../components/modern/FormLanding.astro';
import LegacyPageRenderer from '../components/legacy/LegacyPageRenderer.astro';
import LegacyInsightsFilterResults from '../components/LegacyInsightsFilterResults.astro';
import { getLatestBlogPosts } from '../lib/blogPosts';
import { defaultInsightsPageData, mergeInsightsPageData } from '../lib/insightsPageData';
import { loadLegacyPages } from '../lib/legacyPageFetch';
import { getLegacyPageDefinitionsByGroup, pathToSingleSlug, type LegacyPageData } from '../lib/legacyPageData';
import { richHtml, richText } from '../lib/fixedPageRender';
import { insightsPageQuery, sanityClient, urlFor } from '../lib/sanity';

export async function getStaticPaths() {
  const rootDefinitions = getLegacyPageDefinitionsByGroup('root');
  const pages = await loadLegacyPages(rootDefinitions);

  return rootDefinitions.map((definition) => ({
    params: { slug: pathToSingleSlug(definition.path) },
    props: { page: pages.get(definition.path) },
  }));
}

interface Props {
  page: LegacyPageData;
}

const { page } = Astro.props;
const isDataConnectPage = page.path === '/dataconnect/';
const isInsightsFilterResultsPage = page.path === '/insights-filter-results/';

const filterResultsCanonical = 'https://foundsm.com/insights-filter-results/';
const filterResultsDescription = 'Great performance begins by staying sharp. Tap into fresh insights, news, and forward-thinking strategies from our team and beyond.';
const filterResultsHeroImageFallback = '/images/migrated/insights-bulb-1.webp';

let filterResultsData:
  | {
      hero: {
        headline?: string;
        body?: string;
        imageSrc?: string;
        imageAlt?: string;
      };
      latestPosts: {
        excerpt: string;
        href: string;
        imageSrc?: string;
        imageAlt?: string;
        tag?: string;
      }[];
      filterCards: {
        excerpt: string;
        href: string;
      }[];
      schema: object;
    }
  | undefined;

if (isInsightsFilterResultsPage) {
  const [sanityInsightsPage, latestBlogPosts] = await Promise.all([
    sanityClient.fetch(insightsPageQuery).catch(() => null),
    getLatestBlogPosts(2),
  ]);
  const insightsPage = mergeInsightsPageData(sanityInsightsPage);

  const heroImage = (() => {
    if (!insightsPage.hero.image) return filterResultsHeroImageFallback;

    try {
      return urlFor(insightsPage.hero.image).width(868).height(1218).fit('crop').auto('format').url();
    } catch {
      return filterResultsHeroImageFallback;
    }
  })();

  const headline = insightsPage.hero.headline || defaultInsightsPageData.hero.headline;
  const body = insightsPage.hero.body || filterResultsDescription;
  const filterCardExcerpt = [headline, body].filter(Boolean).join(' ');

  filterResultsData = {
    hero: {
      headline,
      body,
      imageSrc: heroImage,
      imageAlt: insightsPage.hero.imageAlt || '',
    },
    latestPosts: latestBlogPosts.map((post) => ({
      excerpt: post.excerpt,
      href: `/insights/${post.slug}/`,
      imageSrc: post.heroImage,
      imageAlt: post.heroImageAlt,
      tag: 'Blog',
    })),
    filterCards: Array.from({ length: 5 }, () => ({
      excerpt: filterCardExcerpt,
      href: '/insights-filter-results/',
    })),
    schema: {
      '@context': 'https://schema.org',
      '@graph': [
        {
          '@type': 'WebPage',
          '@id': `${filterResultsCanonical}#webpage`,
          url: filterResultsCanonical,
          name: 'Insights | Found Search Marketing | Enterprise Paid Media Agency',
          description: filterResultsDescription,
          primaryImageOfPage: heroImage,
          publisher: {
            '@type': 'Organization',
            name: 'Found Search Marketing',
            url: 'https://foundsm.com/',
          },
        },
      ],
    },
  };
}

const layoutTitle = isInsightsFilterResultsPage
  ? 'Insights | Found Search Marketing | Enterprise Paid Media Agency'
  : page.seoTitle;
const layoutDescription = isInsightsFilterResultsPage ? filterResultsDescription : page.seoDescription;
const layoutCanonical = isInsightsFilterResultsPage ? filterResultsCanonical : page.canonicalUrl;
const layoutRobots = isInsightsFilterResultsPage
  ? 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'
  : page.robots;
const layoutOgImage = isInsightsFilterResultsPage ? filterResultsData?.hero.imageSrc : page.ogImage;
const bodyClass = isDataConnectPage
  ? 'dataconnect-page'
  : isInsightsFilterResultsPage
    ? 'insights-filter-results-page page--dark-hero'
    : 'legacy-page';
---

<BaseLayout
  title={layoutTitle}
  description={layoutDescription}
  canonical={layoutCanonical}
  ogTitle={isInsightsFilterResultsPage ? undefined : page.ogTitle}
  ogDescription={isInsightsFilterResultsPage ? undefined : page.ogDescription}
  ogImage={layoutOgImage}
  ogType={isInsightsFilterResultsPage ? 'article' : undefined}
  robots={layoutRobots}
  twitterCard={page.twitterCard}
  twitterTitle={page.twitterTitle}
  twitterDescription={page.twitterDescription}
  twitterImage={page.twitterImage}
  schema={filterResultsData?.schema}
  schemaJson={page.schemaJson}
  bodyClass={bodyClass}
>
  {isDataConnectPage ? (
    <FormLanding
      variant="dataconnect"
      title={page.hero.heading}
      lead={page.hero.eyebrow}
      intro={page.hero.subheading || ''}
      formId={page.form?.hubspotFormId || ''}
      summary={richText(page.body)}
      summaryHtml={richHtml(page.body)}
      loadFormScript={true}
      showFormCard={false}
    />
  ) : isInsightsFilterResultsPage && filterResultsData ? (
    <LegacyInsightsFilterResults
      hero={filterResultsData.hero}
      latestPosts={filterResultsData.latestPosts}
      filterCards={filterResultsData.filterCards}
    />
  ) : (
    <LegacyPageRenderer page={page} />
  )}
</BaseLayout>

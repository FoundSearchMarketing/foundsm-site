---
import BaseLayout from '../layouts/BaseLayout.astro';
import FormLanding from '../components/modern/FormLanding.astro';
import LegacyPageRenderer from '../components/legacy/LegacyPageRenderer.astro';
import LegacyInsightsFilterResults from '../components/LegacyInsightsFilterResults.astro';
import { getLatestBlogPosts } from '../lib/blogPosts';
import { loadLegacyPages } from '../lib/legacyPageFetch';
import { getLegacyPageDefinitionsByGroup, pathToSingleSlug, type LegacyPageData } from '../lib/legacyPageData';
import { richHtml, richText, srcFor } from '../lib/fixedPageRender';

export async function getStaticPaths() {
  const rootDefinitions = getLegacyPageDefinitionsByGroup('root');
  const pages = await loadLegacyPages(rootDefinitions);

  return rootDefinitions.map((definition) => ({
    params: { slug: pathToSingleSlug(definition.path) },
    props: { page: pages.get(definition.path) },
  }));
}

interface Props {
  page: LegacyPageData;
}

const { page } = Astro.props;
const isDataConnectPage = page.path === '/dataconnect/';
const isInsightsFilterResultsPage = page.path === '/insights-filter-results/';

let filterResultsData:
  | {
      hero: {
        headline?: string;
        body?: string;
        imageSrc?: string;
        imageAlt?: string;
      };
      latestPosts: {
        excerpt: string;
        href: string;
        imageSrc?: string;
        imageAlt?: string;
        tag?: string;
      }[];
      filterCards: {
        excerpt: string;
        href: string;
      }[];
      latestHeading?: string;
      directoryHeading?: string;
      filterLabel?: string;
      schema: object;
    }
  | undefined;

if (isInsightsFilterResultsPage) {
  const latestBlogPosts = await getLatestBlogPosts(2);
  const headline = page.hero.heading;
  const body = page.hero.subheading || page.seoDescription;
  const heroImage = srcFor(page.hero.image);
  const fallbackCards: NonNullable<LegacyPageData['cards']> = page.body.length
    ? [{ title: page.title, body: page.body, cta: { href: page.path } }]
    : [];
  const filterCards = (page.cards?.length ? page.cards : fallbackCards).map((card) => ({
    excerpt: richText(card.body) || card.title,
    href: card.cta?.href || page.path,
  }));

  filterResultsData = {
    hero: {
      headline,
      body,
      imageSrc: heroImage,
      imageAlt: page.hero.imageAlt || '',
    },
    latestPosts: latestBlogPosts.map((post) => ({
      excerpt: post.excerpt,
      href: `/insights/${post.slug}/`,
      imageSrc: post.heroImage,
      imageAlt: post.heroImageAlt,
      tag: 'Blog',
    })),
    filterCards,
    latestHeading: page.listing?.latestHeading,
    directoryHeading: page.listing?.heading || richText(page.listing?.body) || richText(page.body),
    filterLabel: page.listing?.filterLabel,
    schema: {
      '@context': 'https://schema.org',
      '@graph': [
        {
          '@type': 'WebPage',
          '@id': `${page.canonicalUrl}#webpage`,
          url: page.canonicalUrl,
          name: page.seoTitle,
          description: page.seoDescription,
          primaryImageOfPage: heroImage,
          publisher: {
            '@type': 'Organization',
            name: 'Found Search Marketing',
            url: 'https://www.foundsm.com/',
          },
        },
      ],
    },
  };
}

const layoutTitle = page.seoTitle;
const layoutDescription = page.seoDescription;
const layoutCanonical = page.canonicalUrl;
const layoutRobots = page.robots;
const layoutOgImage = isInsightsFilterResultsPage ? filterResultsData?.hero.imageSrc : page.ogImage;
const bodyClass = isDataConnectPage
  ? 'dataconnect-page'
  : isInsightsFilterResultsPage
    ? 'insights-filter-results-page page--dark-hero'
    : 'legacy-page';
---

<BaseLayout
  title={layoutTitle}
  description={layoutDescription}
  canonical={layoutCanonical}
  ogImage={layoutOgImage}
  ogType={isInsightsFilterResultsPage ? 'article' : undefined}
  robots={layoutRobots}
  schema={filterResultsData?.schema}
  bodyClass={bodyClass}
>
  {isDataConnectPage ? (
    <FormLanding
      variant="dataconnect"
      title={page.hero.heading}
      lead={page.hero.eyebrow}
      intro={page.hero.subheading || ''}
      formId={page.form?.hubspotFormId || ''}
      summary={richText(page.body)}
      summaryHtml={richHtml(page.body)}
      loadFormScript={true}
      showFormCard={false}
    />
  ) : isInsightsFilterResultsPage && filterResultsData ? (
    <LegacyInsightsFilterResults
      hero={filterResultsData.hero}
      latestPosts={filterResultsData.latestPosts}
      filterCards={filterResultsData.filterCards}
      latestHeading={filterResultsData.latestHeading}
      directoryHeading={filterResultsData.directoryHeading}
      filterLabel={filterResultsData.filterLabel}
    />
  ) : (
    <LegacyPageRenderer page={page} />
  )}
</BaseLayout>

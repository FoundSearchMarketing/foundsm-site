---
import BaseLayout from '../layouts/BaseLayout.astro';
import { aboutPageQuery, sanityClient } from '../lib/sanity';
import { defaultAboutPageData, mergeAboutPageData } from '../lib/fixedPageData';
import { richHtml, srcFor } from '../lib/fixedPageRender';

const sanityPage = await sanityClient.fetch(aboutPageQuery).catch(() => null);
const page = mergeAboutPageData(sanityPage);
const pageTitle = page.seoTitle || defaultAboutPageData.seoTitle;
const pageDescription = page.seoDescription || defaultAboutPageData.seoDescription;
const canonical = page.canonicalUrl || defaultAboutPageData.canonicalUrl;
const credentials = page.who.credentials.map((credential) => ({
  ...credential,
  imageSrc: srcFor(credential.image),
}));
const missionCards = page.mission.cards.map((card) => ({
  ...card,
  iconSrc: srcFor(card.icon),
}));
const values = page.values.tabs.map((value) => ({
  ...value,
  iconSrc: srcFor(value.icon),
  imageSrc: srcFor(value.image),
}));
const heroImage = srcFor(page.hero.image);
const whoImage = srcFor(page.who.image);
const approachImage = srcFor(page.approach.image);
const teamImage = srcFor(page.team.image);
const missionHeadingLines = page.mission.headingLines.length > 0 ? page.mission.headingLines : defaultAboutPageData.mission.headingLines;
const aboutRichHtml = (blocks: Parameters<typeof richHtml>[0]) => richHtml(blocks).replace(/ - /g, '—');

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      name: 'Found Search Marketing',
      url: 'https://foundsm.com',
      logo: 'https://foundsm.com/images/logo.svg',
      foundingDate: '2006',
      description: pageDescription,
      address: {
        '@type': 'PostalAddress',
        streetAddress: '8475 Nightfall Lane, Suite 200',
        addressLocality: 'Fishers',
        addressRegion: 'IN',
        postalCode: '46037',
        addressCountry: 'US',
      },
      contactPoint: {
        '@type': 'ContactPoint',
        telephone: '+1-317-721-2229',
        contactType: 'sales',
        email: 'info@foundsm.com',
      },
      sameAs: [
        'https://www.facebook.com/foundsm/',
        'https://www.instagram.com/found_sm/',
        'https://www.linkedin.com/company/found-search-marketing/',
        'https://x.com/FoundSM',
      ],
    },
    {
      '@type': 'AboutPage',
      name: pageTitle,
      url: canonical,
      description: pageDescription,
      publisher: {
        '@type': 'Organization',
        name: 'Found Search Marketing',
      },
    },
  ],
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonical}
  robots={page.robots}
  schema={schema}
  bodyClass="about-page-modern"
>
  <article class="about-modern">
    <section class="about-hero" aria-labelledby="about-hero-heading">
      <div class:list={['about-shell about-hero__grid', { 'about-hero__grid--text-only': !heroImage }]}>
        <div class="about-hero__copy fade-in-up">
          <h1 id="about-hero-heading">{page.hero.heading}</h1>
          <div class="about-hero__text" set:html={aboutRichHtml(page.hero.body)} />
        </div>

        {heroImage && (
          <div class="about-hero__media fade-in-up" aria-hidden={page.hero.imageAlt ? undefined : 'true'}>
            <img
              src={heroImage}
              sizes="(min-width: 1024px) 42vw, 100vw"
              alt={page.hero.imageAlt || ''}
              width="682"
              height="660"
              loading="eager"
              fetchpriority="high"
            />
          </div>
        )}
      </div>
    </section>

    <section class="about-who" aria-labelledby="about-who-heading">
      <div class="about-shell about-who__intro fade-in-up">
        {page.who.eyebrow && <p class="about-eyebrow">{page.who.eyebrow}</p>}
        <h2 id="about-who-heading">{page.who.heading}</h2>
      </div>

      <div class:list={['about-shell about-who__grid', { 'about-who__grid--text-only': !whoImage }]}>
        <div class="about-who__copy fade-in-up">
          <div set:html={aboutRichHtml(page.who.body)} />

          {page.who.subheading && <h3>{page.who.subheading}</h3>}
          <div class="credential-grid">
            {credentials.map((credential) => (
              <article class="credential-card">
                <div class="credential-card__media">
                  {credential.imageSrc && (
                    <img
                      src={credential.imageSrc}
                      sizes="(max-width: 767px) 5rem, 6rem"
                      alt={credential.alt || ''}
                      loading="lazy"
                    />
                  )}
                </div>
                <p>{credential.text}</p>
              </article>
            ))}
          </div>
        </div>

        {whoImage && (
          <div class="about-who__media fade-in-up">
            <img
              src={whoImage}
              sizes="(min-width: 1024px) 34vw, 82vw"
              alt={page.who.imageAlt || ''}
              width="652"
              height="1266"
              loading="lazy"
            />
          </div>
        )}
      </div>
    </section>

    <section class="about-mission" aria-labelledby="about-mission-heading">
      <div class="about-shell">
        <div class="about-section-heading about-section-heading--center fade-in-up">
          {page.mission.eyebrow && <p class="about-eyebrow">{page.mission.eyebrow}</p>}
          <h2 id="about-mission-heading">
            {missionHeadingLines.map((line, index) => (
              <Fragment>
                {index > 0 && <br />}
                {line}
              </Fragment>
            ))}
          </h2>
        </div>

        <div class="mission-grid">
          {missionCards.map((card) => (
            <article class="mission-card fade-in-up">
              {card.iconSrc && <img src={card.iconSrc} alt="" width="50" height="50" loading="lazy" />}
              <h3>{card.title}</h3>
              <div set:html={aboutRichHtml(card.body)} />
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="about-values" aria-labelledby="about-values-heading" data-about-values-tabs>
      <div class="about-shell">
        <div class="values-tabs">
          <div class="values-tabs__nav fade-in-up">
            <h2 id="about-values-heading">{page.values.heading}</h2>
            <div class="values-tabs__tablist" role="tablist" aria-label="Found Search Marketing values">
              {values.map((value, index) => (
                <button
                  class:list={['values-tabs__tab', { 'is-active': index === 0 }]}
                  type="button"
                  id={`about-values-tab-${value.id}`}
                  role="tab"
                  aria-selected={index === 0 ? 'true' : 'false'}
                  aria-controls={`about-values-panel-${value.id}`}
                  tabindex={index === 0 ? undefined : '-1'}
                >
                  <span class="values-tabs__tab-bar" aria-hidden="true"></span>
                  <span class="values-tabs__tab-icon" aria-hidden="true">
                    {value.iconSrc && <img src={value.iconSrc} alt="" width="50" height="50" loading="lazy" />}
                  </span>
                  <span>{value.title}</span>
                </button>
              ))}
            </div>
          </div>

          <div class="values-tabs__panels fade-in-up">
            {values.map((value, index) => (
              <div
                class:list={['values-tabs__panel', { 'is-active': index === 0 }]}
                id={`about-values-panel-${value.id}`}
                role="tabpanel"
                aria-labelledby={`about-values-tab-${value.id}`}
                hidden={index !== 0}
              >
                <div class="values-tabs__panel-copy">
                  <h3>{value.title}</h3>
                  <div set:html={aboutRichHtml(value.body)} />
                  <a class="about-link" href="/contact-us/">Let's Talk</a>
                </div>
                {value.imageSrc && (
                  <div class="values-tabs__panel-media">
                    <img
                      src={value.imageSrc}
                      alt={value.imageAlt || value.title || ''}
                      width="368"
                      height="474"
                      loading={index === 0 ? 'eager' : 'lazy'}
                    />
                  </div>
                )}
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="about-approach" aria-labelledby="about-approach-heading">
      <div class:list={['about-shell about-split', { 'about-split--text-only': !approachImage }]}>
        {approachImage && (
          <div class="about-split__media fade-in-up">
            <img
              src={approachImage}
              sizes="(min-width: 900px) 38vw, 90vw"
              alt={page.approach.imageAlt || ''}
              width="604"
              height="604"
              loading="lazy"
            />
          </div>
        )}
        <div class="about-split__copy fade-in-up">
          <h2 id="about-approach-heading">{page.approach.heading}</h2>
          <div set:html={aboutRichHtml(page.approach.body)} />
          {page.approach.cta?.label && page.approach.cta?.href && (
            <a class="about-button" href={page.approach.cta.href}>{page.approach.cta.label}</a>
          )}
        </div>
      </div>
    </section>

    <section class="about-team" aria-labelledby="about-team-heading">
      <div class="about-shell">
        <h2 id="about-team-heading" class="fade-in-up">{page.team.heading}</h2>
        {teamImage && (
          <div class="about-team__image fade-in-up">
            <img
              src={teamImage}
              sizes="(min-width: 1200px) 86rem, 94vw"
              alt={page.team.imageAlt || ''}
              width="1399"
              height="699"
              loading="lazy"
            />
          </div>
        )}
      </div>
    </section>

    <section class="about-team-cta" aria-label="About the Found team">
      <div class="about-shell about-team-cta__grid fade-in-up">
        <div class="about-team-cta__copy" set:html={aboutRichHtml(page.teamCta.body)} />
        {page.teamCta.cta?.label && page.teamCta.cta?.href && (
          <a class="about-button about-button--dark" href={page.teamCta.cta.href}>{page.teamCta.cta.label}</a>
        )}
      </div>
    </section>
  </article>

  <script>
    document.querySelectorAll('[data-about-values-tabs]').forEach((root) => {
      const tabs = Array.from(root.querySelectorAll('[role="tab"]'));
      const panels = Array.from(root.querySelectorAll('[role="tabpanel"]'));

      const activateTab = (tab) => {
        const panelId = tab.getAttribute('aria-controls');

        tabs.forEach((item) => {
          const selected = item === tab;
          item.classList.toggle('is-active', selected);
          item.setAttribute('aria-selected', selected ? 'true' : 'false');
          item.tabIndex = selected ? 0 : -1;
        });

        panels.forEach((panel) => {
          const selected = panel.id === panelId;
          panel.classList.toggle('is-active', selected);
          panel.hidden = !selected;
        });
      };

      tabs.forEach((tab, index) => {
        tab.addEventListener('click', () => activateTab(tab));
        tab.addEventListener('keydown', (event) => {
          if (!['ArrowLeft', 'ArrowRight', 'Home', 'End'].includes(event.key)) {
            return;
          }

          event.preventDefault();
          let nextIndex = index;
          if (event.key === 'ArrowRight') nextIndex = (index + 1) % tabs.length;
          if (event.key === 'ArrowLeft') nextIndex = (index - 1 + tabs.length) % tabs.length;
          if (event.key === 'Home') nextIndex = 0;
          if (event.key === 'End') nextIndex = tabs.length - 1;

          const nextTab = tabs[nextIndex];
          activateTab(nextTab);
          nextTab.focus();
        });
      });
    });
  </script>

  <style>
    .about-modern {
      --about-green: #8bc53f;
      --about-green-dark: #76a834;
      --about-ink: #231f20;
      --about-muted: #5f625c;
      --about-surface: #f2f3f2;
      --about-surface-strong: #e7ebdf;
      --about-border: rgba(26, 26, 26, 0.12);
      --about-shadow: 0 1.5rem 3.5rem rgba(26, 26, 26, 0.12);
      background: #ffffff;
      color: var(--about-ink);
      overflow-x: hidden;
    }

    .about-modern h1,
    .about-modern h2,
    .about-modern h3,
    .about-modern p {
      letter-spacing: 0;
    }

    .about-modern h1,
    .about-modern h2 {
      font-family: var(--font-heading);
      line-height: 1.08;
      color: var(--about-ink);
    }

    .about-modern h1 {
      font-size: 2.375rem;
      font-weight: 900;
      line-height: 1.105;
    }

    .about-modern h2 {
      font-size: 2.125rem;
      font-weight: 900;
      line-height: 1.15;
    }

    .about-modern h3 {
      font-family: var(--font-body);
      font-size: 1.25rem;
      line-height: 1.3;
      font-weight: 700;
      color: var(--about-ink);
    }

    .about-modern p {
      margin: 0;
      color: var(--about-ink);
      font-size: 1.125rem;
      line-height: 1.667;
    }

    .about-modern p + p {
      margin-top: 1rem;
    }

    .about-shell {
      inline-size: min(calc(100% - (2 * var(--page-gutter))), var(--content-max-width));
      margin-inline: auto;
    }

    .about-modern .about-eyebrow {
      margin: 0 0 0.75rem;
      color: var(--about-ink);
      font-size: 1.125rem;
      font-weight: 300;
      line-height: 1.22;
      text-transform: uppercase;
    }

    .about-button,
    .about-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 3.75rem;
      border-radius: 999px;
      font-size: 1.25rem;
      font-weight: 500;
      line-height: 1.2;
      text-align: center;
      transition: background-color var(--duration) var(--ease), color var(--duration) var(--ease), border-color var(--duration) var(--ease), transform var(--duration) var(--ease);
    }

    .about-button {
      justify-self: start;
      padding: 0.95rem 2rem;
      background: var(--about-ink);
      color: #ffffff;
    }

    .about-button:hover,
    .about-button:focus-visible {
      background: #414042;
      color: #ffffff;
      transform: translateY(-1px);
    }

    .about-button--dark {
      background: var(--about-ink);
      color: #ffffff;
    }

    .about-button--dark:hover,
    .about-button--dark:focus-visible {
      background: #414042;
    }

    .about-link {
      justify-self: start;
      padding: 0.95rem 2.9rem;
      background: var(--about-green);
      color: var(--about-ink);
    }

    .about-link:hover,
    .about-link:focus-visible {
      background: var(--about-green-dark);
      color: var(--about-ink);
    }

    .about-hero {
      display: grid;
      align-items: center;
      padding: 6.25rem 0 3.75rem;
      background: #ffffff;
    }

    .about-hero__grid {
      display: grid;
      gap: 2.5rem;
      align-items: start;
    }

    .about-hero__copy {
      max-width: 43rem;
    }

    .about-hero__text {
      margin-top: 1.35rem;
      max-width: 39rem;
    }

    .about-hero__media {
      display: none;
    }

    .about-hero__media img {
      width: min(37.7vw, 42.625rem);
      aspect-ratio: 682 / 660;
      object-fit: cover;
      border-radius: 2.5rem;
    }

    .about-who {
      position: relative;
      margin-top: 3.125rem;
      margin-bottom: 12.5rem;
      padding: 5rem 0 5.5rem;
      background-color: var(--about-surface);
      background-image: url("/images/pages/our-approach/topography-light.svg");
      background-size: cover;
      overflow: visible;
    }

    .about-who::before {
      position: absolute;
      inset: 0;
      content: "";
      background: linear-gradient(90deg, rgba(244, 246, 240, 0.96), rgba(244, 246, 240, 0.82));
      pointer-events: none;
    }

    .about-who > * {
      position: relative;
    }

    .about-who__intro {
      margin-bottom: 2.625rem;
      text-align: center;
    }

    .about-who__grid {
      display: grid;
      gap: 3.125rem;
      align-items: start;
    }

    .about-who__copy {
      max-width: 52rem;
    }

    .about-who__copy h3 {
      margin-top: 1.4rem;
      text-transform: none;
    }

    .credential-grid {
      display: grid;
      gap: 2.6rem 3rem;
      margin-top: 1.4rem;
    }

    .credential-card {
      display: grid;
      grid-template-columns: 8.375rem minmax(0, 1fr);
      gap: 1.5625rem;
      align-items: center;
      min-height: 8.375rem;
      padding: 0;
    }

    .credential-card__media {
      display: grid;
      place-items: center;
      width: 8.375rem;
      height: 8.375rem;
    }

    .credential-card img {
      max-width: 100%;
      max-height: 100%;
      object-fit: contain;
    }

    .credential-card p {
      color: var(--about-ink);
      font-size: 1rem;
      line-height: 1.875;
      font-weight: 400;
    }

    .about-who__media {
      justify-self: center;
      max-width: 26rem;
      margin-bottom: -16.125rem;
    }

    .about-who__media img {
      width: 100%;
      aspect-ratio: 652 / 1266;
      object-fit: cover;
      border-radius: 2.5rem;
      box-shadow: var(--about-shadow);
    }

    .about-mission {
      padding: 0 0 2.5rem;
      background: #ffffff;
    }

    .about-section-heading {
      margin-bottom: 5.5rem;
    }

    .about-section-heading--center {
      text-align: center;
    }

    .mission-grid {
      display: grid;
      gap: 3.125rem;
    }

    .mission-card {
      display: grid;
      align-content: start;
      gap: 1rem;
      min-height: 0;
      padding: 0;
      border: 0;
      border-radius: 0;
      background: transparent;
    }

    .mission-card img {
      width: 3.125rem;
      height: 3.125rem;
      object-fit: contain;
      margin-bottom: 0.4rem;
    }

    .mission-card p {
      color: var(--about-ink);
      font-size: 1rem;
      line-height: 1.875;
    }

    .about-values {
      padding: 0;
      background: #ffffff;
      color: var(--about-ink);
    }

    .values-tabs {
      position: relative;
      display: grid;
      gap: 2rem;
      min-height: 45.3125rem;
      padding: 2.1875rem 1.5625rem;
      border-radius: 2.5rem;
      background: var(--about-ink);
      color: #ffffff;
      overflow: hidden;
    }

    .values-tabs::before {
      position: absolute;
      inset: 0;
      content: "";
      background-image: url("/images/pages/our-approach/topography-light.svg");
      background-size: 34rem;
      opacity: 0.08;
      pointer-events: none;
    }

    .values-tabs > * {
      position: relative;
    }

    .values-tabs__nav {
      display: grid;
      align-content: start;
      gap: 1.2rem;
      padding: 0;
    }

    .values-tabs__nav h2 {
      color: #ffffff;
      font-family: var(--font-body);
      font-size: 1.25rem;
      font-weight: 700;
      line-height: 1.3;
    }

    .values-tabs__tablist {
      display: grid;
      gap: 1.25rem;
    }

    .values-tabs__tab {
      position: relative;
      display: grid;
      grid-template-columns: 0.375rem 3.125rem minmax(0, 1fr);
      align-items: center;
      gap: 1.25rem;
      width: 100%;
      min-height: 4.6875rem;
      padding: 0 1.25rem 0 0;
      color: rgba(255, 255, 255, 0.72);
      text-align: left;
      transition: color var(--duration) var(--ease);
    }

    .values-tabs__tab:hover,
    .values-tabs__tab:focus-visible,
    .values-tabs__tab.is-active {
      color: #ffffff;
    }

    .values-tabs__tab-bar {
      display: block;
      width: 0.375rem;
      height: 100%;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.18);
    }

    .values-tabs__tab.is-active .values-tabs__tab-bar {
      background: var(--about-green);
    }

    .values-tabs__tab-icon {
      display: grid;
      place-items: center;
      width: 3.125rem;
      height: 3.125rem;
    }

    .values-tabs__tab-icon img {
      width: 3.125rem;
      height: 3.125rem;
      object-fit: contain;
      opacity: 0.18;
      transition: opacity var(--duration) var(--ease);
    }

    .values-tabs__tab:hover .values-tabs__tab-icon img,
    .values-tabs__tab:focus-visible .values-tabs__tab-icon img,
    .values-tabs__tab.is-active .values-tabs__tab-icon img {
      opacity: 1;
    }

    .values-tabs__tab span:last-child {
      font-size: 1.125rem;
      font-weight: 700;
      line-height: 1.333;
    }

    .values-tabs__panels {
      min-width: 0;
    }

    .values-tabs__panel {
      display: grid;
      gap: 1.5rem;
      height: 100%;
      min-height: 33rem;
      padding: 0;
    }

    .values-tabs__panel[hidden] {
      display: none;
    }

    .values-tabs__panel-copy {
      display: grid;
      align-content: center;
      gap: 1rem;
      justify-items: start;
    }

    .values-tabs__panel h3 {
      color: #ffffff;
      font-family: var(--font-body);
      font-size: 2.125rem;
      font-weight: 700;
      line-height: 1.235;
    }

    .values-tabs__panel p {
      max-width: 34rem;
      color: #ffffff;
      font-size: 1.125rem;
      line-height: 1.667;
    }

    .values-tabs__panel-media {
      align-self: end;
      overflow: hidden;
      border-radius: 2.5rem;
      background: rgba(255, 255, 255, 0.07);
    }

    .values-tabs__panel-media img {
      width: 100%;
      height: 100%;
      max-height: 28rem;
      aspect-ratio: 368 / 474;
      object-fit: cover;
    }

    .about-approach {
      margin-top: 5rem;
      padding: 6.25rem 0;
      background: #ffffff;
    }

    .about-split {
      display: grid;
      gap: 3.125rem;
      align-items: center;
    }

    .about-split__media {
      overflow: hidden;
      border-radius: 2.5rem;
      background: var(--about-surface);
    }

    .about-split__media img {
      width: 100%;
      aspect-ratio: 1;
      object-fit: cover;
    }

    .about-split__copy {
      display: grid;
      gap: 1.15rem;
      max-width: 38rem;
    }

    .about-team {
      padding: 0 0 0.625rem;
      background: #ffffff;
      text-align: center;
    }

    .about-team__image {
      margin-top: 2rem;
      overflow: hidden;
      border-radius: 2.5rem;
      box-shadow: var(--about-shadow);
    }

    .about-team__image img {
      width: 100%;
      aspect-ratio: 1399 / 699;
      object-fit: cover;
    }

    .about-team-cta {
      margin-bottom: 3.125rem;
      padding: 0.625rem 0 8.5rem;
      background: #ffffff;
    }

    .about-team-cta__grid {
      display: grid;
      gap: 1.5rem;
      align-items: center;
      padding: 0;
      border-radius: 0;
      background: transparent;
      box-shadow: none;
    }

    .about-team-cta__copy {
      max-width: 54rem;

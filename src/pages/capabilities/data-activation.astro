---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DataActivationPage from '../../components/DataActivationPage.astro';
import { capabilityDetailPageQuery, sanityClient } from '../../lib/sanity';
import { defaultCapabilityDetailPages, mergeCapabilityDetailPageData } from '../../lib/fixedPageData';

const sanityPage = await sanityClient.fetch(capabilityDetailPageQuery, { id: 'capabilityDataActivationPage' }).catch(() => null);
const page = mergeCapabilityDetailPageData(defaultCapabilityDetailPages.dataActivation, sanityPage);
const title = page.seoTitle || defaultCapabilityDetailPages.dataActivation.seoTitle;
const description = page.seoDescription || defaultCapabilityDetailPages.dataActivation.seoDescription;
const canonical = page.canonicalUrl || defaultCapabilityDetailPages.dataActivation.canonicalUrl;
const schema = {
  '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: title,
  url: canonical,
  description,
  publisher: {
    '@type': 'Organization',
    name: 'Found Search Marketing',
  },
};

---

<BaseLayout title={title} description={description} canonical={canonical} robots={page.robots} schema={schema}>
  <DataActivationPage page={page} />
</BaseLayout>

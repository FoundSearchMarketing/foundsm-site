---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Data Intelligence | Found Search Marketing";
const description = "Found Search Marketing's Data Intelligence services include marketing mix modeling, predictive analytics, custom dashboards, competitive intelligence, and incrementality testing.";
const canonical = "https://www.foundsm.com/capabilities/data-intelligence";
const robots = "index, follow";
const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Data Intelligence | Found Search Marketing",
  "url": "https://www.foundsm.com/capabilities/data-intelligence",
  "description": "Found Search Marketing's Data Intelligence services include marketing mix modeling, predictive analytics, custom dashboards, competitive intelligence, and incrementality testing.",
  "publisher": {
    "@type": "Organization",
    "name": "Found Search Marketing"
  }
};
---

<BaseLayout title={title} description={description} canonical={canonical} robots={robots} schema={schema}>

    <!-- ============================================
         HERO SECTION
         ============================================ -->
    <section class="hero hero--dark" aria-label="Data Intelligence hero">
      <div class="hero__overlay" aria-hidden="true"></div>
      <div class="hero__bg-image" aria-hidden="true">
        <img src="/images/data-intelligence-hero-bg.jpg" alt="" loading="lazy" width="1920" height="900">
      </div>

      <div class="container hero__content">
        <div class="hero-stagger">
          <p class="hero__breadcrumb"><a href="/capabilities">Capabilities</a> / Data Intelligence</p>
        </div>
        <div class="hero-stagger">
          <h1 class="hero__headline">Data Intelligence</h1>
        </div>
        <div class="hero-stagger">
          <p class="hero__subtitle">Advanced analytics, modeling, and insights that empower smarter marketing decisions and prove the true impact of your media investments.</p>
        </div>
      </div>
    </section>


    <!-- ============================================
         FEATURE CARDS GRID
         ============================================ -->
    <section class="features-grid" aria-label="Data intelligence capabilities">
      <div class="container">
        <h2 class="features-grid__heading fade-in-up">Our Analytical Toolkit</h2>
        <p class="features-grid__subheading fade-in-up">Six core capabilities that transform raw data into strategic advantage.</p>

        <div class="features-grid__cards fade-in-up">

          <!-- Card 1: Marketing Mix Modeling -->
          <div class="feature-card">
            <div class="feature-card__icon" aria-hidden="true">
              <svg width="48" height="48" viewBox="0 0 48 48"><path d="M6 38L14 26L22 32L42 10" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/><circle cx="6" cy="38" r="3" fill="currentColor"/><circle cx="14" cy="26" r="3" fill="currentColor"/><circle cx="22" cy="32" r="3" fill="currentColor"/><circle cx="42" cy="10" r="3" fill="currentColor"/></svg>
            </div>
            <h3 class="feature-card__title">Marketing Mix Modeling</h3>
            <p class="feature-card__description">Quantify the impact of each media channel on your business outcomes. Our marketing mix models isolate the contribution of paid media, organic efforts, and external factors to optimize your budget allocation.</p>
          </div>

          <!-- Card 2: Predictive Analytics -->
          <div class="feature-card">
            <div class="feature-card__icon" aria-hidden="true">
              <svg width="48" height="48" viewBox="0 0 48 48"><rect x="6" y="6" width="36" height="36" rx="6" stroke="currentColor" stroke-width="2.5" fill="none"/><path d="M14 34V26M22 34V20M30 34V24M38 34V16" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/><path d="M14 18L22 14L30 16L38 10" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-dasharray="4 3"/></svg>
            </div>
            <h3 class="feature-card__title">Predictive Analytics</h3>
            <p class="feature-card__description">Forecast future performance with machine learning models trained on your historical data. Anticipate trends, identify opportunities, and allocate budget proactively rather than reactively.</p>
          </div>

          <!-- Card 3: Custom Dashboard Development -->
          <div class="feature-card">
            <div class="feature-card__icon" aria-hidden="true">
              <svg width="48" height="48" viewBox="0 0 48 48"><rect x="4" y="6" width="40" height="30" rx="4" stroke="currentColor" stroke-width="2.5" fill="none"/><path d="M4 14H44" stroke="currentColor" stroke-width="2"/><rect x="8" y="18" width="14" height="8" rx="2" stroke="currentColor" stroke-width="1.5" fill="none"/><rect x="26" y="18" width="14" height="14" rx="2" stroke="currentColor" stroke-width="1.5" fill="none"/><rect x="8" y="28" width="14" height="4" rx="1" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M20 42H28" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/><path d="M24 36V42" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
            </div>
            <h3 class="feature-card__title">Custom Dashboard Development</h3>
            <p class="feature-card__description">Real-time performance dashboards built on Google Cloud that surface the metrics that matter most to your business. Our dashboards provide full transparency and actionable insights for every stakeholder.</p>
          </div>

          <!-- Card 4: Competitive Intelligence -->
          <div class="feature-card">
            <div class="feature-card__icon" aria-hidden="true">
              <svg width="48" height="48" viewBox="0 0 48 48"><circle cx="24" cy="24" r="18" stroke="currentColor" stroke-width="2.5" fill="none"/><circle cx="24" cy="24" r="10" stroke="currentColor" stroke-width="2" fill="none"/><circle cx="24" cy="24" r="3" fill="currentColor"/><path d="M24 6V12M24 36V42M6 24H12M36 24H42" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            </div>
            <h3 class="feature-card__title">Competitive Intelligence</h3>
            <p class="feature-card__description">Monitor competitor ad strategies, spend patterns, and messaging to identify gaps and opportunities. Our competitive analysis keeps you one step ahead in your market.</p>
          </div>

          <!-- Card 5: Conversion Rate Analysis -->
          <div class="feature-card">
            <div class="feature-card__icon" aria-hidden="true">
              <svg width="48" height="48" viewBox="0 0 48 48"><path d="M10 38L18 24L26 30L38 12" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/><path d="M30 12H38V20" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M6 42H42" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            </div>
            <h3 class="feature-card__title">Conversion Rate Analysis</h3>
            <p class="feature-card__description">Deep-dive analysis of your conversion funnel to identify drop-off points, friction areas, and optimization opportunities. We use statistical rigor to ensure recommendations are data-backed and impactful.</p>
          </div>

          <!-- Card 6: Incrementality Testing -->
          <div class="feature-card">
            <div class="feature-card__icon" aria-hidden="true">
              <svg width="48" height="48" viewBox="0 0 48 48"><rect x="6" y="14" width="16" height="24" rx="3" stroke="currentColor" stroke-width="2.5" fill="none"/><rect x="26" y="8" width="16" height="30" rx="3" stroke="currentColor" stroke-width="2.5" fill="none"/><path d="M10 22H18M10 28H18M10 34H18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M30 16H38M30 22H38M30 28H38M30 34H38" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M34 10L34 14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            </div>
            <h3 class="feature-card__title">Incrementality Testing</h3>
            <p class="feature-card__description">Measure the true incremental value of your media spend through controlled experiments. Our geo-lift tests and holdout studies reveal what is truly driving growth versus what would have happened organically.</p>
          </div>

        </div>
      </div>
    </section>


    <!-- ============================================
         CTA BANNER
         ============================================ -->
    <section class="cta-banner" aria-label="Call to action">
      <div class="cta-banner__bg" aria-hidden="true"></div>
      <div class="container cta-banner__inner fade-in-up">
        <h2 class="cta-banner__headline">Unlock Smarter Insights</h2>
        <p class="cta-banner__text">Let our data intelligence team show you what your marketing data is really telling you.</p>
        <a href="/contact-us" class="btn btn--green btn--lg">Start the Conversation</a>
      </div>
    </section>

</BaseLayout>

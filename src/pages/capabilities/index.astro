---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Capabilities | Found Search Marketing | Enterprise Paid Media Agency';
const description = 'Found Search Marketing brings deep channel expertise, custom analytics, and agile strategy together to maximize performance across your entire media ecosystem.';
const canonical = 'https://www.foundsm.com/capabilities/';
const robots = 'index, follow';
const imageBase = 'https://foundsm.com/found2025/wp-content/uploads/2026/03';
const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  url: canonical,
  description,
  publisher: {
    '@type': 'Organization',
    name: 'Found Search Marketing',
    url: 'https://www.foundsm.com',
    logo: 'https://www.foundsm.com/images/logo.svg'
  }
};
---

<BaseLayout title={title} description={description} canonical={canonical} robots={robots} schema={schema}>
  <div class="capabilities-page">
    <section class="capabilities-hero" aria-labelledby="capabilities-hero-title">
      <div class="capabilities-hero__inner">
        <div class="capabilities-hero__copy">
          <h1 id="capabilities-hero-title" class="capabilities-hero__title">Smart Data. Smarter Media. Scalable Growth.</h1>
          <p class="capabilities-hero__text">
            Found Search Marketing is structured to be both strategic and agile, combining deep media channel expertise with expert talent and leading-edge tools.
          </p>
        </div>

        <div class="capabilities-hero__media" aria-hidden="true">
          <img
            class="capabilities-hero__image"
            src={`${imageBase}/capi-eye.webp`}
            srcset={`${imageBase}/capi-eye.webp 800w, ${imageBase}/capi-eye-300x300.webp 300w, ${imageBase}/capi-eye-150x150.webp 150w, ${imageBase}/capi-eye-768x768.webp 768w`}
            sizes="(min-width: 1024px) 40vw, 0px"
            width="800"
            height="800"
            alt=""
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        </div>
      </div>
    </section>

    <section class="outcomes-section" aria-labelledby="outcomes-title">
      <div class="outcomes-section__heading">
        <p class="outcomes-section__eyebrow">Our Capabilities</p>
        <h2 id="outcomes-title" class="outcomes-section__title">Outcomes that Outperform</h2>
      </div>

      <div class="outcomes-section__inner">
        <div class="outcomes-section__media" aria-hidden="true">
          <img
            class="outcomes-section__image"
            src={`${imageBase}/capibilities-mary-jake.webp`}
            srcset={`${imageBase}/capibilities-mary-jake.webp 524w, ${imageBase}/capibilities-mary-jake-217x300.webp 217w`}
            sizes="(min-width: 1024px) 36vw, 0px"
            width="524"
            height="725"
            alt=""
            loading="lazy"
            decoding="async"
          />
        </div>

        <div class="outcomes-section__copy">
          <p>
            We build smart, custom systems for performance marketing by combining first-party data with our proven approach. That starts with a custom playbook where we map solutions tied directly to business outcomes. This includes development of initial KPIs and is our foundation for planning. We also create different versions for launch, expansion, and efficiency&mdash;always taking into account factors like brand strength, demand, revenue, profitability, and opportunity cost.
          </p>
          <p>
            We handle every aspect of your performance lead generation ecosystem, making sure strategy and execution are always aligned.
          </p>
        </div>
      </div>
    </section>

    <section class="workflow-section" aria-labelledby="workflow-title">
      <div class="workflow-section__inner">
        <div class="workflow-section__copy">
          <h2 id="workflow-title" class="workflow-section__title">How We Work</h2>
          <p class="workflow-section__text">
            There are no silos here. Our Paid Media, Data Intelligence, and Performance Creative teams are deeply integrated with each other, creating a connected ecosystem designed to drive smarter decisions and stronger results. This collaboration extends far beyond our walls, as we aim to be a true extension of our clients&rsquo; teams, partnering across their functional teams, and integrating within existing systems and workflows to ensure alignment, agility, and shared success.
          </p>
          <p class="workflow-section__prompt">Explore Our Capabilities Below</p>
        </div>

        <div class="workflow-section__media">
          <img
            class="workflow-section__image"
            src="https://foundsm.com/found2025/wp-content/uploads/elementor/thumbs/Found-PerformanceMediaEcosystem-rfuzrtzgm07e7n81lnl4kp2jjacqnhumsg3oipclfs-copy-rkgq79yuxxktqtdg3t6nzctjrywzquvq6th88gkex4.webp"
            width="500"
            height="500"
            alt="Found Performance Media Ecosystem"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </section>

    <section class="capability-detail capability-detail--data" id="capabilities-data-reporting-analytics" aria-labelledby="capability-data-title">
      <div class="capability-detail__inner">
        <div class="capability-detail__copy">
          <h2 id="capability-data-title" class="capability-detail__title">Data, Reporting &amp; Analytics</h2>
          <div class="capability-detail__text">
            <p>Do you have multiple data sources to connect? Or multiple CRMs? No problem.</p>
            <p>
              For us, analytics and reporting go beyond tracking paid media, and everything we build is uniquely customized to your business goals, data, and workflows. No templates or generic dashboards. From attribution models to automated scripts, we help your team understand what&rsquo;s happening, why, and what to do next.
            </p>
          </div>
          <a class="capability-detail__button capability-detail__button--blue" href="/capabilities/data-intelligence/">Connect Data to Outcomes</a>
        </div>

        <div class="capability-detail__media" aria-hidden="true">
          <img
            class="capability-detail__image"
            src={`${imageBase}/capi-cactus.webp`}
            srcset={`${imageBase}/capi-cactus.webp 1024w, ${imageBase}/capi-cactus-300x288.webp 300w, ${imageBase}/capi-cactus-768x737.webp 768w`}
            sizes="(min-width: 1024px) 44vw, 0px"
            width="1024"
            height="983"
            alt=""
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </section>

    <section class="capability-detail capability-detail--paid" id="capabilities-paid-media" aria-labelledby="capability-paid-title">
      <div class="capability-detail__inner capability-detail__inner--reverse">
        <div class="capability-detail__media" aria-hidden="true">
          <img
            class="capability-detail__image"
            src={`${imageBase}/capi-typing.webp`}
            srcset={`${imageBase}/capi-typing.webp 753w, ${imageBase}/capi-typing-294x300.webp 294w`}
            sizes="(min-width: 1024px) 36vw, 0px"
            width="753"
            height="768"
            alt=""
            loading="lazy"
            decoding="async"
          />
        </div>

        <div class="capability-detail__copy">
          <h2 id="capability-paid-title" class="capability-detail__title">Paid Media</h2>
          <div class="capability-detail__text">
            <p>
              We don&rsquo;t just manage campaigns. We engineer ecosystems.<br />
              Our team brings 20+ years of performance experience and a clear view on how to structure, optimize, and scale lead gen across platforms, all while finding new channels for experimentation and growth. Whether you need to diversify your portfolio or double down on what&rsquo;s working, we&rsquo;ll help you reduce risk, maximize efficiency, and push performance further.
            </p>
          </div>
          <a class="capability-detail__button capability-detail__button--green" href="/capabilities/paid-media/">Let&rsquo;s Scale Smarter</a>
        </div>
      </div>
    </section>

    <section class="capability-detail capability-detail--creative" id="capabilities-performance-creative" aria-labelledby="capability-creative-title">
      <div class="capability-detail__inner">
        <div class="capability-detail__copy">
          <h2 id="capability-creative-title" class="capability-detail__title">Performance Creative &amp; CRO</h2>
          <div class="capability-detail__text">
            <p>
              Performance creative bridges the gap between storytelling and sales. We design motion graphics, ad creative, and landing pages that don&rsquo;t just look good&mdash;they drive traffic and conversions. Everything we do is tested and built with intention: messaging tailored to your audience, strategic rapid experimentation, visuals designed specifically for the platform, and performance that keeps improving.
            </p>
          </div>
          <a class="capability-detail__button capability-detail__button--orange" href="/capabilities/performance-creative/">Creative Ads That Convert</a>
        </div>

        <div class="capability-detail__media" aria-hidden="true">
          <img
            class="capability-detail__image"
            src={`${imageBase}/capi-uiux.webp`}
            srcset={`${imageBase}/capi-uiux.webp 753w, ${imageBase}/capi-uiux-294x300.webp 294w`}
            sizes="(min-width: 1024px) 36vw, 0px"
            width="753"
            height="768"
            alt=""
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .capabilities-page {
    --capabilities-dark: #231f20;
    --capabilities-muted: #414042;
    --capabilities-light: #f2f3f2;
    --capabilities-green: #8dc63f;
    --capabilities-blue: #0aadef;
    --capabilities-orange: #fa9828;
    --capabilities-red: #f05660;
    color: var(--capabilities-dark);
    background: #ffffff;
    font-family: var(--font-body);
    overflow: hidden;
  }

  .capabilities-hero {
    padding: 3.75rem 0 5.625rem;
    background: #ffffff;
  }

  .capabilities-hero__inner,
  .outcomes-section__inner,
  .workflow-section__inner,
  .capability-detail__inner {
    inline-size: min(calc(100% - (2 * var(--page-gutter))), var(--content-max-width));
    margin-inline: auto;
  }

  .capabilities-hero__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(24rem, 40%);
    align-items: center;
    gap: 7.5rem;
  }

  .capabilities-hero__title,
  .workflow-section__title {
    margin: 0 0 1.25rem;
    color: var(--capabilities-dark);
    font-family: var(--font-heading);
    font-weight: 900;
    line-height: 1.083;
    letter-spacing: 0;
  }

  .capabilities-hero__title {
    font-size: 3.75rem;
  }

  .workflow-section__title {
    font-size: 3.75rem;
  }

  .capabilities-hero__text,
  .outcomes-section__copy,
  .workflow-section__text,
  .capability-detail__text {
    color: var(--capabilities-dark);
    font-size: 1.25rem;
    font-weight: 400;
    line-height: 1.8;
  }

  .capabilities-hero__text {
    max-width: 43rem;
  }

  .capabilities-hero__media {
    overflow: hidden;
    border-radius: 2.5rem;
  }

  .capabilities-hero__image {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
  }

  .outcomes-section {
    position: relative;
    margin-top: 1.25rem;
    margin-bottom: 12.5rem;
    padding: 5rem 0 7.5rem;
    background: var(--capabilities-light);
  }

  .outcomes-section::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: url("https://foundsm.com/found2025/wp-content/uploads/2026/03/topography-light_sm.svg");
    background-position: center top;
    background-size: 130rem auto;
    opacity: 0.75;
    pointer-events: none;
  }

  .outcomes-section__heading,
  .outcomes-section__inner {
    position: relative;
    z-index: 1;
  }

  .outcomes-section__heading {
    inline-size: min(calc(100% - (2 * var(--page-gutter))), var(--content-max-width));
    margin: 0 auto 3.75rem;
    text-align: center;
  }

  .outcomes-section__eyebrow {
    margin: 0 0 0.25rem;
    color: var(--capabilities-dark);
    font-size: 1.25rem;
    font-weight: 300;
    line-height: 1.4;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .outcomes-section__title {
    margin: 0;
    color: var(--capabilities-dark);
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: 0;
  }

  .outcomes-section__inner {
    display: grid;
    grid-template-columns: minmax(20rem, 37%) minmax(0, 1fr);
    align-items: start;
    gap: 5.625rem;
  }

  .outcomes-section__image {
    width: 100%;
    max-width: 32.75rem;
  }

  .outcomes-section__copy {
    padding-top: 1.25rem;
  }

  .outcomes-section__copy p + p,
  .capability-detail__text p + p {
    margin-top: 1rem;
  }

  .workflow-section {
    min-height: 35.9375rem;
    background: linear-gradient(180deg, #ffffff 0%, var(--capabilities-light) 100%);
  }

  .workflow-section__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(20rem, 38%);
    align-items: center;
    gap: 3rem;
  }

  .workflow-section__copy {
    padding: 5rem 0;
  }

  .workflow-section__prompt {
    display: inline-block;
    margin: 1.875rem 0 0;
    padding: 0.3125rem 0.625rem;
    border-left: 0.25rem solid var(--capabilities-green);
    color: var(--capabilities-dark);
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.6;
  }

  .workflow-section__image {
    width: min(100%, 31.25rem);
    margin-inline: auto 0;
  }

  .capability-detail {
    background: #ffffff;
  }

  .capability-detail--data {
    margin-top: 3.125rem;
  }

  .capability-detail__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(20rem, 1fr);
    align-items: center;
    gap: 3.125rem;
    min-height: 39rem;
    padding-block: 2rem;
  }

  .capability-detail__inner--reverse {
    grid-template-columns: minmax(20rem, 1fr) minmax(0, 1fr);
  }

  .capability-detail__title {
    margin: 0 0 0.9375rem;
    padding-bottom: 0.3125rem;
    border-bottom: 0.3125rem solid currentColor;
    color: var(--capabilities-dark);
    font-family: var(--font-body);
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: 0;
  }

  .capability-detail--data .capability-detail__title {
    border-color: var(--capabilities-blue);
  }

  .capability-detail--paid .capability-detail__title {
    border-color: var(--capabilities-red);
  }

  .capability-detail--creative .capability-detail__title {
    border-color: var(--capabilities-orange);
  }

  .capability-detail__text {
    padding: 1.5rem 1.25rem 0 0;
  }

  .capability-detail__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 4.125rem;
    margin-top: 1.875rem;
    border-radius: 2.1875rem;
    padding: 0.9375rem 1.875rem;
    color: var(--capabilities-dark);
    font-size: 1.25rem;
    font-weight: 400;
    line-height: 1.8;
    text-align: center;
    transition: background-color 220ms ease, color 220ms ease, transform 220ms ease;
  }

  .capability-detail__button:hover,
  .capability-detail__button:focus-visible {
    background: var(--capabilities-dark);
    color: #ffffff;
    transform: translateY(-1px);
  }

  .capability-detail__button:focus-visible {
    outline: 3px solid rgba(35, 31, 32, 0.25);
    outline-offset: 3px;
  }

  .capability-detail__button--blue {
    background: var(--capabilities-blue);
  }

  .capability-detail__button--green {
    background: var(--capabilities-red);
  }

  .capability-detail__button--orange {
    background: var(--capabilities-orange);
  }

  .capability-detail__image {
    width: 100%;
    max-height: 38rem;
    object-fit: contain;
  }

  @media (max-width: 1024px) {
    .capabilities-hero {
      padding: 1.875rem 0 5.625rem;
    }

    .capabilities-hero__inner,
    .outcomes-section__inner,
    .workflow-section__inner,
    .capability-detail__inner,
    .capability-detail__inner--reverse {
      display: block;
    }

    .capabilities-hero__title,
    .workflow-section__title {
      font-size: 2.375rem;
      line-height: 1.1;
    }

    .capabilities-hero__text,
    .outcomes-section__copy,
    .workflow-section__text,
    .capability-detail__text {
      font-size: 1.125rem;
      line-height: 1.67;
    }

    .capabilities-hero__media,
    .outcomes-section__media,
    .capability-detail__media {
      display: none;
    }

    .outcomes-section {
      margin-top: 0;
      margin-bottom: 5rem;
      padding: 3rem 0 5rem;
    }

    .outcomes-section__heading {
      margin-bottom: 2rem;
    }

    .outcomes-section__eyebrow {
      font-size: 1.125rem;
      line-height: 1.22;
    }

    .outcomes-section__title {
      font-size: 2.125rem;
      line-height: 1.15;
    }

    .outcomes-section__copy {
      padding: 0;
      text-align: center;
    }

    .workflow-section {
      min-height: 0;
    }

    .workflow-section__copy {
      padding: 4.6875rem 0 3.75rem;
    }

    .workflow-section__media {
      max-width: 28rem;
      margin: 0 auto;
      padding-bottom: 2.5rem;
    }

    .workflow-section__prompt {
      font-size: 1.125rem;
      line-height: 1.78;
    }

    .capability-detail--data {
      margin-top: 2rem;
    }

    .capability-detail__inner {
      min-height: 0;
      padding-block: 2.5rem;
    }

    .capability-detail__title {
      font-size: 2.125rem;
      line-height: 1.24;
    }

    .capability-detail__text {
      padding: 1.5rem 0 0;
    }

    .capability-detail__button {
      min-height: 3.875rem;
      margin-top: 1.875rem;
      padding-inline: 0.9375rem;
      font-size: 1.125rem;
      line-height: 1.78;
    }
  }
</style>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { capabilitiesPageQuery, sanityClient } from '../../lib/sanity';
import { defaultCapabilitiesPageData, mergeCapabilitiesPageData } from '../../lib/fixedPageData';
import { richHtml, srcFor } from '../../lib/fixedPageRender';

const sanityPage = await sanityClient.fetch(capabilitiesPageQuery).catch(() => null);
const page = mergeCapabilitiesPageData(sanityPage);
const title = page.seoTitle || defaultCapabilitiesPageData.seoTitle;
const description = page.seoDescription || defaultCapabilitiesPageData.seoDescription;
const canonical = page.canonicalUrl || defaultCapabilitiesPageData.canonicalUrl;
const robots = page.robots || defaultCapabilitiesPageData.robots;
const heroImage = srcFor(page.hero.image);
const outcomesImage = srcFor(page.outcomes.image);
const workflowImage = srcFor(page.workflow.image);
const dataDetail = page.details[0];
const paidDetail = page.details[1];
const creativeDetail = page.details[2];
const dataImage = srcFor(dataDetail?.image);
const paidImage = srcFor(paidDetail?.image);
const creativeImage = srcFor(creativeDetail?.image);
const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  url: canonical,
  description,
  publisher: {
    '@type': 'Organization',
    name: 'Found Search Marketing',
    url: 'https://www.foundsm.com',
    logo: 'https://www.foundsm.com/images/logo.svg'
  }
};
---

<BaseLayout title={title} description={description} canonical={canonical} robots={robots} schema={schema}>
  <div class="capabilities-page">
    <section class="capabilities-hero" aria-labelledby="capabilities-hero-title">
      <div class:list={['capabilities-hero__inner', { 'capabilities-hero__inner--text-only': !heroImage }]}>
        <div class="capabilities-hero__copy">
          <h1 id="capabilities-hero-title" class="capabilities-hero__title">{page.hero.heading}</h1>
          <div class="capabilities-hero__text" set:html={richHtml(page.hero.body)} />
        </div>

        {heroImage && (
          <div class="capabilities-hero__media" aria-hidden={page.hero.imageAlt ? undefined : 'true'}>
            <img
              class="capabilities-hero__image"
              src={heroImage}
              sizes="(min-width: 1024px) 40vw, 0px"
              width="800"
              height="800"
              alt={page.hero.imageAlt || ''}
              loading="eager"
              fetchpriority="high"
              decoding="async"
            />
          </div>
        )}
      </div>
    </section>

    <section class="outcomes-section" aria-labelledby="outcomes-title">
      <div class="outcomes-section__heading">
        {page.outcomes.eyebrow && <p class="outcomes-section__eyebrow">{page.outcomes.eyebrow}</p>}
        <h2 id="outcomes-title" class="outcomes-section__title">{page.outcomes.heading}</h2>
      </div>

      <div class:list={['outcomes-section__inner', { 'outcomes-section__inner--text-only': !outcomesImage }]}>
        {outcomesImage && (
          <div class="outcomes-section__media" aria-hidden={page.outcomes.imageAlt ? undefined : 'true'}>
            <img
              class="outcomes-section__image"
              src={outcomesImage}
              sizes="(min-width: 1024px) 36vw, 0px"
              width="524"
              height="725"
              alt={page.outcomes.imageAlt || ''}
              loading="lazy"
              decoding="async"
            />
          </div>
        )}

        <div class="outcomes-section__copy" set:html={richHtml(page.outcomes.body)} />
      </div>
    </section>

    <section class="workflow-section" aria-labelledby="workflow-title">
      <div class:list={['workflow-section__inner', { 'workflow-section__inner--text-only': !workflowImage }]}>
        <div class="workflow-section__copy">
          <h2 id="workflow-title" class="workflow-section__title">{page.workflow.heading}</h2>
          <div class="workflow-section__text" set:html={richHtml(page.workflow.body)} />
          {page.workflow.prompt && <p class="workflow-section__prompt">{page.workflow.prompt}</p>}
        </div>

        {workflowImage && (
          <div class="workflow-section__media">
            <img
              class="workflow-section__image"
              src={workflowImage}
              width="500"
              height="500"
              alt={page.workflow.imageAlt || ''}
              loading="lazy"
              decoding="async"
            />
          </div>
        )}
      </div>
    </section>

    <section class="capability-detail capability-detail--data" id="capabilities-data-reporting-analytics" aria-labelledby="capability-data-title">
      <div class:list={['capability-detail__inner', { 'capability-detail__inner--text-only': !dataImage }]}>
        <div class="capability-detail__copy">
          <h2 id="capability-data-title" class="capability-detail__title">{dataDetail?.heading}</h2>
          <div class="capability-detail__text" set:html={richHtml(dataDetail?.body)} />
          {dataDetail?.cta?.label && dataDetail?.cta?.href && (
            <a class="capability-detail__button capability-detail__button--blue" href={dataDetail.cta.href}>{dataDetail.cta.label}</a>
          )}
        </div>

        {dataImage && (
          <div class="capability-detail__media" aria-hidden={dataDetail?.imageAlt ? undefined : 'true'}>
            <img
              class="capability-detail__image"
              src={dataImage}
              sizes="(min-width: 1024px) 44vw, 0px"
              width="1024"
              height="983"
              alt={dataDetail?.imageAlt || ''}
              loading="lazy"
              decoding="async"
            />
          </div>
        )}
      </div>
    </section>

    <section class="capability-detail capability-detail--paid" id="capabilities-paid-media" aria-labelledby="capability-paid-title">
      <div class:list={['capability-detail__inner capability-detail__inner--reverse', { 'capability-detail__inner--text-only': !paidImage }]}>
        {paidImage && (
          <div class="capability-detail__media" aria-hidden={paidDetail?.imageAlt ? undefined : 'true'}>
            <img
              class="capability-detail__image"
              src={paidImage}
              sizes="(min-width: 1024px) 36vw, 0px"
              width="753"
              height="768"
              alt={paidDetail?.imageAlt || ''}
              loading="lazy"
              decoding="async"
            />
          </div>
        )}

        <div class="capability-detail__copy">
          <h2 id="capability-paid-title" class="capability-detail__title">{paidDetail?.heading}</h2>
          <div class="capability-detail__text" set:html={richHtml(paidDetail?.body)} />
          {paidDetail?.cta?.label && paidDetail?.cta?.href && (
            <a class="capability-detail__button capability-detail__button--green" href={paidDetail.cta.href}>{paidDetail.cta.label}</a>
          )}
        </div>
      </div>
    </section>

    <section class="capability-detail capability-detail--creative" id="capabilities-performance-creative" aria-labelledby="capability-creative-title">
      <div class:list={['capability-detail__inner', { 'capability-detail__inner--text-only': !creativeImage }]}>
        <div class="capability-detail__copy">
          <h2 id="capability-creative-title" class="capability-detail__title">{creativeDetail?.heading}</h2>
          <div class="capability-detail__text" set:html={richHtml(creativeDetail?.body)} />
          {creativeDetail?.cta?.label && creativeDetail?.cta?.href && (
            <a class="capability-detail__button capability-detail__button--orange" href={creativeDetail.cta.href}>{creativeDetail.cta.label}</a>
          )}
        </div>

        {creativeImage && (
          <div class="capability-detail__media" aria-hidden={creativeDetail?.imageAlt ? undefined : 'true'}>
            <img
              class="capability-detail__image"
              src={creativeImage}
              sizes="(min-width: 1024px) 36vw, 0px"
              width="753"
              height="768"
              alt={creativeDetail?.imageAlt || ''}
              loading="lazy"
              decoding="async"
            />
          </div>
        )}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .capabilities-page {
    --capabilities-dark: #231f20;
    --capabilities-muted: #414042;
    --capabilities-light: #f2f3f2;
    --capabilities-green: #8dc63f;
    --capabilities-blue: #0aadef;
    --capabilities-orange: #fa9828;
    --capabilities-red: #f05660;
    color: var(--capabilities-dark);
    background: #ffffff;
    font-family: var(--font-body);
    overflow: hidden;
  }

  .capabilities-hero {
    padding: 3.75rem 0 5.625rem;
    background: #ffffff;
  }

  .capabilities-hero__inner,
  .outcomes-section__inner,
  .workflow-section__inner,
  .capability-detail__inner {
    inline-size: min(calc(100% - (2 * var(--page-gutter))), var(--content-max-width));
    margin-inline: auto;
  }

  .capabilities-hero__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(24rem, 40%);
    align-items: center;
    gap: 7.5rem;
  }

  .capabilities-hero__inner--text-only {
    grid-template-columns: minmax(0, 44rem);
  }

  .capabilities-hero__title,
  .workflow-section__title {
    margin: 0 0 1.25rem;
    color: var(--capabilities-dark);
    font-family: var(--font-heading);
    font-weight: 900;
    line-height: 1.083;
    letter-spacing: 0;
  }

  .capabilities-hero__title {
    font-size: 3.75rem;
  }

  .workflow-section__title {
    font-size: 3.75rem;
  }

  .capabilities-hero__text,
  .outcomes-section__copy,
  .workflow-section__text,
  .capability-detail__text {
    color: var(--capabilities-dark);
    font-size: 1.25rem;
    font-weight: 400;
    line-height: 1.8;
  }

  .capabilities-hero__text {
    max-width: 43rem;
  }

  .capabilities-hero__media {
    overflow: hidden;
    border-radius: 2.5rem;
  }

  .capabilities-hero__image {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
  }

  .outcomes-section {
    position: relative;
    margin-top: 1.25rem;
    margin-bottom: 12.5rem;
    padding: 5rem 0 7.5rem;
    background: var(--capabilities-light);
  }

  .outcomes-section::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: url("/images/pages/our-approach/topography-light.svg");
    background-position: center top;
    background-size: 130rem auto;
    opacity: 0.75;
    pointer-events: none;
  }

  .outcomes-section__heading,
  .outcomes-section__inner {
    position: relative;
    z-index: 1;
  }

  .outcomes-section__heading {
    inline-size: min(calc(100% - (2 * var(--page-gutter))), var(--content-max-width));
    margin: 0 auto 3.75rem;
    text-align: center;
  }

  .outcomes-section__eyebrow {
    margin: 0 0 0.25rem;
    color: var(--capabilities-dark);
    font-size: 1.25rem;
    font-weight: 300;
    line-height: 1.4;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .outcomes-section__title {
    margin: 0;
    color: var(--capabilities-dark);
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: 0;
  }

  .outcomes-section__inner {
    display: grid;
    grid-template-columns: minmax(20rem, 37%) minmax(0, 1fr);
    align-items: start;
    gap: 5.625rem;
  }

  .outcomes-section__inner--text-only {
    grid-template-columns: minmax(0, 52rem);
    justify-content: center;
  }

  .outcomes-section__image {
    width: 100%;
    max-width: 32.75rem;
  }

  .outcomes-section__copy {
    padding-top: 1.25rem;
  }

  .outcomes-section__copy p + p,
  .capability-detail__text p + p {
    margin-top: 1rem;
  }

  .workflow-section {
    min-height: 35.9375rem;
    background: linear-gradient(180deg, #ffffff 0%, var(--capabilities-light) 100%);
  }

  .workflow-section__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(20rem, 38%);
    align-items: center;
    gap: 3rem;
  }

  .workflow-section__inner--text-only {
    grid-template-columns: minmax(0, 54rem);
  }

  .workflow-section__copy {
    padding: 5rem 0;
  }

  .workflow-section__prompt {
    display: inline-block;
    margin: 1.875rem 0 0;
    padding: 0.3125rem 0.625rem;
    border-left: 0.25rem solid var(--capabilities-green);
    color: var(--capabilities-dark);
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.6;
  }

  .workflow-section__image {
    width: min(100%, 31.25rem);
    margin-inline: auto 0;
  }

  .capability-detail {
    background: #ffffff;
  }

  .capability-detail--data {
    margin-top: 3.125rem;
  }

  .capability-detail__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(20rem, 1fr);
    align-items: center;
    gap: 3.125rem;
    min-height: 39rem;
    padding-block: 2rem;
  }

  .capability-detail__inner--reverse {
    grid-template-columns: minmax(20rem, 1fr) minmax(0, 1fr);
  }

  .capability-detail__inner--text-only,
  .capability-detail__inner--reverse.capability-detail__inner--text-only {
    grid-template-columns: minmax(0, 54rem);
  }

  .capability-detail__title {
    margin: 0 0 0.9375rem;
    padding-bottom: 0.3125rem;
    border-bottom: 0.3125rem solid currentColor;
    color: var(--capabilities-dark);
    font-family: var(--font-body);
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: 0;
  }

  .capability-detail--data .capability-detail__title {
    border-color: var(--capabilities-blue);
  }

  .capability-detail--paid .capability-detail__title {
    border-color: var(--capabilities-red);
  }

  .capability-detail--creative .capability-detail__title {
    border-color: var(--capabilities-orange);
  }

  .capability-detail__text {
    padding: 1.5rem 1.25rem 0 0;
  }

  .capability-detail__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 4.125rem;
    margin-top: 1.875rem;
    border-radius: 2.1875rem;
    padding: 0.9375rem 1.875rem;
    color: var(--capabilities-dark);
    font-size: 1.25rem;
    font-weight: 400;
    line-height: 1.8;
    text-align: center;
    transition: background-color 220ms ease, color 220ms ease, transform 220ms ease;
  }

  .capability-detail__button:hover,
  .capability-detail__button:focus-visible {
    background: var(--capabilities-dark);
    color: #ffffff;
    transform: translateY(-1px);
  }

  .capability-detail__button:focus-visible {
    outline: 3px solid rgba(35, 31, 32, 0.25);
    outline-offset: 3px;
  }

  .capability-detail__button--blue {
    background: var(--capabilities-blue);
  }

  .capability-detail__button--green {
    background: var(--capabilities-red);
  }

  .capability-detail__button--orange {
    background: var(--capabilities-orange);
  }

  .capability-detail__image {
    width: 100%;
    max-height: 38rem;
    object-fit: contain;
  }

  @media (max-width: 1024px) {
    .capabilities-hero {
      padding: 1.875rem 0 5.625rem;
    }

    .capabilities-hero__inner,
    .outcomes-section__inner,
    .workflow-section__inner,
    .capability-detail__inner,
    .capability-detail__inner--reverse {
      display: block;
    }

    .capabilities-hero__title,
    .workflow-section__title {
      font-size: 2.375rem;
      line-height: 1.1;
    }

    .capabilities-hero__text,
    .outcomes-section__copy,
    .workflow-section__text,
    .capability-detail__text {
      font-size: 1.125rem;
      line-height: 1.67;
    }

    .capabilities-hero__media,
    .outcomes-section__media,
    .capability-detail__media {
      display: none;
    }

    .outcomes-section {
      margin-top: 0;
      margin-bottom: 5rem;
      padding: 3rem 0 5rem;
    }

    .outcomes-section__heading {
      margin-bottom: 2rem;
    }

    .outcomes-section__eyebrow {
      font-size: 1.125rem;
      line-height: 1.22;
    }

    .outcomes-section__title {
      font-size: 2.125rem;
      line-height: 1.15;
    }

    .outcomes-section__copy {
      padding: 0;
      text-align: center;
    }

    .workflow-section {
      min-height: 0;
    }

    .workflow-section__copy {
      padding: 4.6875rem 0 3.75rem;
    }

    .workflow-section__media {
      max-width: 28rem;
      margin: 0 auto;
      padding-bottom: 2.5rem;
    }

    .workflow-section__prompt {
      font-size: 1.125rem;
      line-height: 1.78;
    }

    .capability-detail--data {
      margin-top: 2rem;
    }

    .capability-detail__inner {
      min-height: 0;
      padding-block: 2.5rem;
    }

    .capability-detail__title {
      font-size: 2.125rem;
      line-height: 1.24;
    }

    .capability-detail__text {
      padding: 1.5rem 0 0;
    }

    .capability-detail__button {
      min-height: 3.875rem;
      margin-top: 1.875rem;
      padding-inline: 0.9375rem;
      font-size: 1.125rem;
      line-height: 1.78;
    }
  }
</style>

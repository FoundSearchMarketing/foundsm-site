---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ModernHero from '../../components/modern/ModernHero.astro';
import SplitFeature from '../../components/modern/SplitFeature.astro';
import FeatureTabs from '../../components/modern/FeatureTabs.astro';
import CardGrid from '../../components/modern/CardGrid.astro';
import CtaPanel from '../../components/modern/CtaPanel.astro';
import LogoMarquee from '../../components/modern/LogoMarquee.astro';
import { capabilityDetailPageQuery, sanityClient } from '../../lib/sanity';
import { defaultCapabilityDetailPages, mergeCapabilityDetailPageData } from '../../lib/fixedPageData';
import { cardsFor, imageProps, logosFor, richHtml, richText, tabsFor } from '../../lib/fixedPageRender';

const sanityPage = await sanityClient.fetch(capabilityDetailPageQuery, { id: 'capabilityPaidMediaPage' }).catch(() => null);
const page = mergeCapabilityDetailPageData(defaultCapabilityDetailPages.paidMedia, sanityPage);
const title = page.seoTitle || defaultCapabilityDetailPages.paidMedia.seoTitle;
const description = page.seoDescription || defaultCapabilityDetailPages.paidMedia.seoDescription;
const canonical = page.canonicalUrl || defaultCapabilityDetailPages.paidMedia.canonicalUrl;
const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  url: canonical,
  description,
  publisher: {
    '@type': 'Organization',
    name: 'Found Search Marketing',
  },
};

const tabs = tabsFor(page.featureTabs?.tabs);
const channelCards = cardsFor(page.primaryCards?.cards);
const analyticsCards = cardsFor(page.secondaryCards?.cards);
const logos = logosFor(page.logoMarquee?.logos);
---

<BaseLayout title={title} description={description} canonical={canonical} robots={page.robots} schema={schema}>
  <ModernHero
    tone="soft"
    titleScale="display"
    title={page.hero.heading || ''}
    intro={richText(page.hero.body)}
    introHtml={richHtml(page.hero.body)}
    image={imageProps(page.hero, 'eager')}
  />

  <SplitFeature
    title={page.split?.heading || ''}
    body={richText(page.split?.body)}
    bodyHtml={richHtml(page.split?.body)}
    image={imageProps(page.split)}
  />

  {tabs.length > 0 && <FeatureTabs idPrefix={page.featureTabs?.idPrefix || 'paid-media-capabilities'} tabs={tabs} />}

  <CardGrid
    theme="muted"
    title={page.primaryCards?.title}
    subtitle={page.primaryCards?.subtitle}
    cards={channelCards}
    columns={4}
  />

  <CardGrid
    title={page.secondaryCards?.title}
    subtitle={page.secondaryCards?.subtitle}
    cards={analyticsCards}
    columns={3}
  />

  <CtaPanel
    body={richText(page.cta?.body)}
    bodyHtml={richHtml(page.cta?.body)}
    ctaLabel={page.cta?.cta?.label}
    ctaHref={page.cta?.cta?.href}
  />

  {logos.length > 0 && <LogoMarquee logos={logos} theme="muted" />}
</BaseLayout>

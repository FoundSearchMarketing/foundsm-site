---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PerformanceCreativePage from '../../components/modern/PerformanceCreativePage.astro';
import { capabilityDetailPageQuery, sanityClient } from '../../lib/sanity';
import { defaultCapabilityDetailPages, mergeCapabilityDetailPageData } from '../../lib/fixedPageData';
import { cardsFor, imageProps, richHtml, richText, tabsFor } from '../../lib/fixedPageRender';

const sanityPage = await sanityClient.fetch(capabilityDetailPageQuery, { id: 'capabilityPerformanceCreativePage' }).catch(() => null);
const page = mergeCapabilityDetailPageData(defaultCapabilityDetailPages.performanceCreative, sanityPage);
const title = page.seoTitle || defaultCapabilityDetailPages.performanceCreative.seoTitle;
const description = page.seoDescription || defaultCapabilityDetailPages.performanceCreative.seoDescription;
const canonical = page.canonicalUrl || defaultCapabilityDetailPages.performanceCreative.canonicalUrl;
const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  url: canonical,
  description,
  publisher: {
    '@type': 'Organization',
    name: 'Found Search Marketing',
  },
};

const creativeTabs = tabsFor(page.featureTabs?.tabs);
const proofCards = cardsFor(page.primaryCards?.cards);
---

<BaseLayout title={title} description={description} canonical={canonical} robots={page.robots} schema={schema}>
  <PerformanceCreativePage
    idPrefix={page.featureTabs?.idPrefix || 'performance-creative-methods'}
    hero={{
      title: page.hero.heading || '',
      body: richText(page.hero.body),
      bodyHtml: richHtml(page.hero.body),
      image: imageProps(page.hero, 'eager'),
    }}
    split={{
      title: page.split?.heading || '',
      body: richText(page.split?.body),
      bodyHtml: richHtml(page.split?.body),
      image: imageProps(page.split),
    }}
    tabs={creativeTabs}
    secondary={{
      title: page.secondarySplit?.heading || '',
      body: richText(page.secondarySplit?.body),
      bodyHtml: richHtml(page.secondarySplit?.body),
      image: imageProps(page.secondarySplit),
    }}
    cards={proofCards}
  />
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import FormLanding from '../components/modern/FormLanding.astro';
import { formPageQuery, sanityClient } from '../lib/sanity';
import { defaultContactPageData, mergeFormPageData } from '../lib/morePageData';
import { richHtml, richText } from '../lib/fixedPageRender';

const sanityPage = await sanityClient.fetch(formPageQuery, { id: 'contactPage' }).catch(() => null);
const page = mergeFormPageData(defaultContactPageData, sanityPage);
const title = page.seoTitle || defaultContactPageData.seoTitle;
const description = page.seoDescription || defaultContactPageData.seoDescription;
const canonical = page.canonicalUrl || defaultContactPageData.canonicalUrl;
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: title,
    description,
    url: canonical,
    publisher: {
      '@type': 'Organization',
      name: 'Found Search Marketing',
      url: 'https://www.foundsm.com',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'LocalBusiness',
    name: 'Found Search Marketing',
    description: 'An Enterprise Paid Media Agency',
    url: 'https://www.foundsm.com',
    telephone: '+1-317-721-2229',
    email: 'info@foundsm.com',
    address: {
      '@type': 'PostalAddress',
      streetAddress: '8475 Nightfall Lane, Suite 200',
      addressLocality: 'Fishers',
      addressRegion: 'IN',
      postalCode: '46037',
      addressCountry: 'US',
    },
    sameAs: [
      'https://www.facebook.com/foundsm/',
      'https://www.instagram.com/found_sm/',
      'https://www.linkedin.com/company/found-search-marketing/',
      'https://x.com/FoundSM',
    ],
  },
];
---

<BaseLayout title={title} description={description} canonical={canonical} robots={page.robots} schema={schema}>
  <FormLanding
    variant="contact"
    eyebrow={page.eyebrow}
    title={page.heading || ''}
    intro={richText(page.intro)}
    introHtml={richHtml(page.intro)}
    formId={page.formId || ''}
    portalId={page.portalId}
    summary={richText(page.summary)}
    summaryHtml={richHtml(page.summary)}
  />
</BaseLayout>

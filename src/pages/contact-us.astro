---
import BaseLayout from '../layouts/BaseLayout.astro';
import FormLanding from '../components/modern/FormLanding.astro';

const title = 'Contact Us - Found Search Marketing';
const description = "Bring us your biggest challenge. We don't want to be your agency of record. We want to be your agency of results. Let's see what we can achieve together.";
const canonical = 'https://www.foundsm.com/contact-us';
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: title,
    description,
    url: canonical,
    publisher: {
      '@type': 'Organization',
      name: 'Found Search Marketing',
      url: 'https://www.foundsm.com',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'LocalBusiness',
    name: 'Found Search Marketing',
    description: 'An Enterprise Paid Media Agency',
    url: 'https://www.foundsm.com',
    telephone: '+1-317-721-2229',
    email: 'info@foundsm.com',
    address: {
      '@type': 'PostalAddress',
      streetAddress: '8475 Nightfall Lane, Suite 200',
      addressLocality: 'Fishers',
      addressRegion: 'IN',
      postalCode: '46037',
      addressCountry: 'US',
    },
    sameAs: [
      'https://www.facebook.com/foundsm/',
      'https://www.instagram.com/found_sm/',
      'https://www.linkedin.com/company/found-search-marketing/',
      'https://x.com/FoundSM',
    ],
  },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schema={schema}>
  <FormLanding
    variant="contact"
    title="Bring Us Your Biggest Challenge."
    intro="We don't want to be your agency of record. We want to be your agency of results. Let's see what we can achieve together."
    formId="4f48ec0c-d036-4c2f-b461-4b5f4c03c3fc"
    summary="We're ready to learn more about your business goals and talk about all the ways we can work together to find solutions that drive impact and lead to profitable revenue. Whether it's smarter paid media strategy, creative that converts, or finding clarity in your data, we're ready to sit on the same side of the table and get to work."
  />
</BaseLayout>

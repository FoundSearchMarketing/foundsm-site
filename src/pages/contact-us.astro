---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Contact Us | Found Search Marketing",
    "description": "Contact Found Search Marketing to discuss your enterprise paid media needs.",
    "url": "https://www.foundsm.com/contact-us",
    "publisher": {
      "@type": "Organization",
      "name": "Found Search Marketing",
      "url": "https://www.foundsm.com"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Found Search Marketing",
    "description": "An Enterprise Paid Media Agency",
    "url": "https://www.foundsm.com",
    "telephone": "+1-317-721-2229",
    "email": "info@foundsm.com",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "8475 Nightfall Lane, Suite 200",
      "addressLocality": "Fishers",
      "addressRegion": "IN",
      "postalCode": "46037",
      "addressCountry": "US"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 39.9567,
      "longitude": -86.0133
    },
    "sameAs": [
      "https://www.facebook.com/foundsearchmarketing",
      "https://www.instagram.com/foundsearchmarketing",
      "https://www.linkedin.com/company/found-search-marketing",
      "https://x.com/foundsm"
    ]
  }
];
---

<BaseLayout
  title="Contact Us | Found Search Marketing"
  description="Contact Found Search Marketing. Let's start the conversation about your enterprise paid media needs. Reach us by phone, email, or fill out our contact form."
  canonical="https://www.foundsm.com/contact-us"
  robots="index, follow"
  schema={schema}
>

    <!-- Hero Section -->
    <section class="hero hero--short" aria-labelledby="contact-hero-heading">
      <div class="container">
        <div class="hero__content fade-in-up">
          <h1 id="contact-hero-heading">Contact Us</h1>
          <p class="hero__subtitle">Let's start the conversation.</p>
        </div>
      </div>
    </section>

    <!-- Contact Section -->
    <section class="section contact-section" aria-labelledby="contact-section-heading">
      <div class="container">
        <h2 id="contact-section-heading" class="sr-only">Get In Touch</h2>
        <div class="contact-grid">

          <!-- Left Column: Contact Information -->
          <div class="contact-info fade-in-up">
            <h3>Get In Touch</h3>
            <p>Ready to elevate your enterprise paid media strategy? We'd love to hear from you. Reach out using the information below or fill out the form and we'll be in touch.</p>

            <div class="contact-details">
              <div class="contact-detail-item">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                <div>
                  <h4>Our Office</h4>
                  <address>
                    8475 Nightfall Lane<br>
                    Suite 200<br>
                    Fishers, IN 46037
                  </address>
                </div>
              </div>

              <div class="contact-detail-item">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                <div>
                  <h4>Email</h4>
                  <a href="mailto:info@foundsm.com">info@foundsm.com</a>
                </div>
              </div>

              <div class="contact-detail-item">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
                <div>
                  <h4>Phone</h4>
                  <a href="tel:+13177212229">1.317.721.2229</a>
                </div>
              </div>
            </div>

            <div class="contact-social">
              <h4>Follow Us</h4>
              <div class="social-links">
                <a href="https://www.facebook.com/foundsearchmarketing" aria-label="Facebook" target="_blank" rel="noopener noreferrer">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </a>
                <a href="https://www.instagram.com/foundsearchmarketing" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                </a>
                <a href="https://www.linkedin.com/company/found-search-marketing" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                </a>
                <a href="https://x.com/foundsm" aria-label="X (formerly Twitter)" target="_blank" rel="noopener noreferrer">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                </a>
              </div>
            </div>
          </div>

          <!-- Right Column: Contact Form -->
          <div class="contact-form-wrapper fade-in-up">
            <!-- HubSpot Form Embed: Portal 5045186 -->
            <div class="hubspot-form-container" id="hubspot-contact-form">
              <form class="contact-form" aria-label="Contact form">
                <div class="form-row">
                  <div class="form-group">
                    <label for="contact-first-name">First Name <span class="required" aria-hidden="true">*</span></label>
                    <input type="text" id="contact-first-name" name="firstname" required aria-required="true" placeholder="First Name">
                  </div>
                  <div class="form-group">
                    <label for="contact-last-name">Last Name <span class="required" aria-hidden="true">*</span></label>
                    <input type="text" id="contact-last-name" name="lastname" required aria-required="true" placeholder="Last Name">
                  </div>
                </div>

                <div class="form-row">
                  <div class="form-group">
                    <label for="contact-email">Business Email <span class="required" aria-hidden="true">*</span></label>
                    <input type="email" id="contact-email" name="email" required aria-required="true" placeholder="you@company.com">
                  </div>
                  <div class="form-group">
                    <label for="contact-phone">Phone Number</label>
                    <input type="tel" id="contact-phone" name="phone" placeholder="(555) 555-5555">
                  </div>
                </div>

                <div class="form-group">
                  <label for="contact-budget">Monthly Paid Media Budget</label>
                  <select id="contact-budget" name="budget">
                    <option value="" disabled selected>Select a range</option>
                    <option value="under-50k">Under $50,000</option>
                    <option value="50k-100k">$50,000 - $100,000</option>
                    <option value="100k-250k">$100,000 - $250,000</option>
                    <option value="250k-500k">$250,000 - $500,000</option>
                    <option value="500k-1m">$500,000 - $1,000,000</option>
                    <option value="over-1m">$1,000,000+</option>
                  </select>
                </div>

                <div class="form-group">
                  <label for="contact-details">Additional Details</label>
                  <textarea id="contact-details" name="message" rows="5" placeholder="Tell us about your goals and challenges..."></textarea>
                </div>

                <div class="form-group form-checkbox">
                  <input type="checkbox" id="contact-optin" name="marketing_optin" value="yes">
                  <label for="contact-optin">I'd like to receive marketing communications from Found Search Marketing, including insights, case studies, and industry updates.</label>
                </div>

                <button type="submit" class="btn btn--green btn--lg" style="width:100%">Send Message</button>
              </form>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Additional CTA Section -->
    <section class="cta-banner" aria-label="Call to action">
      <div class="cta-banner__bg" aria-hidden="true"></div>
      <div class="container cta-banner__inner fade-in-up">
        <h2 class="cta-banner__headline">Other Ways to Reach Us</h2>
        <p>Whether you're looking for a new paid media partner or want to explore a career with Found, we're here to help.</p>
        <div style="margin-top: var(--space-lg); display: flex; gap: var(--space-sm); flex-wrap: wrap; justify-content: center;">
          <a href="/join-us" class="btn btn--green">View Careers</a>
          <a href="/newsletter" class="btn btn--ghost">Subscribe to Our Newsletter</a>
        </div>
      </div>
    </section>

    <script is:inline>
      // HubSpot Form Embed - Portal 5045186
      if (window.hbspt) {
        window.hbspt.forms.create({
          region: "na1",
          portalId: "5045186",
          formId: "PLACEHOLDER_FORM_ID",
          target: "#hubspot-contact-form"
        });
      }
    </script>

</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import FormLanding from '../components/modern/FormLanding.astro';

const title = 'Data Connect - Found Search Marketing';
const description = "We're ready to learn more about your business goals and talk about all the ways we can work together to find solutions that drive impact and lead to profitable revenue. Whether it's smarter paid media strategy, creative that converts, or finding clarity in your data, we're ready to sit on the same side of the table and get to work.";
const canonical = 'https://www.foundsm.com/dataconnect';
const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  url: canonical,
  description,
  publisher: {
    '@type': 'Organization',
    name: 'Found Search Marketing',
    url: 'https://www.foundsm.com',
  },
};
---

<BaseLayout title={title} description={description} canonical={canonical} schema={schema}>
  <FormLanding
    variant="dataconnect"
    title="Activating First-Party Data for Revenue."
    lead="Ready to stop guessing and start scaling?"
    intro="Let's talk about bringing your first-party data directly to the ad platforms where growth happens."
    formId="77ee07f7-2567-46d2-9255-ff9e410fdf6a"
    summary={description}
  />
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "name": "Found Search Marketing",
      "url": "https://www.foundsm.com",
      "logo": "https://www.foundsm.com/images/logo.svg",
      "description": "An enterprise paid media agency that drives measurable growth.",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "8475 Nightfall Lane, Suite 200",
        "addressLocality": "Fishers",
        "addressRegion": "IN",
        "postalCode": "46037",
        "addressCountry": "US"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+1-317-721-2229",
        "contactType": "sales",
        "email": "info@foundsm.com"
      },
      "sameAs": [
        "https://www.facebook.com/foundsm/",
        "https://www.instagram.com/found_sm/",
        "https://www.linkedin.com/company/found-search-marketing/",
        "https://x.com/FoundSM"
      ]
    },
    {
      "@type": "WebPage",
      "name": "Found Search Marketing | An Enterprise Paid Media Agency",
      "url": "https://www.foundsm.com/",
      "description": "Found Search Marketing is an enterprise paid media agency specializing in data-driven strategy, full-funnel execution, and transparent reporting to drive measurable growth.",
      "publisher": {
        "@type": "Organization",
        "name": "Found Search Marketing"
      }
    }
  ]
};
---

<BaseLayout
  title="Found Search Marketing | An Enterprise Paid Media Agency"
  description="Found Search Marketing is an enterprise paid media agency specializing in data-driven strategy, full-funnel execution, and transparent reporting to drive measurable growth."
  canonical="https://www.foundsm.com/"
  schema={schema}
>

    <!-- ============================================
         ANNOUNCEMENT BANNER
         ============================================ -->
    <aside class="announcement-bar" id="announcement-bar" aria-label="Event announcement">
      <div class="container announcement-bar__inner">
        <a href="/events/lunch-and-learn" class="announcement-bar__link">
          <span class="announcement-bar__badge">Upcoming Event</span>
          <span class="announcement-bar__text">Lunch &amp; Learn: Scale Smarter with AI-Powered Paid Media &mdash; April 15, 2026</span>
          <span class="announcement-bar__cta">Register Free &rarr;</span>
        </a>
        <button class="announcement-bar__close" aria-label="Dismiss announcement" onclick="document.getElementById('announcement-bar').style.display='none'">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 4L12 12M12 4L4 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>
      </div>
    </aside>

    <!-- ============================================
         HERO SECTION
         ============================================ -->
    <section class="hero hero--light" aria-label="Hero">

      <div class="container hero__content">
        <div class="hero-stagger">
          <h1 class="hero__headline">An enterprise paid media agency that drives measurable growth</h1>
        </div>
        <div class="hero-stagger">
          <p class="hero__subtitle">We combine data intelligence, strategic media buying, and performance creative to deliver outcomes that matter for enterprise brands.</p>
        </div>

        <div class="hero-stagger">
          <div class="hero__search-bar" aria-label="Animated search demonstration">
            <div class="hero__search-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="9" cy="9" r="7" stroke="#999" stroke-width="2"/><line x1="14" y1="14" x2="18" y2="18" stroke="#999" stroke-width="2" stroke-linecap="round"/></svg>
            </div>
            <span class="hero__typewriter" id="hero-typewriter" aria-live="polite"></span>
            <div class="hero__mic-icon" aria-hidden="true">
              <svg width="16" height="22" viewBox="0 0 16 22" fill="none"><rect x="4" y="1" width="8" height="13" rx="4" stroke="#999" stroke-width="2"/><path d="M1 10C1 14.4183 4.13401 18 8 18C11.866 18 15 14.4183 15 10" stroke="#999" stroke-width="2"/><line x1="8" y1="18" x2="8" y2="21" stroke="#999" stroke-width="2"/></svg>
            </div>
          </div>
        </div>

        <div class="hero-stagger">
          <a href="/contact-us" class="btn btn--green btn--lg">Start the Conversation</a>
        </div>
      </div>
    </section>


    <!-- ============================================
         CLIENT LOGO MARQUEE
         ============================================ -->
    <section class="logo-marquee" aria-label="Trusted by leading brands">
      <div class="container">
        <h2 class="logo-marquee__heading fade-in-up">Trusted by Leading Brands</h2>
      </div>
      <div class="logo-marquee__track" aria-hidden="true">
        <div class="logo-marquee__scroll">
          <div class="logo-marquee__item"><img src="/images/logos/bar-keepers-friend.png" alt="Bar Keepers Friend" loading="lazy" width="140" height="60"></div>
          <div class="logo-marquee__item"><img src="/images/logos/accuchek.png" alt="AccuChek" loading="lazy" width="140" height="60"></div>
          <div class="logo-marquee__item"><img src="/images/logos/adt.png" alt="ADT" loading="lazy" width="140" height="60"></div>
          <div class="logo-marquee__item"><img src="/images/logos/bastian-solutions.png" alt="Bastian Solutions" loading="lazy" width="140" height="60"></div>
          <div class="logo-marquee__item"><img src="/images/logos/iwu.png" alt="IWU" loading="lazy" width="140" height="60"></div>
          <div class="logo-marquee__item"><img src="/images/logos/hendricks.png" alt="Hendricks" loading="lazy" width="140" height="60"></div>
          <div class="logo-marquee__item"><img src="/images/logos/iu-kelley.png" alt="IU Kelley" loading="lazy" width="140" height="60"></div>
          <div class="logo-marquee__item"><img src="/images/logos/lawn-pride.png" alt="Lawn Pride" loading="lazy" width="140" height="60"></div>
          <div class="logo-marquee__item"><img src="/images/logos/indy-ignite.png" alt="Indy Ignite" loading="lazy" width="140" height="60"></div>
          <div class="logo-marquee__item"><img src="/images/logos/farm-bureau.png" alt="Farm Bureau" loading="lazy" width="140" height="60"></div>
          <div class="logo-marquee__item"><img src="/images/logos/roche.png" alt="Roche" loading="lazy" width="140" height="60"></div>
          <div class="logo-marquee__item"><img src="/images/logos/duke-ce.png" alt="Duke CE" loading="lazy" width="140" height="60"></div>
          <div class="logo-marquee__item"><img src="/images/logos/cook-medical.png" alt="Cook Medical" loading="lazy" width="140" height="60"></div>
          <div class="logo-marquee__item"><img src="/images/logos/mr-quik.png" alt="Mr. Quik" loading="lazy" width="140" height="60"></div>
          <div class="logo-marquee__item"><img src="/images/logos/bne.png" alt="BNE" loading="lazy" width="140" height="60"></div>
          <div class="logo-marquee__item"><img src="/images/logos/artboard-1.png" alt="Artboard-1" loading="lazy" width="140" height="60"></div>

          <!-- Duplicate set for seamless infinite scroll -->
          <div class="logo-marquee__item"><img src="/images/logos/bar-keepers-friend.png" alt="Bar Keepers Friend" loading="lazy" width="140" height="60"></div>
          <div class="logo-marquee__item"><img src="/images/logos/accuchek.png" alt="AccuChek" loading="lazy" width="140" height="60"></div>
          <div class="logo-marquee__item"><img src="/images/logos/adt.png" alt="ADT" loading="lazy" width="140" height="60"></div>
          <div class="logo-marquee__item"><img src="/images/logos/bastian-solutions.png" alt="Bastian Solutions" loading="lazy" width="140" height="60"></div>
          <div class="logo-marquee__item"><img src="/images/logos/iwu.png" alt="IWU" loading="lazy" width="140" height="60"></div>
          <div class="logo-marquee__item"><img src="/images/logos/hendricks.png" alt="Hendricks" loading="lazy" width="140" height="60"></div>
          <div class="logo-marquee__item"><img src="/images/logos/iu-kelley.png" alt="IU Kelley" loading="lazy" width="140" height="60"></div>
          <div class="logo-marquee__item"><img src="/images/logos/lawn-pride.png" alt="Lawn Pride" loading="lazy" width="140" height="60"></div>
          <div class="logo-marquee__item"><img src="/images/logos/indy-ignite.png" alt="Indy Ignite" loading="lazy" width="140" height="60"></div>
          <div class="logo-marquee__item"><img src="/images/logos/farm-bureau.png" alt="Farm Bureau" loading="lazy" width="140" height="60"></div>
          <div class="logo-marquee__item"><img src="/images/logos/roche.png" alt="Roche" loading="lazy" width="140" height="60"></div>
          <div class="logo-marquee__item"><img src="/images/logos/duke-ce.png" alt="Duke CE" loading="lazy" width="140" height="60"></div>
          <div class="logo-marquee__item"><img src="/images/logos/cook-medical.png" alt="Cook Medical" loading="lazy" width="140" height="60"></div>
          <div class="logo-marquee__item"><img src="/images/logos/mr-quik.png" alt="Mr. Quik" loading="lazy" width="140" height="60"></div>
          <div class="logo-marquee__item"><img src="/images/logos/bne.png" alt="BNE" loading="lazy" width="140" height="60"></div>
          <div class="logo-marquee__item"><img src="/images/logos/artboard-1.png" alt="Artboard-1" loading="lazy" width="140" height="60"></div>
        </div>
      </div>
    </section>


    <!-- ============================================
         STATS SECTION
         ============================================ -->
    <section class="stats" aria-label="Key statistics">
      <div class="stats__bg-image" aria-hidden="true">
        <img src="/images/stats-decorative.jpg" alt="" loading="lazy" width="1920" height="600">
      </div>
      <div class="container stats__grid">

        <div class="stats__item fade-in-up" data-target="210" data-prefix="$" data-suffix="M+">
          <span class="stats__number" aria-label="$210M+ Spend Managed">
            <span class="stats__prefix">$</span>
            <span class="stats__value">0</span>
            <span class="stats__suffix">M+</span>
          </span>
          <span class="stats__label">Spend Managed</span>
        </div>

        <div class="stats__item fade-in-up" data-target="1" data-prefix="" data-suffix="M+">
          <span class="stats__number" aria-label="1M+ Leads Generated">
            <span class="stats__value">0</span>
            <span class="stats__suffix">M+</span>
          </span>
          <span class="stats__label">Leads Generated</span>
        </div>

        <div class="stats__item fade-in-up" data-target="20" data-prefix="" data-suffix="+">
          <span class="stats__number" aria-label="20+ Years Experience">
            <span class="stats__value">0</span>
            <span class="stats__suffix">+</span>
          </span>
          <span class="stats__label">Years Experience</span>
        </div>

        <div class="stats__item fade-in-up" data-target="50" data-prefix="" data-suffix="+">
          <span class="stats__number" aria-label="50+ Employees Across 12 States">
            <span class="stats__value">0</span>
            <span class="stats__suffix">+</span>
          </span>
          <span class="stats__label">Employees Across 12 States</span>
        </div>

      </div>
    </section>


    <!-- ============================================
         FOCUSED ON OUTCOMES SECTION
         ============================================ -->
    <section class="outcomes" aria-label="Focused on outcomes">
      <div class="container outcomes__grid">

        <div class="outcomes__image fade-in-up">
          <img src="/images/outcomes-photo.jpg" alt="Team collaborating on data-driven marketing strategy" loading="lazy" width="600" height="450">
        </div>

        <div class="outcomes__content fade-in-up">
          <h2 class="outcomes__headline">Focused On Outcomes, Not Outputs</h2>
          <p class="outcomes__description">At Found Search Marketing, we believe that vanity metrics don't grow businesses. Our team is laser-focused on the outcomes that matter most to your bottom line &mdash; qualified leads, revenue growth, and long-term customer value. We build bespoke paid media strategies grounded in data intelligence so every dollar works harder for your brand.</p>
          <a href="/our-approach" class="outcomes__cta link-arrow">
            Learn About Our Approach
            <svg width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>

      </div>
    </section>


    <!-- ============================================
         TABBED CONTENT SECTION
         ============================================ -->
    <section class="tabs-section" aria-label="What sets us apart">
      <div class="container">
        <h2 class="tabs-section__heading fade-in-up">What Sets Us Apart</h2>

        <div class="tabs" role="tablist" aria-label="Service highlights">

          <button class="tabs__tab tabs__tab--active" id="tab-strategy" role="tab" aria-selected="true" aria-controls="panel-strategy">
            <svg class="tabs__icon" width="28" height="28" viewBox="0 0 28 28" aria-hidden="true"><circle cx="14" cy="14" r="12" stroke="currentColor" stroke-width="2" fill="none"/><path d="M10 14L13 17L18 11" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>Data-Driven Strategy</span>
          </button>

          <button class="tabs__tab" id="tab-execution" role="tab" aria-selected="false" aria-controls="panel-execution" tabindex="-1">
            <svg class="tabs__icon" width="28" height="28" viewBox="0 0 28 28" aria-hidden="true"><rect x="4" y="4" width="20" height="20" rx="3" stroke="currentColor" stroke-width="2" fill="none"/><path d="M10 9V19M14 12V19M18 7V19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            <span>Full-Funnel Execution</span>
          </button>

          <button class="tabs__tab" id="tab-reporting" role="tab" aria-selected="false" aria-controls="panel-reporting" tabindex="-1">
            <svg class="tabs__icon" width="28" height="28" viewBox="0 0 28 28" aria-hidden="true"><path d="M4 22L10 14L16 18L24 6" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/><circle cx="24" cy="6" r="2" fill="currentColor"/></svg>
            <span>Transparent Reporting</span>
          </button>

        </div>

        <!-- Tab Panels -->
        <div class="tabs__panels">

          <div class="tabs__panel tabs__panel--active" id="panel-strategy" role="tabpanel" aria-labelledby="tab-strategy">
            <div class="tabs__panel-grid">
              <div class="tabs__panel-image">
                <img src="/images/tab-strategy.jpg" alt="Data analytics dashboard showing campaign performance metrics" loading="lazy" width="560" height="380">
              </div>
              <div class="tabs__panel-content">
                <h3>Strategy Built on Data, Not Guesswork</h3>
                <p>We start every engagement with deep data analysis to understand your market, audience, and competitive landscape. Our proprietary intelligence tools surface insights that inform smarter media investments and more effective campaign architecture from day one.</p>
              </div>
            </div>
          </div>

          <div class="tabs__panel" id="panel-execution" role="tabpanel" aria-labelledby="tab-execution" hidden>
            <div class="tabs__panel-grid">
              <div class="tabs__panel-image">
                <img src="/images/tab-execution.jpg" alt="Multi-channel campaign execution across search, social, and display" loading="lazy" width="560" height="380">
              </div>
              <div class="tabs__panel-content">
                <h3>Integrated Campaigns Across Every Channel</h3>
                <p>From paid search and social to programmatic display and connected TV, we execute cohesive campaigns across the full funnel. Our team manages every touchpoint to ensure your message reaches the right audience at the right time with the right creative.</p>
              </div>
            </div>
          </div>

          <div class="tabs__panel" id="panel-reporting" role="tabpanel" aria-labelledby="tab-reporting" hidden>
            <div class="tabs__panel-grid">
              <div class="tabs__panel-image">
                <img src="/images/tab-reporting.jpg" alt="Transparent reporting dashboard with real-time performance data" loading="lazy" width="560" height="380">
              </div>
              <div class="tabs__panel-content">
                <h3>Full Visibility Into Performance</h3>
                <p>No black boxes. Our clients receive real-time access to campaign performance through custom dashboards built on Google Cloud. We report on the metrics that matter to your business and provide actionable insights that keep your strategy evolving.</p>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>


    <!-- ============================================
         TESTIMONIAL SECTION
         ============================================ -->
    <section class="testimonial" aria-label="Client testimonial">
      <div class="container testimonial__inner fade-in-up">

        <blockquote class="testimonial__quote">
          <p>&ldquo;It is rare to find an external partner as good as Found Search Marketing. They combine deep platform expertise with genuine strategic thinking, and their transparency sets them apart from every other agency we&rsquo;ve worked with.&rdquo;</p>
        </blockquote>

        <div class="testimonial__attribution">
          <div class="testimonial__avatar">
            <img src="/images/testimonial-marcus-dennis.jpg" alt="Marcus Dennis, Roche" loading="lazy" width="64" height="64">
          </div>
          <div class="testimonial__meta">
            <cite class="testimonial__name">Marcus Dennis</cite>
            <span class="testimonial__role">Roche</span>
          </div>
        </div>

        <div class="testimonial__badge">
          <img src="/images/ibj-badge.png" alt="Indianapolis Business Journal Award Badge" loading="lazy" width="120" height="60">
        </div>

      </div>
    </section>


    <!-- ============================================
         PARTNERSHIP BADGES
         ============================================ -->
    <section class="partners" aria-label="Technology partnerships">
      <div class="container">
        <div class="partners__grid fade-in-up">
          <div class="partners__badge">
            <img src="/images/partners/google-marketing-platform.png" alt="Google Marketing Platform Partner" loading="lazy" width="160" height="80">
          </div>
          <div class="partners__badge">
            <img src="/images/partners/google-cloud-partner.png" alt="Google Cloud Partner" loading="lazy" width="160" height="80">
          </div>
          <div class="partners__badge">
            <img src="/images/partners/google-partner.png" alt="Google Partner" loading="lazy" width="160" height="80">
          </div>
          <div class="partners__badge">
            <img src="/images/partners/microsoft-premier-elite-2026.png" alt="Microsoft Advertising Premier Elite Partner 2026" loading="lazy" width="160" height="80">
          </div>
          <div class="partners__badge">
            <img src="/images/partners/meta-business-partner.png" alt="Meta Business Partner" loading="lazy" width="160" height="80">
          </div>
        </div>
      </div>
    </section>


    <!-- ============================================
         CTA BANNER
         ============================================ -->
    <section class="cta-banner" aria-label="Call to action">
      <div class="cta-banner__bg" aria-hidden="true"></div>
      <div class="container cta-banner__inner fade-in-up">
        <h2 class="cta-banner__headline">Let's Find A Solution</h2>
        <a href="/contact-us" class="btn btn--green btn--lg">Start the Conversation</a>
      </div>
    </section>

</BaseLayout>

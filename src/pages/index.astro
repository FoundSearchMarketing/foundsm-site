---
import BaseLayout from '../layouts/BaseLayout.astro';
import Homepage from '../components/home/Homepage.astro';
import { homePageQuery, sanityClient } from '../lib/sanity';
import { mergeHomePageData } from '../lib/homePageData';

const homePageData = await sanityClient.fetch(homePageQuery).catch(() => null);
const homePage = mergeHomePageData(homePageData);
const title = homePage.seoTitle || 'Found Search Marketing | An Enterprise Paid Media Agency';
const description = homePage.seoDescription || 'Trusted by leading brands, Found Search Marketing is an enterprise paid media agency delivering clarity, efficiency, and performance through advanced data-driven solutions.';
const canonical = homePage.canonicalUrl || 'https://foundsm.com/';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "name": "Found Search Marketing",
      "url": "https://foundsm.com",
      "logo": "https://foundsm.com/images/logo.svg",
      "description": "An enterprise paid media agency that drives measurable growth.",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "8475 Nightfall Lane, Suite 200",
        "addressLocality": "Fishers",
        "addressRegion": "IN",
        "postalCode": "46037",
        "addressCountry": "US"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+1-317-721-2229",
        "contactType": "sales",
        "email": "info@foundsm.com"
      },
      "sameAs": [
        "https://www.facebook.com/foundsm/",
        "https://www.instagram.com/found_sm/",
        "https://www.linkedin.com/company/found-search-marketing/",
        "https://x.com/FoundSM"
      ]
    },
    {
      "@type": "WebPage",
      "name": title,
      "url": canonical,
      "description": description,
      "publisher": {
        "@type": "Organization",
        "name": "Found Search Marketing"
      }
    }
  ]
};
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogTitle={homePage.ogTitle}
  ogDescription={homePage.ogDescription}
  ogImage={homePage.ogImage}
  robots={homePage.robots}
  twitterCard={homePage.twitterCard}
  twitterTitle={homePage.twitterTitle}
  twitterDescription={homePage.twitterDescription}
  twitterImage={homePage.twitterImage}
  schema={schema}
  schemaJson={homePage.schemaJson}
  bodyClass="home-page"
>
  <Homepage data={homePage} />
</BaseLayout>

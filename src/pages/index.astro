---
import BaseLayout from '../layouts/BaseLayout.astro';
import Homepage from '../components/home/Homepage.astro';

const description = 'Trusted by leading brands, Found Search Marketing is an enterprise paid media agency delivering clarity, efficiency, and performance through advanced data-driven solutions.';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "name": "Found Search Marketing",
      "url": "https://www.foundsm.com",
      "logo": "https://www.foundsm.com/images/logo.svg",
      "description": "An enterprise paid media agency that drives measurable growth.",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "8475 Nightfall Lane, Suite 200",
        "addressLocality": "Fishers",
        "addressRegion": "IN",
        "postalCode": "46037",
        "addressCountry": "US"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+1-317-721-2229",
        "contactType": "sales",
        "email": "info@foundsm.com"
      },
      "sameAs": [
        "https://www.facebook.com/foundsm/",
        "https://www.instagram.com/found_sm/",
        "https://www.linkedin.com/company/found-search-marketing/",
        "https://x.com/FoundSM"
      ]
    },
    {
      "@type": "WebPage",
      "name": "Found Search Marketing | An Enterprise Paid Media Agency",
      "url": "https://foundsm.com/",
      "description": description,
      "publisher": {
        "@type": "Organization",
        "name": "Found Search Marketing"
      }
    }
  ]
};
---

<BaseLayout
  title="Found Search Marketing | An Enterprise Paid Media Agency"
  description={description}
  canonical="https://foundsm.com/"
  schema={schema}
  bodyClass="home-page"
>
  <Homepage />
</BaseLayout>

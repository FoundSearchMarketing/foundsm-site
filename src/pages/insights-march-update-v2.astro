---
import BaseLayout from '../layouts/BaseLayout.astro';
import ResourceHubPage from '../components/modern/ResourceHubPage.astro';
import { getResourceHubBySlug } from '../data/legacyResources';

const hub = getResourceHubBySlug('insights-march-update-v2');
const title = 'Insights | Found Search Marketing | Enterprise Paid Media Agency';
const canonical = 'https://www.foundsm.com/insights-march-update-v2/';
---

<BaseLayout title={title} description={hub.description} canonical={canonical}>
  <ResourceHubPage hub={hub} />
</BaseLayout>

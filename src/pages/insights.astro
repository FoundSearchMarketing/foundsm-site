---
import BaseLayout from '../layouts/BaseLayout.astro';
import InsightsHero from '../components/InsightsHero.astro';
import LatestPostsSection from '../components/LatestPostsSection.astro';
import InsightsArticlesTabs from '../components/InsightsArticlesTabs.astro';
import InsightsArticleCards from '../components/InsightsArticleCards.astro';
import InsightsPagination from '../components/InsightsPagination.astro';
import { getAllBlogPosts, toInsightsArticleCards, toLatestPostCards } from '../lib/blogPosts';

const posts = getAllBlogPosts();
const latestPosts = toLatestPostCards(posts, 2);
const articleCards = toInsightsArticleCards(posts);
const postsPerPage = 6;
const totalPages = Math.ceil(posts.length / postsPerPage);

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "name": "Found Search Marketing",
      "url": "https://www.foundsm.com",
      "logo": "https://www.foundsm.com/images/logo.svg"
    },
    {
      "@type": "WebPage",
      "name": "Insights | Found Search Marketing",
      "url": "https://www.foundsm.com/insights",
      "description": "Perspectives on paid media, data strategy, and digital marketing from the Found Search Marketing team.",
      "publisher": {
        "@type": "Organization",
        "name": "Found Search Marketing"
      }
    }
  ]
};
---

<BaseLayout
  title="Insights | Found Search Marketing"
  description="Perspectives on paid media, data strategy, and digital marketing from the Found Search Marketing team. Explore insights on AI, analytics, and enterprise advertising."
  canonical="https://www.foundsm.com/insights"
  robots="index, follow"
  schema={schema}
  bodyClass="page--dark-hero"
>

    <!-- ============================================
         HERO SECTION
         ============================================ -->
    <InsightsHero />

    <LatestPostsSection posts={latestPosts} />

    <InsightsArticlesTabs />

    <InsightsArticleCards articles={articleCards} postsPerPage={postsPerPage}>
      <InsightsPagination slot="pagination" pageSize={postsPerPage} totalPages={totalPages} />
    </InsightsArticleCards>

</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import InsightsHero from '../components/InsightsHero.astro';
import LatestPostsSection from '../components/LatestPostsSection.astro';
import InsightsArticlesTabs from '../components/InsightsArticlesTabs.astro';
import InsightsArticleCards from '../components/InsightsArticleCards.astro';
import InsightsPagination from '../components/InsightsPagination.astro';
import { getAllBlogCategories, getAllBlogPosts, getLatestBlogPosts, toInsightsArticleCards, toLatestPostCards } from '../lib/blogPosts';
import { defaultInsightsPageData, mergeInsightsPageData } from '../lib/insightsPageData';
import { insightsPageQuery, sanityClient, urlFor } from '../lib/sanity';

const [sanityPage, posts, categories, latestBlogPosts] = await Promise.all([
  sanityClient.fetch(insightsPageQuery).catch(() => null),
  getAllBlogPosts(),
  getAllBlogCategories(),
  getLatestBlogPosts(2),
]);
const page = mergeInsightsPageData(sanityPage);
const latestPosts = toLatestPostCards(latestBlogPosts);
const articleCards = toInsightsArticleCards(posts);
const articleTabs = [
  { label: 'All', filter: '__all', active: true },
  ...categories.map((category) => ({ label: category.label, filter: category.slug })),
];
const postsPerPage = 6;
const totalPages = Math.ceil(posts.length / postsPerPage);
const pageTitle = page.seoTitle || defaultInsightsPageData.seoTitle;
const pageDescription = page.seoDescription || defaultInsightsPageData.seoDescription;
const canonical = page.canonicalUrl || defaultInsightsPageData.canonicalUrl;
const heroImage = (() => {
  if (!page.hero.image) return undefined;

  try {
    return urlFor(page.hero.image).width(868).height(1218).fit('crop').auto('format').url();
  } catch {
    return undefined;
  }
})();

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "name": "Found Search Marketing",
      "url": "https://www.foundsm.com",
      "logo": "https://www.foundsm.com/images/logo.svg"
    },
    {
      "@type": "WebPage",
      "name": pageTitle,
      "url": canonical,
      "description": pageDescription,
      "publisher": {
        "@type": "Organization",
        "name": "Found Search Marketing"
      }
    }
  ]
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonical}
  robots={page.robots}
  schema={schema}
  bodyClass="page--dark-hero"
>

    <!-- ============================================
         HERO SECTION
         ============================================ -->
    <InsightsHero headline={page.hero.headline} body={page.hero.body} imageSrc={heroImage} imageAlt={page.hero.imageAlt} />

    <LatestPostsSection posts={latestPosts} />

    <InsightsArticlesTabs tabs={articleTabs} />

    <InsightsArticleCards articles={articleCards} postsPerPage={postsPerPage}>
      <InsightsPagination slot="pagination" pageSize={postsPerPage} totalPages={totalPages} />
    </InsightsArticleCards>

</BaseLayout>

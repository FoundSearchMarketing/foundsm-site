---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogPostTemplate from '../../components/BlogPostTemplate.astro';
import { getAllBlogPosts, getBlogPostNavigation, type BlogPost } from '../../lib/blogPosts';

export async function getStaticPaths() {
  const posts = await getAllBlogPosts();

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
const navigation = await getBlogPostNavigation(post.slug);
const canonical = `https://www.foundsm.com/insights/${post.slug}/`;
const description = post.excerpt;
const author = [post.authorName, post.authorTitle].filter(Boolean).join(', ');
const schema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.title,
  description,
  image: post.heroImage,
  datePublished: post.publishedAt,
  dateModified: post.publishedAt,
  ...(author
    ? {
        author: {
          '@type': 'Person',
          name: author,
        },
      }
    : {}),
  publisher: {
    '@type': 'Organization',
    name: 'Found Search Marketing',
    logo: { '@type': 'ImageObject', url: 'https://www.foundsm.com/images/logo.svg' },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
  ...(post.categories.length > 0 ? { articleSection: post.categories.map((category) => category.label) } : {}),
};
---

<BaseLayout
  title={post.seoTitle}
  description={description}
  canonical={canonical}
  ogImage={post.heroImage || undefined}
  ogType="article"
  robots="index, follow"
  schema={schema}
  bodyClass={`blog-post-page blog-post-page--${post.sourceType}`}
>
  <BlogPostTemplate post={post} navigation={navigation} />
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogPostTemplate from '../../components/BlogPostTemplate.astro';
import LegacyPageRenderer from '../../components/legacy/LegacyPageRenderer.astro';
import { getAllBlogPosts, getBlogPostNavigation, type BlogPost } from '../../lib/blogPosts';
import { loadLegacyPages } from '../../lib/legacyPageFetch';
import { getLegacyPageDefinitionsByGroup, pathToSingleSlug, type LegacyPageData } from '../../lib/legacyPageData';

export async function getStaticPaths() {
  const legacyInsightDefinitions = getLegacyPageDefinitionsByGroup('insights');
  const [posts, legacyPages] = await Promise.all([
    getAllBlogPosts(),
    loadLegacyPages(legacyInsightDefinitions),
  ]);

  return [
    ...posts.map((post) => ({
      params: { slug: post.slug },
      props: { post },
    })),
    ...legacyInsightDefinitions.map((definition) => ({
      params: { slug: pathToSingleSlug(definition.path) },
      props: { page: legacyPages.get(definition.path) },
    })),
  ];
}

interface Props {
  post?: BlogPost;
  page?: LegacyPageData;
}

const { post, page } = Astro.props;
const navigation = post ? await getBlogPostNavigation(post.slug) : {};
const canonical = page?.canonicalUrl || post?.canonicalUrl || (post ? `https://foundsm.com/insights/${post.slug}/` : 'https://foundsm.com/insights/');
const description = page?.seoDescription || post?.seoDescription || post?.excerpt || '';
const author = post ? [post.authorName, post.authorTitle].filter(Boolean).join(', ') : '';
const schema = page
  ? {
      '@context': 'https://schema.org',
      '@type': 'WebPage',
      name: page.title,
      url: canonical,
      description,
      publisher: {
        '@type': 'Organization',
        name: 'Found Search Marketing',
      },
    }
  : {
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: post?.title,
      description,
      image: post?.heroImage,
      datePublished: post?.publishedAt,
      dateModified: post?.publishedAt,
      ...(author
        ? {
            author: {
              '@type': 'Person',
              name: author,
            },
          }
        : {}),
      publisher: {
        '@type': 'Organization',
        name: 'Found Search Marketing',
        logo: { '@type': 'ImageObject', url: 'https://foundsm.com/images/logo.svg' },
      },
      mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
      ...(post && post.categories.length > 0 ? { articleSection: post.categories.map((category) => category.label) } : {}),
    };
---

<BaseLayout
  title={page?.seoTitle || post?.seoTitle || 'Insights | Found Search Marketing'}
  description={description}
  canonical={canonical}
  ogTitle={post?.ogTitle}
  ogDescription={post?.ogDescription}
  ogImage={page?.ogImage || post?.ogImage || post?.heroImage || undefined}
  ogType={post ? 'article' : undefined}
  robots={page?.robots || post?.robots || 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'}
  twitterCard={post?.twitterCard}
  twitterTitle={post?.twitterTitle}
  twitterDescription={post?.twitterDescription}
  twitterImage={post?.twitterImage}
  publishedAt={post?.publishedAt}
  modifiedAt={post?.modifiedAt}
  schema={schema}
  schemaJson={post?.schemaJson}
  bodyClass={post ? 'blog-post-page' : 'legacy-page'}
>
  {page ? <LegacyPageRenderer page={page} /> : post && <BlogPostTemplate post={post} navigation={navigation} />}
</BaseLayout>

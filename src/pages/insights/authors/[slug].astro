---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import LegacyPageRenderer from '../../../components/legacy/LegacyPageRenderer.astro';
import LegacyPostList from '../../../components/legacy/LegacyPostList.astro';
import { getAllBlogPosts } from '../../../lib/blogPosts';
import { loadAuthors } from '../../../lib/legacyPageFetch';
import { mergeLegacyPageData, slugifyAuthorName, type LegacyAuthorData } from '../../../lib/legacyPageData';
import { block } from '../../../lib/simplePortableText';

export async function getStaticPaths() {
  const authors = await loadAuthors();

  return authors.map((author) => ({
    params: { slug: author.slug },
    props: { author },
  }));
}

interface Props {
  author: LegacyAuthorData;
}

const { author } = Astro.props;
const posts = (await getAllBlogPosts()).filter((post) => {
  const postAuthorSlug = slugifyAuthorName(post.authorName);
  const authorName = author.name.toLowerCase();
  const postAuthorName = post.authorName.toLowerCase();
  return postAuthorSlug === author.slug || postAuthorSlug.startsWith(`${author.slug}-`) || postAuthorName.startsWith(authorName);
});
const canonical = author.canonicalUrl || `https://foundsm.com/insights/authors/${author.slug}/`;
const description = author.seoDescription || author.bio || `Insights by ${author.name} from Found Search Marketing.`;
const page = mergeLegacyPageData(
  {
    id: `legacy-author-${author.slug}`,
    path: `/insights/authors/${author.slug}/`,
    title: author.name,
    description,
    group: 'authorIndex',
  },
  {
    title: author.name,
    seoTitle: author.seoTitle || `${author.name} | Found Search Marketing`,
    seoDescription: description,
    canonicalUrl: canonical,
    robots: author.robots,
    ogTitle: author.ogTitle,
    ogDescription: author.ogDescription,
    ogImage: author.ogImage,
    twitterCard: author.twitterCard,
    twitterTitle: author.twitterTitle,
    twitterDescription: author.twitterDescription,
    twitterImage: author.twitterImage,
    schemaJson: author.schemaJson,
    hero: {
      eyebrow: 'Author',
      heading: author.name,
      subheading: author.title || description,
    },
    body: [block(description)],
    cards: author.linkedin
      ? [
          {
            title: `Connect with ${author.name}`,
            body: author.title ? [block(author.title)] : undefined,
            cta: { label: 'View LinkedIn', href: author.linkedin },
          },
        ]
      : undefined,
  },
);
const schema = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  name: author.name,
  url: canonical,
  mainEntity: {
    '@type': 'Person',
    name: author.name,
    jobTitle: author.title,
    image: author.image,
    sameAs: author.linkedin ? [author.linkedin] : undefined,
  },
};
---

<BaseLayout
  title={page.seoTitle}
  description={page.seoDescription}
  canonical={page.canonicalUrl}
  ogTitle={page.ogTitle}
  ogDescription={page.ogDescription}
  ogImage={page.ogImage}
  robots={page.robots}
  twitterCard={page.twitterCard}
  twitterTitle={page.twitterTitle}
  twitterDescription={page.twitterDescription}
  twitterImage={page.twitterImage}
  schema={schema}
  schemaJson={page.schemaJson}
  bodyClass="legacy-page"
>
  <LegacyPageRenderer page={page}>
    <LegacyPostList posts={posts} heading={`Insights by ${author.name}`} emptyText="No posts are published for this author yet." />
  </LegacyPageRenderer>
</BaseLayout>

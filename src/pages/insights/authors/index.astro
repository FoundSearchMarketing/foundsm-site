---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import LegacyPageRenderer from '../../../components/legacy/LegacyPageRenderer.astro';
import { loadAuthors, loadLegacyPage } from '../../../lib/legacyPageFetch';
import { getLegacyPageDefinitionByPath } from '../../../lib/legacyPageData';

const authorIndexDefinition = getLegacyPageDefinitionByPath('/insights/authors/');
if (!authorIndexDefinition) throw new Error('Missing legacy page definition for /insights/authors/.');

const [page, authors] = await Promise.all([
  loadLegacyPage(authorIndexDefinition),
  loadAuthors(),
]);
---

<BaseLayout
  title={page.seoTitle}
  description={page.seoDescription}
  canonical={page.canonicalUrl}
  ogImage={page.ogImage}
  robots={page.robots}
  bodyClass="legacy-page"
>
  <LegacyPageRenderer page={page}>
    <section class="author-directory" aria-label="Authors">
      <div class="author-directory__grid">
        {authors.map((author) => (
          <article class="author-card">
            <a href={`/insights/authors/${author.slug}/`} class="author-card__image" aria-label={author.name}>
              {author.image ? (
                <img src={author.image} alt={author.name} loading="lazy" width="240" height="240" />
              ) : (
                <span>{author.name.slice(0, 1)}</span>
              )}
            </a>
            <div>
              <h2><a href={`/insights/authors/${author.slug}/`}>{author.name}</a></h2>
              {author.title && <p class="author-card__role">{author.title}</p>}
              {author.bio && <p class="author-card__bio">{author.bio}</p>}
            </div>
          </article>
        ))}
      </div>
    </section>
  </LegacyPageRenderer>
</BaseLayout>

<style>
  .author-directory {
    margin-top: var(--space-xl);
  }

  .author-directory__grid {
    display: grid;
    gap: var(--space-lg);
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 16rem), 1fr));
  }

  .author-card {
    background: var(--color-surface-muted);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius);
    display: grid;
    gap: var(--space-md);
    padding: var(--space-lg);
  }

  .author-card__image {
    align-items: center;
    aspect-ratio: 1;
    background: var(--color-dark);
    border-radius: var(--radius);
    color: var(--color-primary);
    display: flex;
    font-family: var(--font-heading);
    font-size: 3rem;
    justify-content: center;
    overflow: hidden;
    width: 6rem;
  }

  .author-card__image img {
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .author-card h2 {
    font-size: 1.35rem;
  }

  .author-card h2 a:hover {
    color: var(--color-primary);
  }

  .author-card__role,
  .author-card__bio {
    color: var(--color-mid);
    margin-top: var(--space-xs);
  }
</style>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import InsightResourcePage from '../../components/legacy/InsightResourcePage.astro';
import { blogArchivePage } from '../../lib/insightResourceContent';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: blogArchivePage.title,
  url: blogArchivePage.canonicalUrl,
  description: blogArchivePage.seoDescription,
  publisher: {
    '@type': 'Organization',
    name: 'Found Search Marketing',
  },
};
---

<BaseLayout
  title={blogArchivePage.seoTitle}
  description={blogArchivePage.seoDescription}
  canonical={blogArchivePage.canonicalUrl}
  ogImage={blogArchivePage.ogImage}
  robots="index, nofollow, max-image-preview:none, max-snippet:-1, max-video-preview:-1, noimageindex"
  schema={schema}
>
  <InsightResourcePage page={blogArchivePage} />
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ResourceVideoPage from '../../components/modern/ResourceVideoPage.astro';
import { getVideoPageBySlug } from '../../data/legacyResources';

const page = getVideoPageBySlug('webinar');
const canonical = 'https://www.foundsm.com/insights/webinar/';
---

<BaseLayout title={page.seoTitle} description={page.description} canonical={canonical}>
  <ResourceVideoPage page={page} />
</BaseLayout>

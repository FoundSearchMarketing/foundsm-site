---
import BaseLayout from '../layouts/BaseLayout.astro';
import WordPressMatchPage from '../components/wordpress/WordPressMatchPage.astro';
import { formPageQuery, sanityClient } from '../lib/sanity';
import { defaultNewsletterPageData, mergeFormPageData } from '../lib/morePageData';

const sanityPage = await sanityClient.fetch(formPageQuery, { id: 'newsletterPage' }).catch(() => null);
const page = mergeFormPageData(defaultNewsletterPageData, sanityPage);
const title = page.seoTitle || defaultNewsletterPageData.seoTitle;
const description = page.seoDescription || defaultNewsletterPageData.seoDescription;
const canonical = page.canonicalUrl || defaultNewsletterPageData.canonicalUrl;
const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  url: canonical,
  description,
  publisher: {
    '@type': 'Organization',
    name: 'Found Search Marketing',
    url: 'https://www.foundsm.com',
  },
};
---

<BaseLayout title={title} description={description} canonical={canonical} robots={page.robots} schema={schema}>
  <WordPressMatchPage variant="newsletter" />
</BaseLayout>

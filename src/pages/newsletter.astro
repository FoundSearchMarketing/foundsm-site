---
import BaseLayout from '../layouts/BaseLayout.astro';
import FormLanding from '../components/modern/FormLanding.astro';

const title = "Sign Up For Found's Newsletter";
const description = 'Found Search Marketing brings deep channel expertise, custom analytics, and agile strategy together to maximize performance across your entire media ecosystem.';
const canonical = 'https://www.foundsm.com/newsletter';
const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  url: canonical,
  description,
  publisher: {
    '@type': 'Organization',
    name: 'Found Search Marketing',
    url: 'https://www.foundsm.com',
  },
};
---

<BaseLayout title={title} description={description} canonical={canonical} schema={schema}>
  <FormLanding
    variant="newsletter"
    eyebrow="Get Found in Your Inbox"
    title="Sign Up for Our Newsletter"
    intro="Get monthly insights, real-world strategies, and expert takes from the Found team."
    formId="f757bd34-b8c5-4f2a-a1ef-19c3a364683b"
    summary="Get monthly insights, real-world strategies, and expert takes from the Found team - plus the latest on upcoming events and recaps on any you missed."
  />
</BaseLayout>

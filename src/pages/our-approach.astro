---
import BaseLayout from '../layouts/BaseLayout.astro';
import { approachPageQuery, sanityClient } from '../lib/sanity';
import { defaultApproachPageData, mergeApproachPageData } from '../lib/morePageData';
import { richHtml, srcFor } from '../lib/fixedPageRender';

const assetPath = '/images/pages/our-approach';

const sanityPage = await sanityClient.fetch(approachPageQuery).catch(() => null);
const page = mergeApproachPageData(sanityPage);
const title = page.seoTitle || defaultApproachPageData.seoTitle;
const description = page.seoDescription || defaultApproachPageData.seoDescription;
const canonical = page.canonicalUrl || defaultApproachPageData.canonicalUrl;
const heroImage = srcFor(page.hero.image);
const introImage = srcFor(page.intro.image);
const defaultAdvantageIcons = [
  'icon-difference-1.svg',
  'icon-difference-2.svg',
  'icon-difference-3.svg',
  'icon-difference-4.svg',
  'icon-difference-5.svg',
  'icon-difference-6.svg',
  'icon-difference-7.svg',
  'icon-difference-8.svg',
];
const advantages = page.advantages.items.map((item, index) => ({
  ...item,
  iconSrc: srcFor(item.icon) || `${assetPath}/${defaultAdvantageIcons[index]}`,
}));
const advantageColumns = [
  advantages.slice(0, 4),
  advantages.slice(4),
];
const partnershipTabs = page.partnerships.tabs.map((tab) => ({
  ...tab,
  imageSrc: srcFor(tab.image),
}));
const linesFor = (value?: string, fallback: string[] = []) => value?.split('\n').filter(Boolean) || fallback;
const heroHeadingLines = linesFor(page.hero.heading);
const introHeadingLines = linesFor(page.intro.heading, page.intro.headingLines);

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "url": canonical,
  "description": description,
  "publisher": {
    "@type": "Organization",
    "name": "Found Search Marketing",
    "url": "https://foundsm.com",
    "logo": "https://foundsm.com/images/logo.svg"
  }
};
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  robots={page.robots}
  schema={schema}
>
  <div class="approach-page">
    <section class="approach-hero" aria-labelledby="approach-hero-title">
      <div class:list={['approach-shell', 'approach-hero__grid', !heroImage && 'approach-hero__grid--without-media']}>
        <div class="approach-hero__copy">
          <h1 id="approach-hero-title">
            {heroHeadingLines.map((line, index) => (
              <Fragment>{index > 0 && <br />}{line}</Fragment>
            ))}
          </h1>
          <div class="approach-hero__intro" set:html={richHtml(page.hero.body)} />
        </div>

        {heroImage && (
          <figure class="approach-hero__media" aria-hidden={page.hero.imageAlt ? undefined : 'true'}>
            <img
              src={heroImage}
              alt={page.hero.imageAlt || ''}
              width="692"
              height="722"
              loading="eager"
              decoding="async"
            />
          </figure>
        )}
      </div>
    </section>

    <section class="approach-intro" aria-labelledby="approach-intro-title">
      <div class="approach-shell">
        {page.intro.eyebrow && <p class="approach-eyebrow">{page.intro.eyebrow}</p>}
        <h2 id="approach-intro-title">
          {introHeadingLines.map((line, index) => (
            <Fragment>{index > 0 && <br />}{line}</Fragment>
          ))}
        </h2>

        <div class:list={['approach-intro__grid', !introImage && 'approach-intro__grid--without-media']}>
          <div class="approach-intro__copy" set:html={richHtml(page.intro.body)} />

          {introImage && (
            <figure class="approach-intro__media" aria-hidden={page.intro.imageAlt ? undefined : 'true'}>
              <img
                src={introImage}
                alt={page.intro.imageAlt || ''}
                width="424"
                height="401"
                loading="lazy"
                decoding="async"
              />
            </figure>
          )}
        </div>
      </div>
    </section>

    <section class="approach-callout" aria-label="Approach callout">
      <div class="approach-shell approach-callout__grid">
        <h2>{page.callout.heading}</h2>
        <div class="approach-callout__action">
          {page.callout.cta?.label && page.callout.cta?.href && <a class="btn btn--green btn--lg" href={page.callout.cta.href}>{page.callout.cta.label}</a>}
        </div>
      </div>
    </section>

    <section class="approach-advantages" aria-labelledby="approach-advantages-title">
      <div class="approach-shell">
        <div class="approach-section-header approach-section-header--center">
          {page.advantages.eyebrow && <p class="approach-eyebrow">{page.advantages.eyebrow}</p>}
          <h2 id="approach-advantages-title">{page.advantages.heading}</h2>
          <div class="approach-section-header__body" set:html={richHtml(page.advantages.body)} />
        </div>

        <div class="approach-advantages__accordion" data-approach-accordion>
          {advantageColumns.map((column, columnIndex) => (
            <div class="approach-advantages__column">
              {column.map((item, itemIndex) => {
                const index = columnIndex * 4 + itemIndex;
                const isOpen = index === 0;
                const panelId = `approach-advantage-panel-${index + 1}`;
                const triggerId = `approach-advantage-trigger-${index + 1}`;

                return (
                  <article class:list={['approach-advantages__item', isOpen && 'is-open']}>
                    <div class="approach-advantages__rail" aria-hidden="true"><span></span></div>
                    <h3>
                      <button
                        class="approach-advantages__trigger"
                        id={triggerId}
                        type="button"
                        aria-expanded={isOpen ? 'true' : 'false'}
                        aria-controls={panelId}
                        data-advantage-trigger
                      >
                        {item.title}
                      </button>
                    </h3>
                    <div
                      class="approach-advantages__panel"
                      id={panelId}
                      role="region"
                      aria-labelledby={triggerId}
                      hidden={!isOpen}
                    >
                      <img
                        src={item.iconSrc}
                        alt=""
                        width="50"
                        height="50"
                        loading="lazy"
                        decoding="async"
                      />
                      <div set:html={richHtml(item.body)} />
                    </div>
                  </article>
                );
              })}
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="approach-partnerships" aria-labelledby="approach-partnerships-title">
      <div class="approach-shell">
        <div class="approach-section-header approach-section-header--center">
          {page.partnerships.eyebrow && <p class="approach-eyebrow">{page.partnerships.eyebrow}</p>}
          <h2 id="approach-partnerships-title" class="approach-partnerships__lede">
            {(page.partnerships.headingLines || []).map((line, index) => (
              <Fragment>{index > 0 && <br />}{line}</Fragment>
            ))}
          </h2>
          <div class="approach-section-header__body" set:html={richHtml(page.partnerships.body)} />
        </div>

        <div class="approach-partnerships__tabs" data-approach-tabs>
          <div class="approach-partnerships__tablist" role="tablist" aria-label="Partnership benefits">
            {partnershipTabs.map((tab, index) => {
              const isSelected = index === 0;

              return (
                <button
                  class="approach-partnerships__tab"
                  id={`approach-partnership-tab-${index + 1}`}
                  type="button"
                  role="tab"
                  aria-selected={isSelected ? 'true' : 'false'}
                  aria-controls={`approach-partnership-panel-${index + 1}`}
                  tabindex={isSelected ? '0' : '-1'}
                  data-partnership-tab
                >
                  <span class="approach-partnerships__tab-rail" aria-hidden="true"><span></span></span>
                  <span>{tab.label}</span>
                </button>
              );
            })}
          </div>

          <div class="approach-partnerships__panels">
            {partnershipTabs.map((tab, index) => {
              const isSelected = index === 0;

              return (
                <section
                  class:list={['approach-partnerships__panel', !tab.imageSrc && 'approach-partnerships__panel--without-badge', isSelected && 'is-active']}
                  id={`approach-partnership-panel-${index + 1}`}
                  role="tabpanel"
                  aria-labelledby={`approach-partnership-tab-${index + 1}`}
                  aria-hidden={!isSelected ? 'true' : undefined}
                  hidden={!isSelected}
                  data-partnership-panel
                >
                  <div class="approach-partnerships__panel-copy">
                    <h3>{tab.heading || tab.label}</h3>
                    <div set:html={richHtml(tab.body)} />
                  </div>
                  {tab.imageSrc && (
                    <div class="approach-partnerships__badge">
                      <img
                        src={tab.imageSrc}
                        alt={tab.imageAlt || tab.label || ''}
                        loading="lazy"
                        decoding="async"
                      />
                    </div>
                  )}
                </section>
              );
            })}
          </div>

          <div class="approach-partnerships__cta">
            <h3>
              {(page.partnerships.ctaHeadingLines || []).map((line, index) => (
                <Fragment>{index > 0 && <br />}{line}</Fragment>
              ))}
            </h3>
            <span aria-hidden="true"></span>
            {page.partnerships.cta?.label && page.partnerships.cta?.href && <a class="btn btn--green btn--lg" href={page.partnerships.cta.href}>{page.partnerships.cta.label}</a>}
          </div>
        </div>
      </div>
    </section>
  </div>

  <script>
    (() => {
      const root = document.querySelector('.approach-page');
      if (!root) return;

      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      const accordion = root.querySelector('[data-approach-accordion]');
      if (accordion) {
        const triggers = Array.from(accordion.querySelectorAll('[data-advantage-trigger]'));
        const panels = Array.from(accordion.querySelectorAll('.approach-advantages__panel'));
        let resizeFrame = 0;

        const syncAdvantagePanelHeight = () => {
          const openTrigger = triggers.find((trigger) => trigger.getAttribute('aria-expanded') === 'true');
          const openPanelId = openTrigger?.getAttribute('aria-controls') || panels[0]?.id;

          panels.forEach((panel) => {
            panel.hidden = false;
            panel.style.removeProperty('height');
            panel.style.removeProperty('overflow');
            panel.style.removeProperty('opacity');
          });

          const maxHeight = Math.max(...panels.map((panel) => panel.scrollHeight));
          if (Number.isFinite(maxHeight) && maxHeight > 0) {
            accordion.style.setProperty('--approach-advantages-panel-height', `${Math.ceil(maxHeight)}px`);
          }

          panels.forEach((panel) => {
            panel.hidden = panel.id !== openPanelId;
          });
        };

        const queueAdvantagePanelSync = () => {
          if (resizeFrame) window.cancelAnimationFrame(resizeFrame);
          resizeFrame = window.requestAnimationFrame(() => {
            resizeFrame = 0;
            syncAdvantagePanelHeight();
          });
        };

        const finishPanelTransition = (panel) => {
          panel.style.removeProperty('opacity');
        };

        const animatePanel = (panel, shouldOpen) => {
          if (prefersReducedMotion) {
            panel.hidden = !shouldOpen;
            finishPanelTransition(panel);
            return;
          }

          if (shouldOpen) {
            panel.hidden = false;
            panel.style.opacity = '0';
            panel.offsetHeight;
            panel.style.opacity = '1';

            const onOpenEnd = (event) => {
              if (event.target !== panel || event.propertyName !== 'opacity') return;
              panel.removeEventListener('transitionend', onOpenEnd);
              finishPanelTransition(panel);
            };

            panel.addEventListener('transitionend', onOpenEnd);
            return;
          }

          panel.hidden = true;
          finishPanelTransition(panel);
        };

        const setAdvantageOpen = (trigger, shouldOpen) => {
          const item = trigger.closest('.approach-advantages__item');
          const panelId = trigger.getAttribute('aria-controls');
          const panel = panelId ? document.getElementById(panelId) : null;

          if (!item || !panel) return;
          if (trigger.getAttribute('aria-expanded') === String(shouldOpen)) return;

          item.classList.toggle('is-open', shouldOpen);
          trigger.setAttribute('aria-expanded', String(shouldOpen));
          animatePanel(panel, shouldOpen);
        };

        triggers.forEach((trigger) => {
          trigger.addEventListener('click', () => {
            triggers.forEach((otherTrigger) => {
              setAdvantageOpen(otherTrigger, otherTrigger === trigger);
            });
          });
        });

        syncAdvantagePanelHeight();
        document.fonts?.ready?.then(syncAdvantagePanelHeight);
        window.addEventListener('resize', queueAdvantagePanelSync, { passive: true });
      }

      const tabsRoot = root.querySelector('[data-approach-tabs]');
      if (tabsRoot) {
        const tabs = Array.from(tabsRoot.querySelectorAll('[data-partnership-tab]'));
        const panels = Array.from(tabsRoot.querySelectorAll('[data-partnership-panel]'));

        const activateTab = (tab) => {
          const panelId = tab.getAttribute('aria-controls');
          const activePanel = panels.find((panel) => panel.classList.contains('is-active'));
          const nextPanel = panels.find((panel) => panel.id === panelId);

          if (!nextPanel || activePanel === nextPanel) return;

          tabs.forEach((candidate) => {
            const isSelected = candidate === tab;
            candidate.setAttribute('aria-selected', String(isSelected));
            candidate.setAttribute('tabindex', isSelected ? '0' : '-1');
          });

          if (activePanel) {
            activePanel.classList.remove('is-active');
            activePanel.setAttribute('aria-hidden', 'true');

            if (prefersReducedMotion) {
              activePanel.hidden = true;
            } else {
              window.setTimeout(() => {
                if (!activePanel.classList.contains('is-active')) activePanel.hidden = true;
              }, 320);
            }
          }

          nextPanel.hidden = false;
          nextPanel.removeAttribute('aria-hidden');
          nextPanel.offsetHeight;
          nextPanel.classList.add('is-active');
        };

        tabs.forEach((tab, index) => {
          tab.addEventListener('click', () => activateTab(tab));

          tab.addEventListener('keydown', (event) => {
            if (!['ArrowDown', 'ArrowRight', 'ArrowUp', 'ArrowLeft', 'Home', 'End'].includes(event.key)) {
              return;
            }

            event.preventDefault();
            let nextIndex = index;

            if (event.key === 'Home') {
              nextIndex = 0;
            } else if (event.key === 'End') {
              nextIndex = tabs.length - 1;
            } else if (event.key === 'ArrowUp' || event.key === 'ArrowLeft') {
              nextIndex = (index - 1 + tabs.length) % tabs.length;
            } else {
              nextIndex = (index + 1) % tabs.length;
            }

            const nextTab = tabs[nextIndex];
            nextTab.focus();
            activateTab(nextTab);
          });
        });
      }
    })();
  </script>

  <style>
    .approach-page {
      --approach-color-text: #231f20;
      --approach-color-muted: #f2f3f2;
      --approach-color-green: #8dc63f;
      --approach-color-green-hover: #b9dc89;
      --approach-h1-size: 3.75rem;
      --approach-h1-line-height: 4.0625rem;
      --approach-h2-size: 2.5rem;
      --approach-h2-line-height: 2.75rem;
      --approach-h3-size: 2.5rem;
      --approach-h3-line-height: 2.75rem;
      --approach-callout-size: 1.5rem;
      --approach-callout-line-height: 2rem;
      --approach-eyebrow-size: 1.25rem;
      --approach-eyebrow-line-height: 1.75rem;
      --approach-body-size: 1.25rem;
      --approach-body-line-height: 1.8;
      --approach-control-size: 1.25rem;
      --approach-control-line-height: 2rem;
      --approach-button-size: 1.25rem;
      --approach-button-line-height: 1.5rem;
      background: var(--color-white);
      color: var(--approach-color-text);
      overflow-x: clip;
    }

    .approach-shell {
      inline-size: min(calc(100% - (2 * var(--page-gutter))), var(--content-max-width));
      margin-inline: auto;
    }

    .approach-eyebrow {
      margin: 0 0 1.25rem;
      color: var(--approach-color-text);
      font-size: var(--approach-eyebrow-size);
      font-weight: 300;
      line-height: var(--approach-eyebrow-line-height);
      letter-spacing: 0;
      text-transform: uppercase;
    }

    .approach-section-header {
      max-inline-size: 58rem;
      margin-inline: auto;
    }

    .approach-section-header--center {
      text-align: center;
    }

    .approach-section-header h2 {
      margin: 0;
      color: var(--approach-color-text);
      font-size: var(--approach-h2-size);
      font-weight: 900;
      line-height: var(--approach-h2-line-height);
      letter-spacing: 0;
    }

    .approach-section-header p:not(.approach-eyebrow),
    .approach-section-header__body {
      margin: 1.5rem auto 0;
      max-inline-size: 48rem;
      color: var(--approach-color-text);
      font-size: var(--approach-body-size);
      font-weight: 400;
      line-height: var(--approach-body-line-height);
    }

    .approach-hero {
      padding-block: 6.25rem 3.125rem;
      background: var(--color-white);
    }

    .approach-hero__grid {
      display: grid;
      grid-template-columns: minmax(0, 1.25fr) minmax(22rem, 0.75fr);
      align-items: center;
      gap: 3.4375rem;
    }

    .approach-hero__grid--without-media {
      grid-template-columns: minmax(0, 1fr);
    }

    .approach-hero__copy {
      display: grid;
      gap: 1.5rem;
      max-inline-size: 57rem;
    }

    .approach-hero h1 {
      margin: 0;
      color: var(--approach-color-text);
      font-size: var(--approach-h1-size);
      font-weight: 900;
      line-height: var(--approach-h1-line-height);
      letter-spacing: 0;
    }

    .approach-hero__intro {
      max-inline-size: 50rem;
    }

    .approach-hero__intro p {
      margin: 0;
      color: var(--approach-color-text);
      font-size: var(--approach-body-size);
      font-weight: 400;
      line-height: var(--approach-body-line-height);
    }

    .approach-hero__intro p + p {
      margin-block-start: 1rem;
    }

    .approach-hero__media {
      min-block-size: 42vh;
      overflow: hidden;
      border-radius: 2.5rem;
      background: var(--color-surface-muted);
    }

    .approach-hero__media img {
      inline-size: 100%;
      block-size: 100%;
      min-block-size: 42vh;
      object-fit: cover;
      object-position: center;
    }

    .approach-intro {
      position: relative;
      isolation: isolate;
      margin-block-start: 3.125rem;
      padding-block: 6.25rem;
      overflow: hidden;
      background: var(--approach-color-muted);
    }

    .approach-intro::before {
      position: absolute;
      inset: 0;
      z-index: 0;
      background: url('/images/pages/our-approach/topography-light.svg') center / cover no-repeat;
      content: '';
    }

    .approach-intro > .approach-shell {
      position: relative;
      z-index: 1;
    }

    .approach-intro .approach-eyebrow,
    .approach-intro h2 {
      text-align: center;
    }

    .approach-intro h2 {
      margin: 0;
      color: var(--approach-color-text);
      font-size: var(--approach-h2-size);
      font-weight: 900;
      line-height: var(--approach-h2-line-height);
      letter-spacing: 0;
    }

    .approach-intro__grid {
      display: grid;
      grid-template-columns: minmax(0, 2fr) minmax(16rem, 1fr);
      align-items: center;
      gap: 3.125rem;
      margin-block-start: 3.75rem;
      padding-inline: 0.625rem;
    }

    .approach-intro__grid--without-media {
      grid-template-columns: minmax(0, 1fr);
    }

    .approach-intro__copy p {
      margin: 0;
      color: var(--approach-color-text);
      font-size: var(--approach-body-size);
      font-weight: 400;
      line-height: var(--approach-body-line-height);
    }

    .approach-intro__media {
      overflow: hidden;
      border-radius: 2.5rem;
      background: var(--color-white);
    }

    .approach-intro__media img {
      inline-size: 100%;
      block-size: 22.125rem;
      object-fit: cover;
      object-position: center;
    }

    .approach-callout {
      position: relative;
      isolation: isolate;
      padding-block: 3.125rem 2.5rem;
      overflow: hidden;
      background: var(--approach-color-text);
      color: var(--color-white);
    }

    .approach-callout::before {
      position: absolute;
      inset: 0;
      z-index: 0;
      background:
        var(--approach-color-text)
        url('/images/pages/our-approach/contact-bg-fc.svg') center / cover no-repeat;
      content: '';
    }

    .approach-callout > .approach-shell {
      position: relative;
      z-index: 1;
    }

    .approach-callout__grid {
      display: grid;
      grid-template-columns: minmax(0, 3fr) minmax(14rem, 2fr);
      align-items: center;
      gap: 3.125rem;
      padding-inline: 3.75rem;
    }

    .approach-callout h2 {
      margin: 0;
      color: var(--color-white);
      font-family: var(--font-body);
      font-size: var(--approach-callout-size);
      font-weight: 700;
      line-height: var(--approach-callout-line-height);
      letter-spacing: 0;
    }

    .approach-callout__action {
      display: flex;
      justify-content: flex-end;
    }

    .approach-callout .btn,
    .approach-partnerships__cta .btn {
      border-radius: 2.1875rem;
      background: var(--approach-color-green);
      color: var(--approach-color-text);
      font-size: var(--approach-button-size);
      font-weight: 500;
      line-height: var(--approach-button-line-height);
      padding: 1.125rem 2.8125rem;
    }

    .approach-callout .btn:hover,
    .approach-partnerships__cta .btn:hover {
      background: var(--approach-color-green-hover);
    }

    .approach-advantages {
      position: relative;
      isolation: isolate;
      padding-block: 6.25rem;
      overflow: hidden;
      background: var(--approach-color-muted);
    }

    .approach-advantages::before {
      position: absolute;
      inset: 0;
      z-index: 0;
      background: url('/images/pages/our-approach/streets-light.svg') center / cover no-repeat;
      content: '';
      opacity: 0.5;
    }

    .approach-advantages > .approach-shell {
      position: relative;
      z-index: 1;
    }

    .approach-advantages__accordion {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 6.25rem;
      margin-block-start: 6.25rem;
    }

    .approach-advantages__column {
      display: grid;
      align-content: start;
      gap: 1.5625rem;
    }

    .approach-advantages__item {
      position: relative;
      padding: 0.625rem 1.25rem 0.625rem 2.1875rem;
    }

    .approach-advantages__rail {
      position: absolute;
      inset-block: 0;
      inset-inline-start: 0.3125rem;
      inline-size: 0.375rem;
      overflow: hidden;
      border-radius: 999px;
      background: rgba(35, 31, 32, 0.15);
    }

    .approach-advantages__rail span {
      position: absolute;
      inset-inline: 0;
      inset-block-end: 0;
      block-size: 0;
      border-radius: inherit;
      background: var(--approach-color-text);
      transition: block-size var(--transition-base);
    }

    .approach-advantages__item.is-open .approach-advantages__rail span {
      block-size: 100%;
    }

    .approach-advantages__item h3 {
      margin: 0;
      font-family: var(--font-body);
      font-size: var(--approach-control-size);
      font-weight: 700;
      line-height: var(--approach-control-line-height);
      letter-spacing: 0;

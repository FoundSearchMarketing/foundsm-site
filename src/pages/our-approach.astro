---
import BaseLayout from '../layouts/BaseLayout.astro';

const assetPath = '/images/pages/our-approach';

const title = 'Our Proven Paid Media Approach | Found Search Marketing';
const description = 'At Found Search Marketing, our proven paid media approach transforms complex data into actionable insights that fuel smarter strategy and measurable results.';
const canonical = 'https://www.foundsm.com/our-approach';

const advantages = [
  {
    title: '1. Google Background',
    icon: 'icon-difference-1.svg',
    body: 'Our team includes three former Google employees. That means we&rsquo;re not only well versed in the entire Google suite of analytics and paid media channels&mdash;we&rsquo;re also leveraging the latest trends in ad tech. Julie Warnecke, our CEO, was the fourth employee on the Google AdWords Ad Operations team, and has experienced the evolution of digital marketing firsthand.'
  },
  {
    title: '2. Big Picture View',
    icon: 'icon-difference-2.svg',
    body: 'Your performance lead generation ecosystem has lots of interworking parts that need to synergize to create better quality leads. We see your lead generation ecosystem from every angle&mdash;from performance paid media to engineering audience models to creative and landing pages, and beyond&mdash;making sure you&rsquo;re always moving in alignment with your business objectives.'
  },
  {
    title: '3. Singular Focus',
    icon: 'icon-difference-3.svg',
    body: 'We aren&rsquo;t here to help create new logos, build custom fonts, or reposition your branding. We&rsquo;re here to drive leads through performance paid media, protect your brand, and deliver consistent, measurable wins that maximize profitability.'
  },
  {
    title: '4. Uniquely Dedicated People',
    icon: 'icon-difference-4.svg',
    body: 'Not many companies can say their people stay for more than six years on average&mdash;or that they actually love to solve problems without seeking credit. With no hourly billing or upselling, our outcomes-obsessed team focuses solely on delivering measurable results through a transparent, customized, and innovative process.'
  },
  {
    title: '5. Simplicity',
    icon: 'icon-difference-5.svg',
    body: 'A single scope of work and point of contact. Transparent pricing. No hourly billing. We take on the complexity&mdash;whether it&rsquo;s navigating data privacy policies, engineering dashboards, or reconciling media spend&mdash;so our clients can experience simplicity and confidence in every aspect of their campaigns. Bottom line: Our partnership will be simple, agile, and above all, value-and-performance driven.'
  },
  {
    title: '6. Results Without Fluff',
    icon: 'icon-difference-6.svg',
    body: 'Our team doesn&rsquo;t get caught up in vanity metrics, cherry pick the best stats, or build fancy presentations. But we do give you the clearest possible picture of exactly what&rsquo;s working and what isn&rsquo;t with powerful analytics models and custom dashboards&mdash;and we tie everything back to what you&rsquo;re trying to accomplish internally.'
  },
  {
    title: '7. Leading Tech Stack',
    icon: 'icon-difference-7.svg',
    body: 'AI is transforming the way we work. New, more powerful analytics platforms are available almost daily. Methods of data visualization are becoming more intuitive. We&rsquo;re on the leading edge of paid media strategies and we make sure our clients are, too.'
  },
  {
    title: '8. Extreme Customization',
    icon: 'icon-difference-8.svg',
    body: 'We don&rsquo;t like templates. Everything we do is built and customized just for you, because there&rsquo;s no other business exactly like yours. Unique problems need unique solutions&mdash;and an outside, expert perspective focused on your business goals. We&rsquo;re glad you found us.'
  }
];

const advantageColumns = [
  advantages.slice(0, 4),
  advantages.slice(4)
];

const partnershipTabs = [
  {
    label: 'Google Marketing Platform Certified',
    image: 'google-marketing-platform-badge.svg',
    alt: 'Google Marketing Platform Certified',
    body: 'Our team is trained across GMP tools, with decades of experience using the platform. That gives you lots of perks, including early access to Google alpha and beta programs, advanced targeting and measurement strategies, and optimization tools to drive smarter campaigns.'
  },
  {
    label: 'Microsoft Advertising Elite Partner',
    image: 'microsoft-badge-2026.svg',
    alt: 'Microsoft Advertising Elite Partner',
    body: 'Elite Partner status is Microsoft&rsquo;s highest recognition, granted only to a select group of top-performing agencies globally. This status translates to many benefits for you, including exclusive access to new programs, and early visibility into product roadmaps, search trends, and audience insights.'
  },
  {
    label: 'Google Partner',
    image: 'google-partner-badge.svg',
    alt: 'Google Partner',
    body: 'Being named a Google Partner is recognition for maximizing campaign success for our clients by driving growth and demonstrating Google Ads skills and expertise. You can rest assured that many of our team members are certified in Google Ads and its products.'
  },
  {
    label: 'Meta Business Partner',
    image: 'meta-badge.svg',
    alt: 'Meta Business Partner',
    body: 'Earning a partnership with Meta means doing more than just demonstrating excellence across Meta platforms. It means giving our clients early access to Meta alpha and beta programs, a direct connection to Meta&rsquo;s evolving roadmap, and assurance that our team is leveraging exclusive tools that drive higher-performing campaigns.'
  },
  {
    label: 'OneTrust Privacy Professional',
    image: 'onetrust-privacy-professional.png',
    alt: 'OneTrust Privacy Professional',
    body: 'At Found, we have a deep understanding of how privacy impacts marketing. As a certified OneTrust partner, we bring expertise in privacy, security, and data governance&mdash;empowering your organization to confidently navigate today&rsquo;s complex regulatory landscape.'
  }
];

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "url": canonical,
  "description": description,
  "publisher": {
    "@type": "Organization",
    "name": "Found Search Marketing",
    "url": "https://www.foundsm.com",
    "logo": "https://www.foundsm.com/images/logo.svg"
  }
};
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  schema={schema}
>
  <div class="approach-page">
    <section class="approach-hero" aria-labelledby="approach-hero-title">
      <div class="approach-shell approach-hero__grid">
        <div class="approach-hero__copy">
          <h1 id="approach-hero-title">It&rsquo;s Not What We Do.<br />It&rsquo;s How We Do It.</h1>
          <div class="approach-hero__intro">
            <p>Found Search Marketing exists because we saw a need for a new kind of agency. One that not only had background in the industry with an expert understanding of paid media, but that could also serve as a true extension of client teams through creative problem solving and customized solutions.</p>
            <p>We&rsquo;ve used that formula for nearly two decades to consistently build strategies and campaigns that convert, while driving maximum profitability for our clients.</p>
          </div>
        </div>

        <figure class="approach-hero__media" aria-hidden="true">
          <img
            src={`${assetPath}/hero-approach-matt.webp`}
            alt=""
            width="692"
            height="722"
            loading="eager"
            decoding="async"
          />
        </figure>
      </div>
    </section>

    <section class="approach-intro" aria-labelledby="approach-intro-title">
      <div class="approach-shell">
        <p class="approach-eyebrow">Our Approach</p>
        <h2 id="approach-intro-title">Your Search for an<br />Unfair Advantage is Over</h2>

        <div class="approach-intro__grid">
          <div class="approach-intro__copy">
            <p>Over the past 20 years, we&rsquo;ve perfected a unique, proprietary approach that has consistently elevated performance for many top brands, driving measurable results and sustained growth. It works by combining first-party data, automation, innovative bid strategies, custom playbook formulation, audience modeling, and a unique understanding of our client&rsquo;s paid media ecosystem. Our approach is a fully custom, self-reinforcing optimization cycle designed to achieve predictable and profitable outcomes while relentlessly eliminating paid media waste.</p>
          </div>

          <figure class="approach-intro__media" aria-hidden="true">
            <img
              src={`${assetPath}/approach.webp`}
              alt=""
              width="424"
              height="401"
              loading="lazy"
              decoding="async"
            />
          </figure>
        </div>
      </div>
    </section>

    <section class="approach-callout" aria-label="Approach callout">
      <div class="approach-shell approach-callout__grid">
        <h2>Every piece of your lead generation ecosystem complementing another&mdash;perpetually adapting and improving with each iteration&mdash;is what our formula is all about.</h2>
        <div class="approach-callout__action">
          <a class="btn btn--green btn--lg" href="/contact-us/">Start the Conversation</a>
        </div>
      </div>
    </section>

    <section class="approach-advantages" aria-labelledby="approach-advantages-title">
      <div class="approach-shell">
        <div class="approach-section-header approach-section-header--center">
          <p class="approach-eyebrow">The Found Difference</p>
          <h2 id="approach-advantages-title">Eight Key Advantages</h2>
          <p>We drive value by seamlessly integrating with your team, applying our unique approach, and delivering industry-leading performance that drives customer acquisition at scale. But that&rsquo;s easier said than done. We&rsquo;ll help you succeed with unique competitive edges that put your business goals first.</p>
        </div>

        <div class="approach-advantages__accordion" data-approach-accordion>
          {advantageColumns.map((column, columnIndex) => (
            <div class="approach-advantages__column">
              {column.map((item, itemIndex) => {
                const index = columnIndex * 4 + itemIndex;
                const isOpen = index === 0;
                const panelId = `approach-advantage-panel-${index + 1}`;
                const triggerId = `approach-advantage-trigger-${index + 1}`;

                return (
                  <article class:list={['approach-advantages__item', isOpen && 'is-open']}>
                    <div class="approach-advantages__rail" aria-hidden="true"><span></span></div>
                    <h3>
                      <button
                        class="approach-advantages__trigger"
                        id={triggerId}
                        type="button"
                        aria-expanded={isOpen ? 'true' : 'false'}
                        aria-controls={panelId}
                        data-advantage-trigger
                      >
                        {item.title}
                      </button>
                    </h3>
                    <div
                      class="approach-advantages__panel"
                      id={panelId}
                      role="region"
                      aria-labelledby={triggerId}
                      hidden={!isOpen}
                    >
                      <img
                        src={`${assetPath}/${item.icon}`}
                        alt=""
                        width="50"
                        height="50"
                        loading="lazy"
                        decoding="async"
                      />
                      <p><Fragment set:html={item.body} /></p>
                    </div>
                  </article>
                );
              })}
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="approach-partnerships" aria-labelledby="approach-partnerships-title">
      <div class="approach-shell">
        <div class="approach-section-header approach-section-header--center">
          <p class="approach-eyebrow">Top-Tier Partnerships</p>
          <h2 id="approach-partnerships-title" class="approach-partnerships__lede">Your VIP Access to<br />Premium Benefits</h2>
          <p>We have industry-leading partnerships giving you a huge range of benefits&mdash;which means you can trust your media investment to an agency that&rsquo;s proven to maximize campaign success.</p>
        </div>

        <div class="approach-partnerships__tabs" data-approach-tabs>
          <div class="approach-partnerships__tablist" role="tablist" aria-label="Partnership benefits">
            {partnershipTabs.map((tab, index) => {
              const isSelected = index === 0;

              return (
                <button
                  class="approach-partnerships__tab"
                  id={`approach-partnership-tab-${index + 1}`}
                  type="button"
                  role="tab"
                  aria-selected={isSelected ? 'true' : 'false'}
                  aria-controls={`approach-partnership-panel-${index + 1}`}
                  tabindex={isSelected ? '0' : '-1'}
                  data-partnership-tab
                >
                  <span class="approach-partnerships__tab-rail" aria-hidden="true"><span></span></span>
                  <span>{tab.label}</span>
                </button>
              );
            })}
          </div>

          <div class="approach-partnerships__panels">
            {partnershipTabs.map((tab, index) => {
              const isSelected = index === 0;

              return (
                <section
                  class="approach-partnerships__panel"
                  id={`approach-partnership-panel-${index + 1}`}
                  role="tabpanel"
                  aria-labelledby={`approach-partnership-tab-${index + 1}`}
                  hidden={!isSelected}
                  data-partnership-panel
                >
                  <div class="approach-partnerships__panel-copy">
                    <h3>{tab.label}</h3>
                    <p><Fragment set:html={tab.body} /></p>
                  </div>
                  <div class="approach-partnerships__badge">
                    <img
                      src={`${assetPath}/${tab.image}`}
                      alt={tab.alt}
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                </section>
              );
            })}
          </div>

          <div class="approach-partnerships__cta">
            <h3>Comprehensive Capabilities.<br />Designed for Your Business.</h3>
            <span aria-hidden="true"></span>
            <a class="btn btn--green btn--lg" href="/contact-us/">Let&rsquo;s Find A Solution</a>
          </div>
        </div>
      </div>
    </section>
  </div>

  <script>
    (() => {
      const root = document.querySelector('.approach-page');
      if (!root) return;

      const accordion = root.querySelector('[data-approach-accordion]');
      if (accordion) {
        const triggers = Array.from(accordion.querySelectorAll('[data-advantage-trigger]'));

        const setAdvantageOpen = (trigger, shouldOpen) => {
          const item = trigger.closest('.approach-advantages__item');
          const panelId = trigger.getAttribute('aria-controls');
          const panel = panelId ? document.getElementById(panelId) : null;

          if (!item || !panel) return;

          item.classList.toggle('is-open', shouldOpen);
          trigger.setAttribute('aria-expanded', String(shouldOpen));
          panel.hidden = !shouldOpen;
        };

        triggers.forEach((trigger) => {
          trigger.addEventListener('click', () => {
            triggers.forEach((otherTrigger) => {
              setAdvantageOpen(otherTrigger, otherTrigger === trigger);
            });
          });
        });
      }

      const tabsRoot = root.querySelector('[data-approach-tabs]');
      if (tabsRoot) {
        const tabs = Array.from(tabsRoot.querySelectorAll('[data-partnership-tab]'));
        const panels = Array.from(tabsRoot.querySelectorAll('[data-partnership-panel]'));

        const activateTab = (tab) => {
          const panelId = tab.getAttribute('aria-controls');

          tabs.forEach((candidate) => {
            const isSelected = candidate === tab;
            candidate.setAttribute('aria-selected', String(isSelected));
            candidate.setAttribute('tabindex', isSelected ? '0' : '-1');
          });

          panels.forEach((panel) => {
            panel.hidden = panel.id !== panelId;
          });
        };

        tabs.forEach((tab, index) => {
          tab.addEventListener('click', () => activateTab(tab));

          tab.addEventListener('keydown', (event) => {
            if (!['ArrowDown', 'ArrowRight', 'ArrowUp', 'ArrowLeft', 'Home', 'End'].includes(event.key)) {
              return;
            }

            event.preventDefault();
            let nextIndex = index;

            if (event.key === 'Home') {
              nextIndex = 0;
            } else if (event.key === 'End') {
              nextIndex = tabs.length - 1;
            } else if (event.key === 'ArrowUp' || event.key === 'ArrowLeft') {
              nextIndex = (index - 1 + tabs.length) % tabs.length;
            } else {
              nextIndex = (index + 1) % tabs.length;
            }

            const nextTab = tabs[nextIndex];
            nextTab.focus();
            activateTab(nextTab);
          });
        });
      }
    })();
  </script>

  <style>
    .approach-page {
      --approach-color-text: #231f20;
      --approach-color-muted: #f2f3f2;
      --approach-color-green: #8dc63f;
      --approach-color-green-hover: #b9dc89;
      --approach-h1-size: 3.75rem;
      --approach-h1-line-height: 4.0625rem;
      --approach-h2-size: 2.5rem;
      --approach-h2-line-height: 2.75rem;
      --approach-h3-size: 2.5rem;
      --approach-h3-line-height: 2.75rem;
      --approach-callout-size: 1.5rem;
      --approach-callout-line-height: 2rem;
      --approach-eyebrow-size: 1.25rem;
      --approach-eyebrow-line-height: 1.75rem;
      --approach-body-size: 1.25rem;
      --approach-body-line-height: 1.8;
      --approach-control-size: 1.25rem;
      --approach-control-line-height: 2rem;
      --approach-button-size: 1.25rem;
      --approach-button-line-height: 1.5rem;
      background: var(--color-white);
      color: var(--approach-color-text);
      overflow-x: clip;
    }

    .approach-shell {
      inline-size: min(calc(100% - (2 * var(--page-gutter))), var(--content-max-width));
      margin-inline: auto;
    }

    .approach-eyebrow {
      margin: 0 0 1rem;
      color: var(--approach-color-text);
      font-size: var(--approach-eyebrow-size);
      font-weight: 300;
      line-height: var(--approach-eyebrow-line-height);
      letter-spacing: 0;
      text-transform: uppercase;
    }

    .approach-section-header {
      max-inline-size: 58rem;
      margin-inline: auto;
    }

    .approach-section-header--center {
      text-align: center;
    }

    .approach-section-header h2 {
      margin: 0;
      color: var(--approach-color-text);
      font-size: var(--approach-h2-size);
      font-weight: 900;
      line-height: var(--approach-h2-line-height);
      letter-spacing: 0;
    }

    .approach-section-header p:not(.approach-eyebrow) {
      margin: 1.5rem auto 0;
      max-inline-size: 48rem;
      color: var(--approach-color-text);
      font-size: var(--approach-body-size);
      font-weight: 400;
      line-height: var(--approach-body-line-height);
    }

    .approach-hero {
      padding-block: 6.25rem 3.125rem;
      background: var(--color-white);
    }

    .approach-hero__grid {
      display: grid;
      grid-template-columns: minmax(0, 1.25fr) minmax(22rem, 0.75fr);
      align-items: center;
      gap: 3.4375rem;
    }

    .approach-hero__copy {
      display: grid;
      gap: 1.5rem;
      max-inline-size: 57rem;
    }

    .approach-hero h1 {
      margin: 0;
      color: var(--approach-color-text);
      font-size: var(--approach-h1-size);
      font-weight: 900;
      line-height: var(--approach-h1-line-height);
      letter-spacing: 0;
    }

    .approach-hero__intro {
      max-inline-size: 50rem;
    }

    .approach-hero__intro p {
      margin: 0;
      color: var(--approach-color-text);
      font-size: var(--approach-body-size);
      font-weight: 400;
      line-height: var(--approach-body-line-height);
    }

    .approach-hero__intro p + p {
      margin-block-start: 1rem;
    }

    .approach-hero__media {
      min-block-size: 42vh;
      overflow: hidden;
      border-radius: 2.5rem;
      background: var(--color-surface-muted);
    }

    .approach-hero__media img {
      inline-size: 100%;
      block-size: 100%;
      min-block-size: 42vh;
      object-fit: cover;
      object-position: center;
    }

    .approach-intro {
      position: relative;
      isolation: isolate;
      margin-block-start: 3.125rem;
      padding-block: 6.25rem;
      overflow: hidden;
      background: var(--approach-color-muted);
    }

    .approach-intro::before {
      position: absolute;
      inset: 0;
      z-index: 0;
      background: url('/images/pages/our-approach/topography-light.svg') center / cover no-repeat;
      content: '';
    }

    .approach-intro > .approach-shell {
      position: relative;
      z-index: 1;
    }

    .approach-intro .approach-eyebrow,
    .approach-intro h2 {
      text-align: center;
    }

    .approach-intro h2 {
      margin: 0;
      color: var(--approach-color-text);
      font-size: var(--approach-h2-size);
      font-weight: 900;
      line-height: var(--approach-h2-line-height);
      letter-spacing: 0;
    }

    .approach-intro__grid {
      display: grid;
      grid-template-columns: minmax(0, 2fr) minmax(16rem, 1fr);
      align-items: center;
      gap: 3.125rem;
      margin-block-start: 3.75rem;
      padding-inline: 0.625rem;
    }

    .approach-intro__copy p {
      margin: 0;
      color: var(--approach-color-text);
      font-size: var(--approach-body-size);
      font-weight: 400;
      line-height: var(--approach-body-line-height);
    }

    .approach-intro__media {
      overflow: hidden;
      border-radius: 2.5rem;
      background: var(--color-white);
    }

    .approach-intro__media img {
      inline-size: 100%;
      block-size: 22.125rem;
      object-fit: cover;
      object-position: center;
    }

    .approach-callout {
      position: relative;
      isolation: isolate;
      padding-block: 3.125rem 2.5rem;
      overflow: hidden;
      background: var(--approach-color-text);
      color: var(--color-white);
    }

    .approach-callout::before {
      position: absolute;
      inset: 0;
      z-index: 0;
      background:
        var(--approach-color-text)
        url('/images/pages/our-approach/contact-bg-fc.svg') center / cover no-repeat;
      content: '';
    }

    .approach-callout > .approach-shell {
      position: relative;
      z-index: 1;
    }

    .approach-callout__grid {
      display: grid;
      grid-template-columns: minmax(0, 3fr) minmax(14rem, 2fr);
      align-items: center;
      gap: 3.125rem;
      padding-inline: 3.75rem;
    }

    .approach-callout h2 {
      margin: 0;
      color: var(--color-white);
      font-family: var(--font-body);
      font-size: var(--approach-callout-size);
      font-weight: 700;
      line-height: var(--approach-callout-line-height);
      letter-spacing: 0;
    }

    .approach-callout__action {
      display: flex;
      justify-content: flex-end;
    }

    .approach-callout .btn,
    .approach-partnerships__cta .btn {
      border-radius: 2.1875rem;
      background: var(--approach-color-green);
      color: var(--approach-color-text);
      font-size: var(--approach-button-size);
      font-weight: 500;
      line-height: var(--approach-button-line-height);
      padding: 1.125rem 2.8125rem;
    }

    .approach-callout .btn:hover,
    .approach-partnerships__cta .btn:hover {
      background: var(--approach-color-green-hover);
    }

    .approach-advantages {
      position: relative;
      isolation: isolate;
      padding-block: 6.25rem;
      overflow: hidden;
      background: var(--approach-color-muted);
    }

    .approach-advantages::before {
      position: absolute;
      inset: 0;
      z-index: 0;
      background: url('/images/pages/our-approach/streets-light.svg') center / cover no-repeat;
      content: '';
      opacity: 0.5;
    }

    .approach-advantages > .approach-shell {
      position: relative;
      z-index: 1;
    }

    .approach-advantages__accordion {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 6.25rem;
      margin-block-start: 6.25rem;
    }

    .approach-advantages__column {
      display: grid;
      align-content: start;
      gap: 1.5625rem;
    }

    .approach-advantages__item {
      position: relative;
      padding: 0.625rem 1.25rem 0.625rem 2.1875rem;
    }

    .approach-advantages__rail {
      position: absolute;
      inset-block: 0;
      inset-inline-start: 0.3125rem;
      inline-size: 0.375rem;
      overflow: hidden;
      border-radius: 999px;
      background: rgba(35, 31, 32, 0.15);
    }

    .approach-advantages__rail span {
      position: absolute;
      inset-inline: 0;
      inset-block-end: 0;
      block-size: 0;
      border-radius: inherit;
      background: var(--approach-color-text);
      transition: block-size var(--transition-base);
    }

    .approach-advantages__item.is-open .approach-advantages__rail span {
      block-size: 100%;
    }

    .approach-advantages__item h3 {
      margin: 0;
      font-family: var(--font-body);
      font-size: var(--approach-control-size);
      font-weight: 700;
      line-height: var(--approach-control-line-height);
      letter-spacing: 0;
    }

    .approach-advantages__trigger {
      display: inline-flex;
      inline-size: 100%;
      border: 0;
      background: transparent;
      color: var(--approach-color-text);
      font: inherit;
      font-weight: 700;
      text-align: left;
      cursor: pointer;
    }


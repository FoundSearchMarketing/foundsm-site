---
import BaseLayout from '../layouts/BaseLayout.astro';
import ConfirmationHero from '../components/modern/ConfirmationHero.astro';

const title = "Safelist Found's Newsletter";
const description = 'To make sure our emails land straight in your inbox and not your spam or junk folder, follow these quick steps to safelist us.';
const canonical = 'https://www.foundsm.com/safelist';
const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  url: canonical,
  description,
  publisher: {
    '@type': 'Organization',
    name: 'Found Search Marketing',
    url: 'https://www.foundsm.com',
  },
};
---

<BaseLayout title={title} description={description} canonical={canonical} schema={schema}>
  <ConfirmationHero
    title="Thank You for Signing Up!"
    intro="So glad you've found your way to us, welcome aboard! To make sure our emails land straight in your inbox and not your spam or junk folder, follow these quick steps to safelist us:"
  />

  <section class="safelist-steps" aria-labelledby="safelist-steps-heading">
    <div class="safelist-steps__inner">
      <p class="safelist-steps__eyebrow" id="safelist-steps-heading">How to Safelist Our Emails</p>
      <div class="safelist-steps__grid">
        <article class="safelist-card">
          <h2>Gmail</h2>
          <ol>
            <li>Open Gmail and go to <strong>Settings &gt; See all settings</strong>.</li>
            <li>Click the <strong>Filters and Blocked Addresses</strong> tab and select <strong>Create a new filter</strong>.</li>
            <li>Add our email (marketing@foundsm.com) in the <strong>From</strong> field and click <strong>Create filter</strong>.</li>
            <li>Check <strong>Never send it to Spam</strong>, then hit <strong>Create filter</strong> again.</li>
          </ol>
        </article>

        <article class="safelist-card">
          <h2>Outlook</h2>
          <ol>
            <li>Open Outlook and go to <strong>Settings &gt; View all Outlook settings</strong>.</li>
            <li>Navigate to <strong>Mail</strong> &gt; <strong>Junk email</strong>.</li>
            <li>Under <strong>Safe senders and domains</strong>, click <strong>Add</strong> and enter our email (marketing@foundsm.com) or domain (foundsm.com).</li>
            <li>Hit <strong>Save</strong> to confirm.</li>
          </ol>
        </article>

        <article class="safelist-card">
          <h2>Yahoo</h2>
          <ol>
            <li>Go to <strong>Settings &gt; More Settings &gt; Filters</strong>.</li>
            <li>Click <strong>Add new filters</strong> and name it, such as "Newsletter".</li>
            <li>Add our email (marketing@foundsm.com) under the <strong>From</strong> field and set it to send to your <strong>Inbox</strong>.</li>
            <li>Click <strong>Save</strong>.</li>
          </ol>
        </article>
      </div>
    </div>
  </section>

  <section class="safelist-closing" aria-label="Safelist confirmation">
    <div class="safelist-closing__inner">
      <p>That's it! You're all set to stay updated with our latest news, tips, and exclusive content. If you don't see our emails, check your spam folder just in case.</p>
      <h2>Happy reading!</h2>
    </div>
  </section>
</BaseLayout>

<style>
  .safelist-steps {
    padding: 4rem var(--gutter);
    background: #f2f3f2;
  }

  .safelist-steps__inner {
    inline-size: min(100%, var(--content-max-width));
    margin-inline: auto;
  }

  .safelist-steps__eyebrow {
    margin: 0 0 2.125rem;
    color: var(--color-dark);
    font-size: 1.625rem;
    font-weight: 700;
    line-height: 1.2;
    text-align: center;
  }

  .safelist-steps__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.375rem;
  }

  .safelist-card {
    display: grid;
    align-content: start;
    gap: 1rem;
    min-inline-size: 0;
    padding: 1.75rem;
    border: 1px solid rgba(26, 26, 26, 0.12);
    border-radius: 0.5rem;
    background: #ffffff;
    box-shadow: 0 16px 34px rgba(26, 26, 26, 0.06);
  }

  .safelist-card h2 {
    margin: 0;
    font-size: 1.75rem;
    line-height: 1.2;
    letter-spacing: 0;
  }

  .safelist-card ol {
    display: grid;
    gap: 0.625rem;
    margin: 0;
    padding-inline-start: 1.25rem;
    color: rgba(26, 26, 26, 0.78);
    font-size: 1rem;
    line-height: 1.62;
    list-style: decimal;
  }

  .safelist-closing {
    padding: 3.5rem var(--gutter) 4.5rem;
    background: #ffffff;
    text-align: center;
  }

  .safelist-closing__inner {
    display: grid;
    gap: 1.125rem;
    inline-size: min(100%, 58rem);
    margin-inline: auto;
  }

  .safelist-closing p {
    color: rgba(26, 26, 26, 0.78);
    font-size: 1.25rem;
    line-height: 1.75;
  }

  .safelist-closing h2 {
    margin: 0;
    font-size: 2.625rem;
    line-height: 1.12;
    letter-spacing: 0;
  }

  @media (max-width: 1024px) {
    .safelist-steps__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .safelist-steps,
    .safelist-closing {
      padding-block: 3rem;
    }

    .safelist-card {
      padding: 1.25rem;
    }

    .safelist-closing p {
      font-size: 1rem;
      line-height: 1.65;
    }

    .safelist-closing h2 {
      font-size: 2.125rem;
    }
  }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Signal Quiz - Found Search Marketing';
const description = 'Are you scaling profit or just burning cash? Answer 7 questions to uncover your Revenue Engineering Score and identify the leaks in your paid media budget.';
const canonical = 'https://www.foundsm.com/signal-quiz';
const ogImage = 'https://foundsm.com/found2025/wp-content/uploads/2026/03/signal-quiz-feature.webp';
const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  url: canonical,
  description,
  image: ogImage,
  publisher: {
    '@type': 'Organization',
    name: 'Found Search Marketing',
    url: 'https://www.foundsm.com',
  },
};
---

<BaseLayout title={title} description={description} canonical={canonical} ogImage={ogImage} schema={schema}>
  <section class="signal-quiz" aria-labelledby="signal-quiz-heading">
    <div class="signal-quiz__inner">
      <div class="signal-quiz__copy">
        <h1 id="signal-quiz-heading">Curious where your organization stands?</h1>
        <p>Take the quiz to find out.</p>
      </div>
      <div class="signal-quiz__embed">
        <div class="involveme_embed" data-project="quiz" data-title="Revenue Engineering Assessment - Embedded"></div>
      </div>
    </div>
  </section>

  <script is:inline src="https://datasignals.foundsm.com/embed" defer></script>
</BaseLayout>

<style>
  .signal-quiz {
    min-block-size: 44rem;
    padding: 5.5rem var(--gutter);
    background-color: #231f20;
    background-image: url("https://foundsm.com/found2025/wp-content/uploads/2025/11/map.png");
    background-position: center;
    background-repeat: no-repeat;
    background-size: cover;
    color: #ffffff;
  }

  .signal-quiz__inner {
    display: grid;
    justify-items: center;
    gap: 2rem;
    inline-size: min(100%, 58rem);
    margin-inline: auto;
    text-align: center;
  }

  .signal-quiz__copy {
    display: grid;
    gap: 0.75rem;
  }

  .signal-quiz h1 {
    margin: 0;
    color: #ffffff;
    font-family: var(--font-body);
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: 0;
  }

  .signal-quiz p {
    margin: 0;
    color: #ffffff;
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.15;
  }

  .signal-quiz__embed {
    inline-size: min(100%, 56rem);
    min-block-size: 35rem;
    padding: 1.25rem;
    border-radius: 0.5rem;
    background: #ffffff;
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.18);
  }

  :global(.signal-quiz__embed iframe) {
    inline-size: 100%;
  }

  @media (max-width: 640px) {
    .signal-quiz {
      min-block-size: 36rem;
      padding-block: 3rem;
    }

    .signal-quiz h1,
    .signal-quiz p {
      font-size: 2.125rem;
    }

    .signal-quiz__embed {
      min-block-size: 28rem;
      padding: 1rem;
    }
  }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import ModernHero from '../components/modern/ModernHero.astro';
import StatementBand from '../components/modern/StatementBand.astro';
import LeadershipGrid from '../components/modern/LeadershipGrid.astro';
import CtaPanel from '../components/modern/CtaPanel.astro';
import { allTeamMembersQuery, sanityClient, teamPageQuery } from '../lib/sanity';
import { defaultTeamPageData, mergeTeamPageData } from '../lib/morePageData';
import { imageProps, richHtml, richText, srcFor } from '../lib/fixedPageRender';

const [sanityPage, sanityLeaders] = await Promise.all([
  sanityClient.fetch(teamPageQuery).catch(() => null),
  sanityClient.fetch(allTeamMembersQuery).catch(() => []),
]);
const page = mergeTeamPageData(sanityPage);
const title = page.seoTitle || defaultTeamPageData.seoTitle;
const description = page.seoDescription || defaultTeamPageData.seoDescription;
const canonical = page.canonicalUrl || defaultTeamPageData.canonicalUrl;
const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  url: canonical,
  description,
  publisher: {
    '@type': 'Organization',
    name: 'Found Search Marketing',
    url: 'https://www.foundsm.com',
  },
};

const defaultLeadersByName = new Map((page.leaders || []).filter((leader) => leader.name).map((leader) => [leader.name, leader]));
const leaderSource = (sanityLeaders?.length ? sanityLeaders : page.leaders) || [];
const leaders = leaderSource
  .map((leader, index) => {
    const fallback = (leader.name && defaultLeadersByName.get(leader.name)) || page.leaders[index] || {};
    return {
      name: leader.name || fallback.name || '',
      role: leader.role || fallback.role || '',
      image: srcFor(leader.image) || srcFor(fallback.image),
    };
  })
  .filter((leader) => leader.name);
---

<BaseLayout title={title} description={description} canonical={canonical} robots={page.robots} schema={schema}>
  <ModernHero
    tone="light"
    title={page.hero.heading || ''}
    intro={richText(page.hero.body)}
    introHtml={richHtml(page.hero.body)}
    cta={page.hero.cta?.label && page.hero.cta?.href ? { label: page.hero.cta.label, href: page.hero.cta.href } : undefined}
    image={imageProps(page.hero, 'eager')}
    imageShape="rounded"
    mediaHeight="33rem"
    className="team-hero"
  />

  <StatementBand
    lead={page.statement.lead || ''}
    body={richText(page.statement.body)}
    bodyHtml={richHtml(page.statement.body)}
    pattern
    width="narrow"
  />

  <LeadershipGrid
    layout="centered"
    title={page.leadership.heading || ''}
    intro={richText(page.leadership.body)}
    introHtml={richHtml(page.leadership.body)}
    leaders={leaders}
  />

  <CtaPanel
    theme="white"
    align="centered"
    title={page.cta.heading}
    body={richText(page.cta.body)}
    bodyHtml={richHtml(page.cta.body)}
    ctaLabel={page.cta.cta?.label}
    ctaHref={page.cta.cta?.href}
  />
</BaseLayout>

<style>
  :global(.team-hero) {
    padding-block: 6.25rem 4.5rem;
    padding-inline: 1.5625rem;
  }

  :global(.team-hero .modern-hero__inner) {
    align-items: start;
    gap: 6.25rem;
  }

  :global(.team-hero .modern-hero__intro) {
    max-inline-size: 43rem;
  }

  @media (max-width: 1024px) {
    :global(.team-hero) {
      padding: 1.25rem 1.25rem 3rem;
    }

    :global(.team-hero .modern-hero__media) {
      display: none;
    }
  }
</style>

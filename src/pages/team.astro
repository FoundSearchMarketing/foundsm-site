---
import BaseLayout from '../layouts/BaseLayout.astro';
import ModernHero from '../components/modern/ModernHero.astro';
import StatementBand from '../components/modern/StatementBand.astro';
import LeadershipGrid from '../components/modern/LeadershipGrid.astro';
import CtaPanel from '../components/modern/CtaPanel.astro';

const title = 'Our Team | Found Search Marketing';
const description = 'Found Search Marketing brings deep channel expertise, custom analytics, and agile strategy together to maximize performance across your entire media ecosystem.';
const canonical = 'https://www.foundsm.com/team';
const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  url: canonical,
  description,
  publisher: {
    '@type': 'Organization',
    name: 'Found Search Marketing',
    url: 'https://www.foundsm.com',
  },
};

const leaders = [

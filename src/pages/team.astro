---
import BaseLayout from '../layouts/BaseLayout.astro';
import ModernHero from '../components/modern/ModernHero.astro';
import StatementBand from '../components/modern/StatementBand.astro';
import LeadershipGrid from '../components/modern/LeadershipGrid.astro';
import { allTeamMembersQuery, sanityClient, teamPageQuery } from '../lib/sanity';
import { defaultTeamPageData, mergeTeamPageData } from '../lib/morePageData';
import { imageProps, richHtml, richText, srcFor } from '../lib/fixedPageRender';

const [sanityPage, sanityLeaders] = await Promise.all([
  sanityClient.fetch(teamPageQuery).catch(() => null),
  sanityClient.fetch(allTeamMembersQuery).catch(() => []),
]);
const page = mergeTeamPageData(sanityPage);
const title = page.seoTitle || defaultTeamPageData.seoTitle;
const description = page.seoDescription || defaultTeamPageData.seoDescription;
const canonical = page.canonicalUrl || defaultTeamPageData.canonicalUrl;
const careersHref = '/about-us/#careers';
const heroCta = page.hero.cta?.label ? { label: page.hero.cta.label, href: careersHref } : undefined;
const careersCta = page.cta.cta?.label ? { label: page.cta.cta.label, href: careersHref } : undefined;
const careersBodyHtml = richHtml(page.cta.body);
const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  url: canonical,
  description,
  publisher: {
    '@type': 'Organization',
    name: 'Found Search Marketing',
    url: 'https://foundsm.com',
  },
};

const defaultLeadersByName = new Map((page.leaders || []).filter((leader) => leader.name).map((leader) => [leader.name, leader]));
const leaderSource = (sanityLeaders?.length ? sanityLeaders : page.leaders) || [];
const leaders = leaderSource
  .map((leader, index) => {
    const fallback = (leader.name && defaultLeadersByName.get(leader.name)) || page.leaders[index] || {};
    return {
      name: leader.name || fallback.name || '',
      role: leader.role || fallback.role || '',
      image: srcFor(leader.image),
      videoUrl: leader.videoUrl || fallback.videoUrl,
    };
  })
  .filter((leader) => leader.name);
---

<BaseLayout title={title} description={description} canonical={canonical} robots={page.robots} schema={schema}>
  <ModernHero
    tone="light"
    title={page.hero.heading || ''}
    intro={richText(page.hero.body)}
    introHtml={richHtml(page.hero.body)}
    cta={heroCta}
    image={imageProps(page.hero, 'eager')}
    imageShape="rounded"
    mediaHeight="33rem"
    className="team-hero"
  />

  <StatementBand
    lead={page.statement.lead || ''}
    body={richText(page.statement.body)}
    bodyHtml={richHtml(page.statement.body)}
    pattern
    width="narrow"
  />

  <LeadershipGrid
    layout="centered"
    title={page.leadership.heading || ''}
    intro={richText(page.leadership.body)}
    introHtml={richHtml(page.leadership.body)}
    leaders={leaders}
    showImages
  />

  <section class="team-careers-cta" aria-labelledby="team-careers-heading">
    <div class="team-careers-cta__inner">
      <div class="team-careers-cta__copy">
        <h2 id="team-careers-heading">{page.cta.heading}</h2>
        {careersBodyHtml && <div set:html={careersBodyHtml} />}
      </div>
      {careersCta && <a class="team-careers-cta__button" href={careersCta.href}>{careersCta.label}</a>}
    </div>
  </section>

</BaseLayout>

<style>
  :global(.team-hero) {
    padding-block: 6.25rem 4.5rem;
    padding-inline: 1.5625rem;
  }

  :global(.team-hero .modern-hero__inner) {
    align-items: start;
    gap: 6.25rem;
  }

  :global(.team-hero .modern-hero__intro) {
    max-inline-size: 43rem;
  }

  .team-careers-cta {
    padding: clamp(3.5rem, 6vw, 5rem) var(--gutter);
    background: #231f20;
    color: #ffffff;
  }

  .team-careers-cta__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 2rem;
    inline-size: min(100%, var(--content-max-width));
    margin-inline: auto;
  }

  .team-careers-cta__copy {
    display: grid;
    gap: 1rem;
    max-inline-size: 52rem;
  }

  .team-careers-cta h2 {
    margin: 0;
    color: #ffffff;
    font-size: clamp(2.35rem, 4vw, 4rem);
    font-weight: 900;
    line-height: 1.05;
  }

  .team-careers-cta__copy :global(p) {
    margin: 0;
    color: rgba(255, 255, 255, 0.84);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .team-careers-cta__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-block-size: 3.5rem;
    padding: 0.9rem 1.8rem;
    border-radius: 999px;
    background: #8bc53f;
    color: #1a1a1a;
    font-weight: 800;
    line-height: 1.2;
    text-align: center;
    transition:
      background-color var(--transition-fast),
      transform var(--transition-fast);
  }

  .team-careers-cta__button:hover,
  .team-careers-cta__button:focus-visible {
    background: #a4d96a;
    transform: translateY(-1px);
  }

  @media (max-width: 1024px) {
    :global(.team-hero) {
      padding: 1.25rem 1.25rem 3rem;
    }

    :global(.team-hero .modern-hero__media) {
      display: none;
    }

    .team-careers-cta__inner {
      grid-template-columns: 1fr;
      justify-items: start;
    }
  }
</style>

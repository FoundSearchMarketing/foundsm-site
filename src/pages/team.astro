---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Our Team | Found Search Marketing",
  "description": "Meet the talented team behind Found Search Marketing.",
  "url": "https://www.foundsm.com/team",
  "publisher": {
    "@type": "Organization",
    "name": "Found Search Marketing",
    "url": "https://www.foundsm.com"
  }
};
---

<BaseLayout
  title="Our Team | Found Search Marketing"
  description="Meet the talented team behind Found Search Marketing. Our experts in paid media, data intelligence, and performance creative drive results for enterprise brands."
  canonical="https://www.foundsm.com/team"
  schema={schema}
>

        <!-- Hero Section -->
        <section class="hero hero-dark" aria-labelledby="team-hero-heading">
            <div class="container">
                <div class="hero-content fade-in-up">
                    <h1 id="team-hero-heading">Our Team</h1>
                    <p class="hero-subtitle">Meet the talented people behind Found Search Marketing. Our diverse team of strategists, analysts, creatives, and technologists work together to deliver exceptional results for enterprise brands.</p>
                </div>
            </div>
        </section>

        <!-- Team Grid Section -->

---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleTeaserGrid from '../components/modern/ArticleTeaserGrid.astro';
import ConfirmationHero from '../components/modern/ConfirmationHero.astro';
import { getLatestBlogPosts } from '../lib/blogPosts';

const title = 'Thank You';
const description = 'Thank you for reaching out to Found.';
const canonical = 'https://www.foundsm.com/thank-you';
const latestPosts = await getLatestBlogPosts(6);
const articles = latestPosts.map((post) => ({
  title: post.title,
  href: `/insights/${post.slug}/`,
  categories: post.categories.map((category) => category.label),
  dateLabel: post.publishedLabel,
  datetime: post.publishedAt,
  excerpt: post.excerpt,
  image: post.heroImage
    ? {
        src: post.heroImage,
        width: 768,
        height: 513,
        alt: post.heroImageAlt || post.title,
      }
    : undefined,
}));
const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  url: canonical,
  description,
  publisher: {
    '@type': 'Organization',
    name: 'Found Search Marketing',
    url: 'https://www.foundsm.com',
  },
};
---

<BaseLayout title={title} description={description} canonical={canonical} schema={schema}>
  <ConfirmationHero
    title="You've Just Made a Smart Move."
    intro={[
      'Thanks for connecting with Found!',
      'Someone from our team will reach out within 1-2 business days to talk about how we can help you grow faster, smarter, and with data on your side.',
    ]}
  />

  <section class="thank-you-insights" aria-labelledby="thank-you-insights-heading">
    <div class="thank-you-insights__inner">
      <h2 id="thank-you-insights-heading">Curious? Dive Into Our Latest Insights Below.</h2>
      <ArticleTeaserGrid articles={articles} />
    </div>
  </section>
</BaseLayout>

<style>
  .thank-you-insights {
    padding: 2rem var(--gutter) 5rem;
    background: #ffffff;
  }

  .thank-you-insights__inner {
    display: grid;
    gap: 2.125rem;
    inline-size: min(100%, var(--content-max-width));
    margin-inline: auto;
  }

  .thank-you-insights h2 {
    max-inline-size: 48rem;
    margin: 0 auto;
    font-size: 3.25rem;
    line-height: 1.12;
    letter-spacing: 0;
    text-align: center;
  }

  @media (max-width: 640px) {
    .thank-you-insights {
      padding-block: 1.5rem 3.5rem;
    }

    .thank-you-insights h2 {
      font-size: 2.25rem;
      line-height: 1.15;
    }
  }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'The Startup Ladies \u2192 Data Activation';
const description = "In today's AI marketing landscape, data is your most valuable asset, but most companies don't use it to its full potential or may not have the proper foundation set up to measure or report on metrics.";
const canonical = 'https://www.foundsm.com/whitepapers';
const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  url: canonical,
  description,
  publisher: {
    '@type': 'Organization',
    name: 'Found Search Marketing',
    url: 'https://www.foundsm.com',
  },
};
---

<BaseLayout title={title} description={description} canonical={canonical} schema={schema}>
  <section class="whitepaper-landing" aria-labelledby="whitepaper-heading">
    <div class="whitepaper-landing__inner">
      <h1 id="whitepaper-heading">You've built something great.<br />Now let data fuel your growth.</h1>
      <p>Found turns your data into a growth engine for smarter targeting and faster ROI.</p>
      <a class="whitepaper-landing__button" href="https://meetings.hubspot.com/brian2204/tsl">Let's Chat Data &mdash; Grab a Spot on Our Calendar &rarr;</a>
    </div>
  </section>
</BaseLayout>

<style>
  .whitepaper-landing {
    display: grid;
    place-items: center;
    min-block-size: 42rem;
    padding: 6rem var(--gutter);
    background-color: #231f20;
    background-image: url("https://foundsm.com/found2025/wp-content/uploads/2025/11/map.png");
    background-position: center;
    background-repeat: no-repeat;
    background-size: cover;
    color: #ffffff;
    text-align: center;
  }

  .whitepaper-landing__inner {
    display: grid;
    justify-items: center;
    gap: 1.5rem;
    inline-size: min(100%, 58rem);
  }

  .whitepaper-landing h1 {
    margin: 0;
    color: #ffffff;
    font-size: clamp(2.75rem, 6vw, 4.5rem);
    line-height: 1.05;
    letter-spacing: 0;
  }

  .whitepaper-landing p {
    max-inline-size: 44rem;
    margin: 0;
    color: rgba(255, 255, 255, 0.86);
    font-size: 1.5rem;
    line-height: 1.55;
  }

  .whitepaper-landing__button {
    display: inline-flex;
    justify-content: center;
    min-block-size: 3.75rem;
    padding: 1rem 1.875rem;
    border-radius: 999px;
    background: var(--color-primary);
    color: #1a1a1a;
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.25;
    text-align: center;
    transition: background-color var(--transition-fast), transform var(--transition-fast);
  }

  .whitepaper-landing__button:hover,
  .whitepaper-landing__button:focus-visible {
    background: #b9dc89;
    transform: translateY(-1px);
  }

  @media (max-width: 640px) {
    .whitepaper-landing {
      min-block-size: 34rem;
      padding-block: 4rem;
    }

    .whitepaper-landing h1 {
      font-size: 2.5rem;
    }

    .whitepaper-landing p {
      font-size: 1.125rem;
      line-height: 1.65;
    }

    .whitepaper-landing__button {
      min-block-size: 3.25rem;
      padding: 0.875rem 1.25rem;
      font-size: 1rem;
    }
  }
</style>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LegacyPageRenderer from '../../components/legacy/LegacyPageRenderer.astro';
import WordPressMatchPage from '../../components/wordpress/WordPressMatchPage.astro';
import { loadLegacyPages } from '../../lib/legacyPageFetch';
import { getLegacyPageDefinitionsByGroup, pathToSingleSlug, type LegacyPageData } from '../../lib/legacyPageData';

export async function getStaticPaths() {
  const whitepaperDefinitions = getLegacyPageDefinitionsByGroup('whitepapers').filter((definition) => definition.path !== '/whitepapers/');
  const pages = await loadLegacyPages(whitepaperDefinitions);

  return whitepaperDefinitions.map((definition) => ({
    params: { slug: pathToSingleSlug(definition.path) },
    props: { page: pages.get(definition.path) },
  }));
}

interface Props {
  page: LegacyPageData;
}

const { page } = Astro.props;
const isFirstPartyData = page.path === '/whitepapers/first-party-data/';
const firstPartyTitle = 'Why First-Party Data Is Your Most Valuable Profit Lever';
const firstPartyDescription = "In this comprehensive technical guide, you'll learn how to architect a closed-loop data system that feeds real revenue intelligence (not noisy browser signals) back into your ad platforms. You'll discover how to capture durable identifiers, store them in a resilient first-party framework, and push enriched, truth-based events directly into Google, Meta, LinkedIn, and beyond.";
const firstPartyOgImage = 'https://foundsm.com/found2025/wp-content/uploads/2026/03/first-party-whitepaper-feature.webp';
---

<BaseLayout
  title={isFirstPartyData ? firstPartyTitle : page.seoTitle}
  description={isFirstPartyData ? firstPartyDescription : page.seoDescription}
  canonical={page.canonicalUrl}
  ogImage={isFirstPartyData ? firstPartyOgImage : page.ogImage}
  robots={page.robots}
  bodyClass={isFirstPartyData ? 'wordpress-match-page' : 'legacy-page'}
>
  {isFirstPartyData ? <WordPressMatchPage variant="first-party-data" /> : <LegacyPageRenderer page={page} />}
</BaseLayout>

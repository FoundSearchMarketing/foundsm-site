---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ResourceLanding from '../../components/modern/ResourceLanding.astro';
import { getLandingPageBySlug } from '../../data/legacyResources';

const page = getLandingPageBySlug('first-party-data');
const canonical = 'https://www.foundsm.com/whitepapers/first-party-data/';
---

<BaseLayout title={page.seoTitle} description={page.description} canonical={canonical}>
  <ResourceLanding page={page} />
</BaseLayout>

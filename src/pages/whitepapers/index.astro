---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WordPressMatchPage from '../../components/wordpress/WordPressMatchPage.astro';
import { loadLegacyPage } from '../../lib/legacyPageFetch';
import { getLegacyPageDefinitionByPath } from '../../lib/legacyPageData';

const definition = getLegacyPageDefinitionByPath('/whitepapers/');
if (!definition) throw new Error('Missing legacy page definition for /whitepapers/.');

const page = await loadLegacyPage(definition);
---

<BaseLayout
  title="The Startup Ladies → Data Activation"
  description="Found turns your data into a growth engine for smarter targeting and faster ROI."
  canonical={page.canonicalUrl}
  ogTitle={page.ogTitle}
  ogDescription={page.ogDescription}
  ogImage={page.ogImage}
  robots={page.robots}
  twitterCard={page.twitterCard}
  twitterTitle={page.twitterTitle}
  twitterDescription={page.twitterDescription}
  twitterImage={page.twitterImage}
  schemaJson={page.schemaJson}
  bodyClass="wordpress-match-page"
>
  <WordPressMatchPage variant="whitepapers-index" />
</BaseLayout>
